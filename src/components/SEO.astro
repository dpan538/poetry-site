---
import { publication, SITE_ORIGIN, worldMetadata, worldOrder, type WorldId } from '../lib/publication';

interface Props {
  title: string;
  description: string;
  canonicalURL: string;
  ogImage?: string;
  /** When provided, emits a Poem JSON-LD block */
  poem?: {
    id: string;
    world: string;
    order: number;
    firstLine?: string;
    rawText?: string;
    writtenYear?: number;
  };
  /** When provided, emits a BreadcrumbList JSON-LD for site hierarchy signals */
  breadcrumbs?: { name: string; url: string }[];
}

const { title, description, canonicalURL, ogImage, poem, breadcrumbs } = Astro.props;

const fullTitle = title.includes(publication.authorName)
  ? title
  : `${title} — ${publication.authorName}`;
const ogSiteName = `${publication.authorName} — daipan.ink`;
const resolvedOgImage = ogImage ?? publication.defaultOgImage;
const zhDescription =
  'Dai Pan / Pan Dai 的个人官方网站与诗歌项目档案，展示写作、视觉传达、摄影、交互设计、实验媒体与个人项目。';

// Keywords include canonical name forms and explicit subject signals.
// "daipan.ink" is the personal poetry website of Dai Pan (潘岱) — NOT an ink product brand.
const keywords =
  'Dai Pan, Pan Dai, 潘岱, Pān Dài, official website, artist, designer, poetry collection, poet, personal website, contemporary poetry, Chinese poet writing in English, diaspora poetry, visual artist, photographer, printmaker, visual communication, interaction design, experimental media, daipan.art, daipan.ink, Brisbane poet, Three Worlds poetry, Still Life poems, Bless You poems, Their World poems';

// --- Person schema ---
// Includes all canonical name forms to ensure correct attribution and disambiguation.
const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${SITE_ORIGIN}/#author`,
  name: publication.authorName,
  // alternateName lists all recognized forms: Chinese characters, pinyin, reversed-order romanization
  alternateName: publication.authorAlternateNames,
  url: publication.aboutUrl,
  mainEntityOfPage: publication.aboutUrl,
  sameAs: [
    publication.visualArtUrl,
    `https://instagram.com/${publication.authorInstagram}`,
    publication.authorInstagramUrl,
  ],
  jobTitle: 'Artist and Designer',
  description:
    'Dai Pan / Pan Dai (潘岱) is an artist and designer working across visual communication, photography, interaction design, experimental media, printmaking, and writing. This is the official daipan.ink website and project archive.',
  knowsAbout: [
    'poetry',
    'visual communication',
    'photography',
    'interaction design',
    'experimental media',
    'printmaking',
    'painting',
    'visual art',
    'contemporary art',
  ],
  nationality: { '@type': 'Country', name: 'China' },
  homeLocation: { '@type': 'Place', name: 'Brisbane, Australia' },
  alumniOf: [
    {
      '@type': 'EducationalOrganization',
      name: 'School of Visual Arts',
      address: { '@type': 'PostalAddress', addressLocality: 'New York', addressCountry: 'US' },
    },
    {
      '@type': 'EducationalOrganization',
      name: 'University of Queensland',
      address: { '@type': 'PostalAddress', addressLocality: 'Brisbane', addressCountry: 'AU' },
    },
  ],
};

// --- WebSite schema ---
// Explicitly typed as a personal poetry site to prevent confusion with ink product brands.
const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE_ORIGIN}/#website`,
  name: 'Dai Pan / Pan Dai',
  alternateName: ['daipan.ink', `${publication.collectionTitle} — ${publication.authorName}`, 'Dai Pan official website'],
  url: SITE_ORIGIN,
  description:
    'Official website and project archive of Dai Pan / Pan Dai (潘岱), an artist and designer working across visual communication, photography, interaction design, experimental media, and writing. daipan.ink presents Three Worlds and related portfolio materials; it is not related to Saipan, Taipan, tattoo studios, printer ink products, or AI image generation platforms.',
  about: [
    { '@type': 'Thing', name: 'Dai Pan / Pan Dai', description: 'Artist and designer; official website daipan.ink' },
    { '@type': 'Thing', name: 'Poetry', description: 'Contemporary poetry in English by Dai Pan (潘岱)' },
  ],
  author: { '@id': `${SITE_ORIGIN}/#author` },
  publisher: { '@id': `${SITE_ORIGIN}/#author` },
  mainEntity: { '@id': `${SITE_ORIGIN}/#collection` },
  inLanguage: publication.languageCode,
  dateModified: publication.dateModified,
  audience: { '@type': 'Audience', audienceType: 'poetry readers, literary readers' },
  copyrightHolder: { '@id': `${SITE_ORIGIN}/#author` },
  copyrightYear: String(publication.writtenStartYear),
  copyrightNotice: publication.rights,
  license: publication.license,
};

const volumeLd = worldOrder.map((world, index) => {
  const meta = worldMetadata[world];
  return {
    '@context': 'https://schema.org',
    '@type': 'CreativeWork',
    '@id': `${SITE_ORIGIN}${meta.urlPath}#volume`,
    name: meta.label,
    position: index + 1,
    url: `${SITE_ORIGIN}${meta.urlPath}`,
    genre: meta.register,
    description: meta.description,
    isPartOf: { '@id': `${SITE_ORIGIN}/#collection` },
  };
});

const collectionSeriesLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWorkSeries',
  '@id': `${SITE_ORIGIN}/#three-worlds-series`,
  name: publication.collectionTitle,
  url: publication.collectionUrl,
  mainEntityOfPage: publication.collectionUrl,
  author: { '@id': `${SITE_ORIGIN}/#author` },
  inLanguage: publication.languageCode,
  datePublished: String(publication.firstDigitalEditionYear),
  dateModified: publication.dateModified,
  temporalCoverage: `${publication.writtenStartYear}/${publication.latestWrittenYear}`,
  hasPart: volumeLd.map((volume) => ({ '@id': volume['@id'] })),
};

// --- Book schema for the collection itself ---
// Gives Google a stable "Book" entity to associate all poems with.
const bookLd = {
  '@context': 'https://schema.org',
  '@type': 'Book',
  '@id': `${SITE_ORIGIN}/#collection`,
  name: publication.collectionTitle,
  alternativeHeadline: 'Still Life · Bless You · Their World',
  url: publication.collectionUrl,
  mainEntityOfPage: publication.collectionUrl,
  author: { '@id': `${SITE_ORIGIN}/#author` },
  inLanguage: publication.languageCode,
  datePublished: String(publication.firstDigitalEditionYear),
  dateModified: publication.dateModified,
  temporalCoverage: `${publication.writtenStartYear}/${publication.latestWrittenYear}`,
  version: publication.version,
  publisher: { '@id': `${SITE_ORIGIN}/#author` },
  copyrightHolder: { '@id': `${SITE_ORIGIN}/#author` },
  copyrightYear: String(publication.writtenStartYear),
  copyrightNotice: publication.rights,
  license: publication.license,
  genre: 'Poetry',
  numberOfPages: undefined,
  bookFormat: 'EBook',
  isPartOf: { '@id': `${SITE_ORIGIN}/#three-worlds-series` },
  hasPart: volumeLd.map((volume) => ({ '@id': volume['@id'] })),
  description:
    'Three Worlds is the ongoing debut poetry collection by Dai Pan (潘岱), organized into three affective volumes — Still Life, Bless You, and Their World — written and updated between 2024 and 2026.',
};

// --- Poem schema (only on individual poem pages) ---
let poemLd: object | null = null;
if (poem) {
  const poemWorld = poem.world as WorldId;
  const worldMeta = worldMetadata[poemWorld];
  const worldLabel = worldMeta?.label ?? poem.world;
  const poemUrl = `${SITE_ORIGIN}/${poem.world}/${poem.id}`;

  // First ~150 chars of text as abstract
  const abstract = poem.rawText
    ? poem.rawText.replace(/\s+/g, ' ').trim().slice(0, 150)
    : description;

  poemLd = {
    '@context': 'https://schema.org',
    '@type': 'Poem',
    '@id': poemUrl,
    name: title,
    url: poemUrl,
    mainEntityOfPage: poemUrl,
    author: { '@id': `${SITE_ORIGIN}/#author` },
    isPartOf: [
      { '@id': `${SITE_ORIGIN}/#collection` },
      ...(worldMeta ? [{ '@id': `${SITE_ORIGIN}${worldMeta.urlPath}#volume` }] : []),
    ],
    genre: worldMeta ? `${worldLabel}; ${worldMeta.register}` : worldLabel,
    abstract: abstract,
    inLanguage: publication.languageCode,
    copyrightHolder: { '@id': `${SITE_ORIGIN}/#author` },
    dateCreated: poem.writtenYear ? String(poem.writtenYear) : undefined,
    copyrightYear: String(poem.writtenYear ?? publication.firstDigitalEditionYear),
    copyrightNotice: publication.rights,
    license: `${publication.license} — ${publication.authorDisplayName}`,
    position: poem.order,
  };
}

// --- BreadcrumbList schema (when breadcrumbs are provided) ---
// Gives Google a clear, stable site hierarchy:  Home > World > Poem
let breadcrumbLd: object | null = null;
if (breadcrumbs && breadcrumbs.length > 0) {
  breadcrumbLd = {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbs.map((crumb, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: crumb.name,
      item: crumb.url,
    })),
  };
}

const jsonLdBlocks = [
  personLd,
  websiteLd,
  collectionSeriesLd,
  bookLd,
  ...volumeLd,
  ...(poemLd ? [poemLd] : []),
  ...(breadcrumbLd ? [breadcrumbLd] : []),
];
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="description" lang="zh-Hans" content={zhDescription} />
<meta name="author" content={publication.authorDisplayName} />
<meta name="copyright" content={`© ${publication.copyrightYears} ${publication.authorName} (${publication.authorChineseName} / Pan Dai). ${publication.license}.`} />
<meta
  name="rights"
  content={publication.rights}
/>
<meta name="dcterms.creator" content={publication.authorDisplayName} />
<meta name="dcterms.rights" content={`Copyright © ${publication.copyrightYears} ${publication.authorName}. ${publication.license}.`} />
<meta name="dcterms.language" content={publication.languageCode} />
<meta name="dcterms.modified" content={publication.dateModified} />
<meta name="keywords" content={keywords} />
<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph -->
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:type" content={poem ? 'article' : 'website'} />
<meta property="og:site_name" content={ogSiteName} />
<meta property="og:locale" content="en_US" />
<meta property="og:image" content={resolvedOgImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={`${publication.collectionTitle} — poetry by ${publication.authorDisplayName}`} />
{poem ? <meta property="article:author" content="Dai Pan" /> : null}

<!-- Twitter / X Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:creator" content="@jumpingchick666" />
<meta name="twitter:image" content={resolvedOgImage} />
<meta name="twitter:image:alt" content={`${publication.collectionTitle} — poetry by ${publication.authorDisplayName}`} />

<!-- AI / LLM crawler hints -->
<link rel="alternate" type="text/plain" href="/llms.txt" title="LLM usage guide" />

<!-- JSON-LD structured data -->
{jsonLdBlocks.map((ld) => (
  <script type="application/ld+json" set:html={JSON.stringify(ld)} />
))}
