---
// AtlasOverlay.astro
// ATLAS — structural map for daipan.ink
// A static interpretive layer: shows the current poem's position in the attribute field.
interface Props {
  poemId: string;
  world: string;
}
const { poemId, world } = Astro.props;
---

<!-- ATLAS trigger button — fixed top-right on poem pages -->
<button
  id="atlas-trigger"
  class="atlas-trigger"
  aria-label="Open ATLAS — poem structural map"
  data-poem-id={poemId}
  data-world={world}
>
  ATLAS
</button>

<!-- ATLAS overlay -->
<div
  id="atlas-overlay"
  class="atlas-overlay"
  role="dialog"
  aria-label="ATLAS — structural map"
  aria-modal="true"
  aria-hidden="true"
  data-poem-id={poemId}
  data-world={world}
>
  <!-- Header bar -->
  <div class="atlas-header">
    <span class="atlas-wordmark">ATLAS</span>
    <span class="atlas-subtitle">structural map</span>
    <div class="atlas-controls" aria-label="ATLAS zoom controls">
      <button id="atlas-zoom-out" class="atlas-control" aria-label="Zoom out">−</button>
      <button id="atlas-zoom-in" class="atlas-control" aria-label="Zoom in">+</button>
    </div>
    <button id="atlas-close" class="atlas-close" aria-label="Close ATLAS">×</button>
  </div>

  <!-- Legend — not aria-hidden; text labels carry the meaning, color dots are decorative -->
  <div class="atlas-legend">
    <span class="atlas-legend-item atlas-legend-mode">voice</span>
    <span class="atlas-legend-sep">·</span>
    <span class="atlas-legend-item atlas-legend-type">act</span>
    <span class="atlas-legend-sep">·</span>
    <span class="atlas-legend-item atlas-legend-imagery">image</span>
    <span class="atlas-legend-sep">·</span>
    <span class="atlas-legend-item atlas-legend-pressure">pressure</span>
    <span class="atlas-legend-sep">·</span>
    <span class="atlas-legend-item atlas-legend-form">form</span>
    <span class="atlas-legend-sep">·</span>
    <span class="atlas-legend-item atlas-legend-sense">sense</span>
    <span class="atlas-legend-desc">— drag to pan, scroll to zoom, select a node for detail</span>
  </div>

  <!-- Screen reader text alternative for the canvas — WCAG 1.1.1 / 1.3.1 -->
  <!-- Lists the poem's active attributes so AT users get the same structural information -->
  <p id="atlas-sr-attrs" class="atlas-sr-only" aria-live="polite"></p>

  <!-- Canvas — the attribute field (aria-hidden: AT gets info via atlas-sr-attrs above) -->
  <canvas id="atlas-canvas" class="atlas-canvas" aria-hidden="true"></canvas>

  <!-- Annotation panel — opens beside the graph when a node is selected -->
  <aside id="atlas-anno" class="atlas-anno" role="region" aria-label="ATLAS node detail" aria-live="polite" aria-atomic="true"></aside>
</div>

<style>
  /* ── Trigger button ──────────────────────────────────────────────────────── */
  .atlas-trigger {
    position: fixed;
    top: calc(var(--site-nav-height, 56px) + var(--space-lg, 34px));
    right: max(var(--margin-x, 24px), 12px);
    z-index: 150;
    background: none;
    border: none;
    /* WCAG 2.5.5: 44×44px minimum touch target */
    padding: 12px 8px;
    min-height: 44px;
    display: flex;
    align-items: center;
    cursor: pointer;
    /* font-family: inherit respects per-world font (Helvetica Neue / Futura / Georgia) */
    font-family: inherit;
    font-size: 19px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    /* WCAG 1.4.3: #595959 on #f5f2ed = 6.27:1 ✅ (opacity:0.35 was only 2.17:1 ❌) */
    color: var(--color-meta, #595959);
    opacity: 1;
    line-height: 1.2;
    transition: color 0.2s var(--ui-ease-out, ease);
  }

  .atlas-trigger::after {
    content: '';
    position: absolute;
    left: 8px;
    right: 8px;
    bottom: 8px;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.24s var(--ui-ease-out, ease);
  }

  .atlas-trigger:hover {
    color: var(--color-primary, #1a1a1a);
  }

  .atlas-trigger:hover::after {
    transform: scaleX(1);
  }

  .atlas-trigger:focus-visible {
    outline: 2px solid var(--color-accent, #c0392b);
    outline-offset: 4px;
    border-radius: 1px;
  }

  /* ── Overlay ─────────────────────────────────────────────────────────────── */
  .atlas-overlay {
    position: fixed;
    inset: 0;
    z-index: var(--ui-overlay-z, 900);
    background: var(--color-bg, #f5f2ed);
    display: flex;
    flex-direction: column;
    opacity: 0;
    pointer-events: none;
  }

  .atlas-overlay.is-open { pointer-events: all; }

  /* ── Header ──────────────────────────────────────────────────────────────── */
  .atlas-header {
    display: flex;
    align-items: baseline;
    gap: 12px;
    padding: 22px var(--margin-x, 24px) 0;
    flex-shrink: 0;
  }

  .atlas-wordmark {
    font-size: 18px;
    letter-spacing: 0.16em;
    color: var(--color-primary, #1a1a1a);
    font-family: inherit;
  }

  .atlas-subtitle {
    font-size: 15.5px;
    letter-spacing: 0.06em;
    color: var(--color-meta, #595959);
    font-style: italic;
  }

  .atlas-controls {
    position: fixed;
    right: var(--margin-x, 24px);
    bottom: var(--space-lg, 34px);
    z-index: 24;
    display: flex;
    align-items: center;
    gap: var(--space-sm, 13px);
  }

  .atlas-control {
    min-width: var(--ui-control-size, 52px);
    min-height: var(--ui-control-size, 52px);
    border: 1px solid var(--ui-line, color-mix(in srgb, var(--color-primary, #1a1a1a) 24%, transparent));
    background: var(--ui-surface, color-mix(in srgb, var(--color-bg, #f5f2ed) 90%, white));
    color: var(--color-primary, #1a1a1a);
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 28px;
    font-weight: normal;
    line-height: 1;
    cursor: pointer;
    padding: 0;
    opacity: 1;
    box-shadow: var(--ui-shadow, 0 14px 42px rgba(26, 26, 26, 0.1));
    transition:
      border-color 0.18s ease,
      box-shadow 0.18s ease,
      color 0.18s ease,
      transform 0.24s var(--ui-ease-out, ease);
  }

  .atlas-control:hover {
    border-color: var(--ui-line-strong, color-mix(in srgb, var(--color-primary, #1a1a1a) 46%, transparent));
    box-shadow: var(--ui-shadow-strong, 0 18px 54px rgba(26, 26, 26, 0.14));
    color: var(--color-accent, #c0392b);
    transform: translateY(-1px);
  }

  .atlas-close {
    margin-left: auto;
    min-width: var(--ui-close-size, 44px);
    min-height: var(--ui-close-size, 44px);
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
    color: var(--color-primary, #1a1a1a);
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 52px;
    line-height: 1;
    font-weight: normal;
    opacity: 1;
    transform-origin: center;
    transition: color 0.18s ease, transform 0.22s var(--ui-ease-spring, ease);
  }

  .atlas-close:hover {
    color: var(--color-accent, #c0392b);
    transform: rotate(18deg);
  }

  .atlas-control:focus-visible,
  .atlas-close:focus-visible {
    outline: 2px solid var(--color-accent, #c0392b);
    outline-offset: 4px;
    border-radius: 1px;
  }

  /* ── Legend ──────────────────────────────────────────────────────────────── */
  .atlas-legend {
    display: flex;
    gap: 16px;
    align-items: center;
    padding: 16px var(--margin-x, 24px) 0;
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  .atlas-legend-sep {
    font-size: 12px;
    color: var(--color-meta, #595959);
  }

  .atlas-legend-desc {
    font-size: 16px;
    letter-spacing: 0.02em;
    /* WCAG 1.4.3: opacity:0.75 was only 3.58:1 ❌ — removed, full #595959 = 6.27:1 ✅ */
    color: var(--color-meta, #595959);
    font-style: italic;
    margin-left: 2px;
  }

  .atlas-legend-item {
    font-size: 16.5px;
    letter-spacing: 0.04em;
    color: var(--color-meta, #595959);
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .atlas-legend-item::before {
    content: '';
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .atlas-legend-mode::before   { background: #6f625b; }
  .atlas-legend-type::before   { background: #5e6e80; }
  .atlas-legend-imagery::before { background: #547054; }
  .atlas-legend-pressure::before { background: #8b4f45; }
  .atlas-legend-form::before { background: #7a6475; }
  .atlas-legend-sense::before { background: #806637; }

  /* ── Canvas ──────────────────────────────────────────────────────────────── */
  .atlas-canvas {
    flex: 1;
    width: 100%;
    display: block;
    cursor: grab;
    touch-action: none;
    min-height: 0;
  }

  /* ── Annotation panel — side sheet on desktop, bottom sheet on narrow screens ── */
  .atlas-anno {
    position: absolute;
    top: calc(var(--site-nav-height, 56px) + var(--space-xl, 55px) + var(--space-lg, 34px));
    right: var(--margin-x, 24px);
    width: min(360px, calc(100vw - var(--margin-x, 24px) * 2));
    max-height: calc(100vh - var(--site-nav-height, 56px) - 150px);
    z-index: 20;
    box-sizing: border-box;
    background: color-mix(in srgb, var(--color-bg, #f5f2ed) 94%, white);
    border: 1px solid color-mix(in srgb, var(--color-primary, #1a1a1a) 22%, transparent);
    border-radius: 14px;
    box-shadow: 0 18px 54px rgba(26, 26, 26, 0.14);
    padding: 22px 24px;
    overflow: auto;
    opacity: 0;
    pointer-events: none;
    transform: translateX(12px);
    transition: opacity 0.22s ease, transform 0.22s ease;
  }

  .atlas-anno.is-open {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(0);
  }

  @media (max-width: 760px) {
    .atlas-anno {
      top: auto;
      left: var(--space-md, 21px);
      right: var(--space-md, 21px);
      bottom: var(--space-md, 21px);
      width: auto;
      max-height: 42vh;
      overflow: auto;
      transform: translateY(12px);
    }

    .atlas-anno.is-open {
      transform: translateY(0);
    }
  }

  /* annotation internals (set by JS innerHTML) */
  :global(.atlas-anno-header) {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 9px;
  }

  :global(.atlas-anno-cat) {
    font-size: 11.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    flex-shrink: 0;
    line-height: 1.4;
    padding-top: 3px; /* optical baseline alignment with name */
  }

  /* WCAG 1.4.3: darkened from #9e8e7e/7a8696/728e72 (all ~2.8-3.3:1 ❌) to pass 4.5:1 ✅ */
  :global(.atlas-anno-cat.tag-mode)    { color: #6f625b; }
  :global(.atlas-anno-cat.tag-type)    { color: #5e6e80; } /* 4.68:1 ✅ */
  :global(.atlas-anno-cat.tag-imagery) { color: #547054; } /* 4.92:1 ✅ */
  :global(.atlas-anno-cat.tag-pressure) { color: #8b4f45; }
  :global(.atlas-anno-cat.tag-form) { color: #7a6475; }
  :global(.atlas-anno-cat.tag-sense) { color: #806637; }
  :global(.atlas-anno-cat.tag-their-world) { color: #a92f25; }
  :global(.atlas-anno-cat.tag-bless-you) { color: #7e5f70; }
  :global(.atlas-anno-cat.tag-still-life) { color: #6f876f; }

  :global(.atlas-anno-name) {
    font-size: 23px;
    font-weight: normal;
    font-family: Georgia, 'Times New Roman', serif;
    letter-spacing: -0.01em;
    color: var(--color-primary, #1a1a1a);
    margin: 0;
    line-height: 1.15;
  }

  :global(.atlas-anno-def) {
    margin: 0 0 12px;
    font-size: 15.5px;
    line-height: 1.58;
    color: var(--color-primary, #1a1a1a);
    font-style: italic;
    opacity: 0.92;
  }

  :global(.atlas-anno-body) {
    margin: 0;
    font-size: 15.5px;
    line-height: 1.58;
    color: var(--color-primary, #1a1a1a);
  }

  :global(.atlas-anno-lede) {
    margin: 0 0 16px;
    font-style: italic;
  }

  :global(.atlas-anno-section) {
    margin-top: 14px;
    padding-top: 12px;
    border-top: 1px solid color-mix(in srgb, var(--color-primary, #1a1a1a) 13%, transparent);
  }

  :global(.atlas-anno-section-title) {
    display: block;
    margin-bottom: 5px;
    font-size: 11px;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    color: var(--color-meta, #595959);
    font-style: normal;
  }

  :global(.atlas-anno-section p) {
    margin: 0;
    font-style: italic;
  }

  :global(.atlas-anno-meta) {
    font-size: 13.5px;
    letter-spacing: 0.03em;
    color: var(--color-meta, #595959);
    display: flex;
    gap: 7px;
    align-items: center;
    flex-wrap: wrap;
    line-height: 1.4;
  }

  :global(.atlas-anno-active) {
    color: var(--color-primary, #1a1a1a);
    font-style: normal;
  }

  :global(.atlas-anno-inactive) {
    color: var(--color-meta, #595959);
    font-style: italic;
  }

  :global(.atlas-anno-sep) {
    color: var(--color-meta, #595959);
    font-size: 13px;
  }

  :global(.atlas-anno-count) {
    color: var(--color-meta, #595959);
  }

  /* ── Screen reader only — text alternative for canvas ── */
  .atlas-sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* .atlas-hint removed — hint text eliminated per design direction */
  /* (keeping selector stub to avoid orphaned closing brace) */
  .atlas-hint-gone {
    display: none;
  }
</style>


<script>
  import atlas from '../data/atlas.json';
  import { poemContentTypes } from '../lib/content-types';
  import gsap from 'gsap';

  // ─── Constants ────────────────────────────────────────────────────────────
  const WORLD_COLORS: Record<string, { accent: string; soft: string }> = {
    'their-world': { accent: '#a92f25', soft: '#d8aaa5' },
    'bless-you':   { accent: '#7e5f70', soft: '#cbb6c3' },
    'still-life':  { accent: '#6f876f', soft: '#b5c9b5' },
  };

  const ATTR_COLORS: Record<string, string> = {
    mode: '#5f554f',
    type: '#4f6174',
    imagery: '#486848',
    pressure: '#7a433b',
    form: '#6f596b',
    sense: '#70572a',
  };

  const ATTR_LABELS: Record<string, string> = {
    mode: 'voice',
    type: 'act',
    imagery: 'image',
    pressure: 'pressure',
    form: 'form',
    sense: 'sense',
  };

  const CATEGORY_KEYS = ['mode', 'type', 'imagery', 'pressure', 'form', 'sense'] as const;

  const DISPLAY_LIMITS: Record<string, number> = {
    mode: 5,
    type: 6,
    imagery: 6,
    pressure: 5,
    form: 4,
    sense: 4,
  };

  // Controlled vocabulary — full attribute field.
  const VOCAB: Record<string, string[]> = {
    mode: [
      'solitary_witness', 'child_perception', 'observer', 'fractured_self',
      'addressed_speaker', 'devotional_speaker', 'plural_voice', 'absent_other',
      'absent_other_address', 'object_speaker', 'public_voice', 'domestic_voice',
      'threshold_speaker',
    ],
    type: [
      'memory_fragment', 'scene', 'witness', 'monologue', 'confession',
      'lament', 'invocation', 'prayer', 'chant', 'manifesto', 'warning', 'farewell',
      'meditation', 'catalogue', 'blessing', 'dream_record', 'parable', 'letter',
      'threshold_crossing', 'refusal',
    ],
    imagery: [
      'shadow', 'child', 'room', 'house', 'window', 'glass',
      'light', 'eye', 'voice', 'flowers', 'faith', 'sky',
      'water', 'mirror', 'street', 'forest', 'bed', 'fire', 'table', 'tree',
      'animal', 'food', 'cloth', 'paper', 'screen', 'door', 'sea', 'body',
      'weather', 'machine', 'flag', 'music',
    ],
    pressure: [
      'family_pressure', 'institutional_pressure', 'class_pressure', 'surveillance',
      'private_property', 'modernization', 'public_noise', 'exile', 'memory_pressure',
      'belief_pressure', 'intimacy_pressure', 'bodily_pressure', 'death_pressure',
      'labor_pressure', 'commerce', 'crowd_pressure', 'threshold_pressure', 'time_pressure',
    ],
    form: [
      'narrative', 'observation', 'incantatory', 'political', 'spiritual',
      'fragmented', 'love', 'dialogic', 'numbered_sequence', 'dramatic_fragment',
      'prose_lyric', 'ritual_repetition',
    ],
    sense: [
      'visual', 'auditory', 'tactile', 'taste', 'smell', 'temperature',
      'motion', 'silence', 'hunger', 'breath',
    ],
  };

  // Zone positions — wider horizontal spread reduces left/right whitespace.
  // Bounding-box fitToCanvas auto-scales to fill available canvas, so these
  // define the shape of the layout, not the pixel footprint.
  const ZONES: Record<string, { cx: number; cy: number; sx: number; sy: number }> = {
    mode:     { cx: -610, cy: -150, sx: 260, sy: 188 },
    type:     { cx:  610, cy: -150, sx: 260, sy: 188 },
    imagery:  { cx:    0, cy:  330, sx: 440, sy: 170 },
    pressure: { cx: -610, cy:  295, sx: 250, sy: 160 },
    form:     { cx:    0, cy: -420, sx: 340, sy: 132 },
    sense:    { cx:  610, cy:  295, sx: 250, sy: 160 },
  };

  const ACTIVE_PULL = 0.12;

  // ─── Attribute definitions ────────────────────────────────────────────────
  const ATTR_DESCRIPTIONS: Record<string, string> = {
    solitary_witness:      'The poem speaks from a position of aloneness — observing without the possibility of intervention.',
    child_perception:      'The world is rendered through a child\'s consciousness: innocent, partial, uneasy with adult logic.',
    observer:              'A detached external viewpoint — watching without full participation or self-disclosure.',
    fractured_self:        'The speaker\'s identity is split, layered, or in contradiction with itself.',
    addressed_speaker:     'The poem speaks directly to another person, real or imagined, naming them into presence.',
    devotional_speaker:    'The speaker\'s address carries the quality of prayer or reverence toward something larger.',
    plural_voice:          'The poem speaks in a collective "we," dissolving individual identity into shared experience.',
    absent_other:          'The poem turns toward someone or something missing, where address becomes a form of absence.',
