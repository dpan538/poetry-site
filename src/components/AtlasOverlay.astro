---
// AtlasOverlay.astro
// ATLAS — relational reading map for daipan.ink
// Poem ID and world are passed as props; atlas data is read via data-attr and imported in <script>
interface Props {
  poemId: string;
  world: string;
}
const { poemId, world } = Astro.props;
---

<!-- ATLAS trigger button — fixed top-right on poem pages -->
<button
  id="atlas-trigger"
  class="atlas-trigger"
  aria-label="Open ATLAS — poem relation map"
  data-poem-id={poemId}
  data-world={world}
>
  ATLAS
</button>

<!-- ATLAS overlay -->
<div
  id="atlas-overlay"
  class="atlas-overlay"
  role="dialog"
  aria-label="ATLAS — poem relation map"
  aria-modal="true"
  aria-hidden="true"
  data-poem-id={poemId}
  data-world={world}
>
  <!-- Header bar -->
  <div class="atlas-header">
    <span class="atlas-wordmark">ATLAS</span>
    <span class="atlas-subtitle">relation map</span>
    <button id="atlas-close" class="atlas-close" aria-label="Close ATLAS">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.2">
        <line x1="1" y1="1" x2="13" y2="13"/>
        <line x1="13" y1="1" x2="1" y2="13"/>
      </svg>
    </button>
  </div>

  <!-- Legend -->
  <div class="atlas-legend" aria-hidden="true">
    <span class="atlas-legend-item atlas-legend-mode">speaker mode</span>
    <span class="atlas-legend-sep">·</span>
    <span class="atlas-legend-item atlas-legend-type">poem act</span>
    <span class="atlas-legend-sep">·</span>
    <span class="atlas-legend-item atlas-legend-imagery">imagery</span>
    <span class="atlas-legend-desc">— highlighted = active in this poem</span>
  </div>

  <!-- Interpretation line — updates to describe current state -->
  <p id="atlas-summary" class="atlas-summary" aria-live="polite"></p>

  <!-- Canvas -->
  <canvas id="atlas-canvas" class="atlas-canvas" aria-hidden="true"></canvas>

  <!-- Hint text -->
  <p id="atlas-hint" class="atlas-hint" aria-live="polite">
    tap speaker · act · image to explore the poem's structural position
  </p>

  <!-- Preview card (shown on poem node click) -->
  <div id="atlas-preview" class="atlas-preview" aria-live="polite" aria-atomic="true"></div>
</div>

<style>
  /* ── Trigger button — mirrors INDEX visual logic, top-right below nav ─────── */
  .atlas-trigger {
    position: fixed;
    top: calc(var(--site-nav-height, 56px) + var(--space-lg, 34px));
    right: max(var(--margin-x, 24px), 12px);
    z-index: 150;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 19px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary, #1a1a1a);
    opacity: 0.35;
    line-height: 1.2;
    transition: opacity 0.2s;
  }

  .atlas-trigger:hover {
    opacity: 1;
    color: var(--color-accent, #1a1a1a);
  }

  .atlas-trigger:focus-visible {
    outline: 2px solid var(--color-accent, #c0392b);
    outline-offset: 4px;
    border-radius: 1px;
  }

  /* ── Overlay ─────────────────────────────────────────────────────────────── */
  .atlas-overlay {
    position: fixed;
    inset: 0;
    z-index: 900;
    background: var(--color-bg, #f5f2ed);
    display: flex;
    flex-direction: column;
    opacity: 0;
    pointer-events: none;
    /* will-change managed by GSAP */
  }

  .atlas-overlay.is-open {
    pointer-events: all;
  }

  /* ── Header ──────────────────────────────────────────────────────────────── */
  .atlas-header {
    display: flex;
    align-items: baseline;
    gap: 10px;
    padding: 16px var(--margin-x, 24px) 0;
    flex-shrink: 0;
  }

  .atlas-wordmark {
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--color-primary, #1a1a1a);
    font-family: inherit;
  }

  .atlas-subtitle {
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--color-meta, #595959);
    font-style: italic;
  }

  .atlas-close {
    margin-left: auto;
    background: transparent;
    border: none;
    padding: 6px;
    cursor: pointer;
    color: var(--color-meta, #595959);
    transition: color 0.15s ease, transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .atlas-close:hover {
    color: var(--color-primary, #1a1a1a);
    transform: rotate(90deg);
  }

  .atlas-close:focus-visible {
    outline: 2px solid var(--color-accent, #c0392b);
    outline-offset: 3px;
    border-radius: 1px;
  }

  /* ── Legend ──────────────────────────────────────────────────────────────── */
  .atlas-legend {
    display: flex;
    gap: 18px;
    align-items: center;
    padding: 10px var(--margin-x, 24px) 0;
    flex-shrink: 0;
  }

  .atlas-legend-sep {
    font-size: 10px;
    color: var(--color-meta, #595959);
    opacity: 0.45;
  }

  .atlas-legend-desc {
    font-size: 10px;
    letter-spacing: 0.03em;
    color: var(--color-meta, #595959);
    font-style: italic;
    margin-left: 6px;
    opacity: 0.7;
  }

  .atlas-legend-item {
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--color-meta, #595959);
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .atlas-legend-item::before {
    content: '';
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .atlas-legend-mode::before   { background: #b8a898; }
  .atlas-legend-type::before   { background: #8a96a8; }
  .atlas-legend-imagery::before { background: #8a9e8a; }

  .atlas-legend-transform {
    font-style: italic;
    color: var(--color-meta, #595959);
  }

  .atlas-legend-transform::before {
    display: none;
  }

  /* ── Canvas ──────────────────────────────────────────────────────────────── */
  .atlas-canvas {
    flex: 1;
    width: 100%;
    display: block;
    touch-action: none;
  }

  /* ── Summary line ───────────────────────────────────────────────────────── */
  .atlas-summary {
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--color-meta, #595959);
    font-style: italic;
    text-align: center;
    padding: 5px var(--margin-x, 24px) 0;
    flex-shrink: 0;
    min-height: 1.5em;
    transition: opacity 0.4s ease;
    margin: 0;
  }

  /* ── Hint ────────────────────────────────────────────────────────────────── */
  .atlas-hint {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 13px;
    letter-spacing: 0.04em;
    color: var(--color-meta, #595959);
    font-style: italic;
    pointer-events: none;
    text-align: center;
    transition: opacity 0.3s ease;
    white-space: nowrap;
  }

  .atlas-hint.is-hidden {
    opacity: 0;
  }

  /* ── Preview card ────────────────────────────────────────────────────────── */
  .atlas-preview {
    position: absolute;
    bottom: 48px;
    left: 50%;
    transform: translateX(-50%);
    width: min(380px, calc(100vw - 48px));
    background: var(--color-bg, #f5f2ed);
    border: 0.5px solid rgba(26, 26, 26, 0.12);
    padding: 18px 20px 16px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.22s ease, transform 0.22s cubic-bezier(0.16, 1, 0.3, 1);
    transform: translateX(-50%) translateY(6px);
  }

  .atlas-preview.is-visible {
    opacity: 1;
    pointer-events: all;
    transform: translateX(-50%) translateY(0);
  }

  /* preview card internals (set by JS innerHTML) */
  :global(.atlas-preview-tag) {
    display: inline-block;
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--color-meta, #595959);
    margin-bottom: 6px;
  }

  :global(.atlas-preview-tag.tag-mode)    { color: #b8a898; }
  :global(.atlas-preview-tag.tag-type)    { color: #8a96a8; }
  :global(.atlas-preview-tag.tag-imagery) { color: #8a9e8a; }

  :global(.atlas-preview-vol-label) {
    display: block;
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--color-meta, #595959);
    margin-bottom: 4px;
  }

  :global(.atlas-preview-title) {
    margin: 0 0 7px;
    font-size: 19px;
    font-weight: normal;
    letter-spacing: -0.01em;
    color: var(--color-primary, #1a1a1a);
    line-height: 1.25;
  }

  :global(.atlas-preview-firstline) {
    margin: 0 0 10px;
    font-size: 13px;
    line-height: 1.6;
    color: var(--color-meta, #595959);
    font-style: italic;
  }

  :global(.atlas-preview-reason) {
    margin: 0 0 14px;
    font-size: 11.5px;
    letter-spacing: 0.04em;
    color: var(--color-meta, #595959);
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 3px;
  }

  :global(.atlas-reason-tag) {
    font-size: 11px;
    letter-spacing: 0.05em;
    font-style: italic;
  }

  :global(.atlas-reason-sep) {
    font-size: 11px;
    color: var(--color-meta, #595959);
    opacity: 0.5;
  }

  :global(.atlas-preview-active-note) {
    margin: 0 0 10px;
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--color-accent, #c0392b);
    font-style: italic;
  }

  :global(.atlas-preview-inactive-note) {
    margin: 0 0 10px;
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--color-meta, #595959);
    font-style: italic;
    opacity: 0.7;
  }

  :global(.atlas-transform-badge) {
    font-style: italic;
    color: var(--color-accent, #c0392b);
    margin-left: 4px;
  }

  :global(.atlas-preview-cta) {
    display: inline-block;
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--color-primary, #1a1a1a);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 0.15s ease;
  }

  :global(.atlas-preview-cta:hover) {
    opacity: 0.65;
  }

  :global(.atlas-attr-list) {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  :global(.atlas-attr-poem) {
    display: flex;
    align-items: baseline;
    gap: 8px;
    font-size: 12.5px;
    color: var(--color-primary, #1a1a1a);
    text-decoration: none;
    padding: 3px 0;
    border-bottom: 0.5px solid rgba(26,26,26,0.06);
    transition: padding-left 0.15s ease;
  }

  :global(.atlas-attr-poem:last-child) {
    border-bottom: none;
  }

  :global(.atlas-attr-poem:hover) {
    padding-left: 4px;
  }

  :global(.atlas-attr-vol) {
    font-size: 10px;
    letter-spacing: 0.06em;
    color: var(--color-meta, #595959);
    min-width: 16px;
  }
</style>


<script>
  import atlas from '../data/atlas.json';
  import gsap from 'gsap';

  // ─── Constants ────────────────────────────────────────────────────────────
  const WORLD_COLORS: Record<string, { accent: string; soft: string; bg: string }> = {
    'their-world': { accent: '#c0392b', soft: '#e8c8c4', bg: '#f5f2ed' },
    'bless-you':   { accent: '#9b7b8b', soft: '#ddd0d8', bg: '#f2ede4' },
    'still-life':  { accent: '#8a9e8a', soft: '#c8d8c8', bg: '#f8f7f4' },
  };

  const ATTR_COLORS: Record<string, string> = {
    mode:    '#b8a898',
    type:    '#8a96a8',
    imagery: '#8a9e8a',
  };

  const VOL_LABELS: Record<string, string> = {
    'their-world': 'I', 'bless-you': 'II', 'still-life': 'III',
  };
  const VOL_FULL: Record<string, string> = {
    'their-world': 'I — Their World', 'bless-you': 'II — Bless You', 'still-life': 'III — Still Life',
  };

  // Controlled vocabulary — the full conceptual field.
  // Nodes are placed by zone + hash jitter, then settled by force simulation.
  const VOCAB: Record<string, string[]> = {
    mode: [
      'solitary_witness', 'child_perception', 'observer', 'fractured_self',
      'addressed_speaker', 'devotional_speaker', 'plural_voice', 'absent_other_address',
    ],
    type: [
      'memory_fragment', 'scene', 'witness', 'monologue', 'confession',
      'lament', 'invocation', 'prayer', 'chant', 'manifesto', 'warning', 'farewell',
    ],
    imagery: [
      'shadow', 'child', 'room', 'house', 'window', 'glass',
      'light', 'eye', 'voice', 'flowers', 'faith', 'sky',
    ],
  };

  // Zone definitions: centre + half-extents for each attribute type
  // Active attrs are pulled 42% toward the anchor (origin), narrowing the zone.
  const ZONES: Record<string, { cx: number; cy: number; sx: number; sy: number }> = {
    mode:    { cx: -208, cy:   0, sx: 62, sy: 128 },
    type:    { cx:  208, cy:   0, sx: 58, sy: 118 },
    imagery: { cx:    0, cy: 186, sx: 188, sy: 42 },
  };

  const ACTIVE_PULL = 0.42; // how far active attrs move toward anchor (0 = zone edge, 1 = origin)

  // ─── Types ────────────────────────────────────────────────────────────────
  interface Node {
    kind: 'anchor' | 'attr' | 'satellite';
    x: number; y: number; r: number;
    vx: number; vy: number;       // velocity (force simulation)
    homeX: number; homeY: number; // spring attractor
    // anchor + satellite
    id?: string; title?: string; world?: string;
    firstLine?: string; url?: string;
    // attr
    attrType?: string; value?: string; active?: boolean;
    // satellite
    attrNodeRef?: Node; visible?: boolean;
    // animation
    alpha: number; delay: number; currentAlpha: number;
  }

  interface Edge { from: Node; to: Node; color?: string; isSatellite?: boolean; }

  // ─── AtlasGraph ───────────────────────────────────────────────────────────
  class AtlasGraph {
    canvas: HTMLCanvasElement;
    ctx: CanvasRenderingContext2D;
    poemId: string; worldKey: string; poem: any;
    nodes: Node[]; edges: Edge[];
    selectedNode: Node | null; hoveredNode: Node | null;
    tx: number; ty: number; scale: number;
    cx: number; cy: number; dpr: number;
    isDragging: boolean;
    dragStart: { x: number; y: number; tx: number; ty: number } | null;
    pinchStart: number | null; pinchScale: number;
    pointerDownPos: { x: number; y: number } | null; pointerDownTime: number;
    rafId: number; isStub: boolean;

    constructor(canvas: HTMLCanvasElement, poemId: string, worldKey: string) {
      this.canvas = canvas;
      this.ctx = canvas.getContext('2d')!;
      this.poemId = poemId; this.worldKey = worldKey;
      this.poem = (atlas.poems as any[]).find((p: any) => p.id === poemId) ?? null;
      this.nodes = []; this.edges = [];
      this.selectedNode = null; this.hoveredNode = null;
      this.tx = 0; this.ty = 0; this.scale = 1;
      this.cx = 0; this.cy = 0; this.dpr = window.devicePixelRatio || 1;
      this.isDragging = false; this.dragStart = null;
      this.pinchStart = null; this.pinchScale = 1;
      this.pointerDownPos = null; this.pointerDownTime = 0;
      this.rafId = 0; this.isStub = !this.poem?.mode;

      this.resize();
      this.buildGraph();
      this.fitToCanvas();
      this.setupEvents();
      this.startLoop();
    }

    // ── Deterministic hash (0..1) ─────────────────────────────────────────────
    hashStr(s: string): number {
      let h = 0;
      for (let i = 0; i < s.length; i++) h = (Math.imul(31, h) + s.charCodeAt(i)) | 0;
      return (h >>> 0) / 4294967296;
    }

    // ── Home position for an attr node within its zone ─────────────────────────
    // Active nodes: home pulled ACTIVE_PULL fraction toward origin (the poem).
    computeHome(attrType: string, value: string, active: boolean): { x: number; y: number } {
      const z = ZONES[attrType] || { cx: 0, cy: 0, sx: 80, sy: 80 };
      const hx = this.hashStr(value + '_hx') * 2 - 1; // −1..1
      const hy = this.hashStr(value + '_hy') * 2 - 1;
      const rawX = z.cx + hx * z.sx;
      const rawY = z.cy + hy * z.sy;
      if (active) {
        // Pull home toward anchor (origin)
        return { x: rawX * (1 - ACTIVE_PULL), y: rawY * (1 - ACTIVE_PULL) };
      }
      return { x: rawX, y: rawY };
    }

    // ── Graph construction ────────────────────────────────────────────────────
    buildGraph() {
      this.nodes = []; this.edges = [];
      const poem = this.poem;
      const activeSets: Record<string, Set<string>> = {
        mode:    new Set<string>(poem?.mode    || []),
        type:    new Set<string>(poem?.type    || []),
        imagery: new Set<string>(poem?.imagery || []),
      };

      // Anchor: fixed at origin, no simulation forces
      const anchor: Node = {
        kind: 'anchor', x: 0, y: 0, r: 26, vx: 0, vy: 0, homeX: 0, homeY: 0,
        id: poem?.id, title: poem?.title ?? this.poemId,
        world: poem?.world ?? this.worldKey,
        alpha: 1, delay: 0, currentAlpha: 1,
      };
      this.nodes.push(anchor);

      // Attr nodes for every vocabulary item
      ['mode', 'type', 'imagery'].forEach(attrType => {
        VOCAB[attrType].forEach((value, i) => {
          const active = activeSets[attrType].has(value);
          const home = this.computeHome(attrType, value, active);
          // Start position = home + small jitter so simulation has something to converge from
          const jitterX = (this.hashStr(value + '_jx') - 0.5) * 12;
          const jitterY = (this.hashStr(value + '_jy') - 0.5) * 12;
          const n: Node = {
            kind: 'attr', attrType, value,
            x: home.x + jitterX, y: home.y + jitterY,
            vx: 0, vy: 0, homeX: home.x, homeY: home.y,
            r: active ? 8 : 6, active,
            alpha: 0, delay: 0.04 + i * 0.042, currentAlpha: 0,
          };
          this.nodes.push(n);
          if (active) this.edges.push({ from: anchor, to: n, color: ATTR_COLORS[attrType] });
          this.buildSatellites(n); // pre-build invisible satellites
        });
      });
    }

    // Build satellite poem nodes (hidden until attr selected)
    buildSatellites(attrNode: Node) {
      const matches = (atlas.poems as any[])
        .filter((p: any) => {
          if (p.id === this.poemId) return false;
          const arr: string[] = p[attrNode.attrType!] || [];
          return arr.includes(attrNode.value!);
        })
        .slice(0, 5);

      matches.forEach((p: any, i: number) => {
        const sat: Node = {
          kind: 'satellite', attrNodeRef: attrNode,
          id: p.id, title: p.title, world: p.world,
          firstLine: p.firstLine, url: p.url,
          // Initial position near attr (will be updated in selectAttr)
          x: attrNode.x, y: attrNode.y,
          vx: 0, vy: 0, homeX: attrNode.x, homeY: attrNode.y,
          r: 15, visible: false,
          alpha: 0, delay: i * 0.06, currentAlpha: 0,
        };
        this.nodes.push(sat);
        this.edges.push({
          from: attrNode, to: sat,
          color: ATTR_COLORS[attrNode.attrType!], isSatellite: true,
        });
      });
    }

    // ── Force simulation ──────────────────────────────────────────────────────
    // Zone spring + anchor pull (active) + node repulsion + damping.
    // No continuous noise — simulation runs during startLoop/runRelayout only.
    simulateStep() {
      const ZONE_K   = 0.036;  // zone spring constant
      const ANCHOR_K = 0.013;  // additional pull for active attrs
      const SEL_K    = 0.022;  // extra pull for selected attr
      const REPEL_K  = 0.65;   // repulsion strength
      const DAMPING  = 0.80;   // velocity decay per step

      // Eligible nodes: not anchor, visible (satellites only when visible)
      const active = this.nodes.filter(n =>
        n.kind !== 'anchor' && !(n.kind === 'satellite' && !n.visible)
      );

      active.forEach(n => {
        // Zone spring
        n.vx += (n.homeX - n.x) * ZONE_K;
        n.vy += (n.homeY - n.y) * ZONE_K;

        // Active attr: extra spring toward anchor (poem distorts field)
        if (n.kind === 'attr' && n.active) {
          n.vx += (0 - n.x) * ANCHOR_K;
          n.vy += (0 - n.y) * ANCHOR_K;
        }

        // Selected attr: even stronger pull inward
        if (n === this.selectedNode && n.kind === 'attr') {
          n.vx += (0 - n.x) * SEL_K;
          n.vy += (0 - n.y) * SEL_K;
        }

        // Node-node repulsion (all visible nodes, including anchor)
        const allVis = [this.nodes[0], ...active]; // include anchor
        allVis.forEach(other => {
          if (other === n) return;
          const dx = n.x - other.x, dy = n.y - other.y;
          const dist = Math.sqrt(dx * dx + dy * dy) || 0.1;
          const minD = n.r + other.r + 26;
          if (dist < minD) {
            const f = REPEL_K * (minD - dist) / dist;
            n.vx += dx * f; n.vy += dy * f;
          }
        });

        // Damping + integrate (no random noise — layout must stay stable)
        n.vx *= DAMPING; n.vy *= DAMPING;
        n.x  += n.vx;    n.y  += n.vy;
      });
    }

    // ── Fit canvas to show full vocabulary field ──────────────────────────────
    fitToCanvas() {
      const spanW = 560, spanH = 450;
      const scaleW = (this.cx * 2 * 0.84) / spanW;
      const scaleH = (this.cy * 2 * 0.84) / spanH;
      this.scale = Math.min(scaleW, scaleH, 1.2);
      this.ty = -18 * this.scale;
    }

    resize() {
      const el = this.canvas.parentElement!;
      const rect = el.getBoundingClientRect();
      const W = rect.width, H = el.clientHeight || rect.height;
      this.canvas.width  = W * this.dpr; this.canvas.height = H * this.dpr;
      this.canvas.style.width = W + 'px'; this.canvas.style.height = H + 'px';
      this.cx = W / 2; this.cy = H / 2;
    }

    // ── Render loop — settles then freezes ────────────────────────────────────
    // Runs the force sim for ~1.8 s then stops RAF. After freeze, interactions
    // call this.draw() directly on the frozen canvas.
    startLoop() {
      if (this.rafId) cancelAnimationFrame(this.rafId);
      const start = performance.now();
      const alphaDur = 1200; // fade-in window
      const simDur   = 1800; // total settling window — RAF stops after this
      const tick = (now: number) => {
        const elapsed = now - start;
        // Entry animation: fade in attr nodes
        const t = Math.min(1, elapsed / alphaDur);
        if (t < 1) {
          this.nodes.forEach(n => {
            if (n.kind === 'satellite') return;
            const p = Math.max(0, Math.min(1, (t - n.delay) / 0.35));
            n.currentAlpha = this.easeOut(p);
          });
        }
        if (elapsed < simDur) {
          this.simulateStep();
        }
        this.draw();
        if (elapsed < simDur) {
          this.rafId = requestAnimationFrame(tick);
        } else {
          this.rafId = 0; // freeze — interactions draw() directly
        }
      };
      this.rafId = requestAnimationFrame(tick);
    }

    // ── Short re-layout burst after attr selection (then freezes) ─────────────
    runRelayout() {
      if (this.rafId) cancelAnimationFrame(this.rafId);
      const start = performance.now();
      const dur = 700; // ms — then freeze
      const tick = (now: number) => {
        const elapsed = now - start;
        // Animate visible satellite alpha
        this.nodes.filter(n => n.kind === 'satellite' && n.visible).forEach(sat => {
          const p = Math.max(0, Math.min(1, (elapsed / dur - sat.delay) / 0.40));
          sat.currentAlpha = this.easeOut(p);
        });
        this.simulateStep();
        this.draw();
        if (elapsed < dur) {
          this.rafId = requestAnimationFrame(tick);
        } else {
          this.rafId = 0;
        }
      };
      this.rafId = requestAnimationFrame(tick);
    }

    easeOut(t: number) { return 1 - Math.pow(1 - t, 3); }

    // ── Drawing ───────────────────────────────────────────────────────────────
    draw() {
      const ctx = this.ctx, dpr = this.dpr;
      const W = this.canvas.width / dpr, H = this.canvas.height / dpr;
      ctx.save();
      ctx.scale(dpr, dpr);
      ctx.clearRect(0, 0, W, H);
      ctx.translate(this.cx + this.tx, this.cy + this.ty);
      ctx.scale(this.scale, this.scale);
      this.drawZoneHalos();
      this.drawEdges();
      this.drawNodes();
      ctx.restore();
    }

    // Subtle halos indicating zone regions — fill + stroke ring + label
    drawZoneHalos() {
      const ctx = this.ctx;
      const zones = [
        { key: 'mode',    label: 'speaker mode', rx: ZONES.mode.sx + 48,    ry: ZONES.mode.sy + 28,    labelY: ZONES.mode.cy - ZONES.mode.sy - 20 },
        { key: 'type',    label: 'poem act',      rx: ZONES.type.sx + 48,    ry: ZONES.type.sy + 28,    labelY: ZONES.type.cy - ZONES.type.sy - 20 },
        { key: 'imagery', label: 'imagery',       rx: ZONES.imagery.sx + 38, ry: ZONES.imagery.sy + 48, labelY: ZONES.imagery.cy + ZONES.imagery.sy + 22 },
      ];

      // Fill passes
      zones.forEach(({ key, rx, ry }) => {
        const z = ZONES[key];
        const color = ATTR_COLORS[key];
        ctx.save();
        ctx.globalAlpha = 0.07;
        ctx.beginPath();
        ctx.ellipse(z.cx, z.cy, rx, ry, 0, 0, Math.PI * 2);
        ctx.fillStyle = color;
        ctx.fill();
        ctx.restore();
      });

      // Stroke ring passes (slightly outside fill)
      zones.forEach(({ key, rx, ry }) => {
        const z = ZONES[key];
        const color = ATTR_COLORS[key];
        ctx.save();
        ctx.globalAlpha = 0.13;
        ctx.beginPath();
        ctx.ellipse(z.cx, z.cy, rx + 2, ry + 2, 0, 0, Math.PI * 2);
        ctx.strokeStyle = color;
        ctx.lineWidth = 0.8;
        ctx.setLineDash([4, 5]);
        ctx.stroke();
        ctx.setLineDash([]);
        ctx.restore();
      });

      // Zone labels — readable but recessed
      ctx.save();
      ctx.font = 'italic 10px Georgia, serif';
      ctx.textBaseline = 'middle';
      ctx.textAlign = 'center';
      zones.forEach(({ key, label, labelY }) => {
        const z = ZONES[key];
        ctx.globalAlpha = 0.45;
        ctx.fillStyle = ATTR_COLORS[key];
        ctx.fillText(label, z.cx, labelY);
      });
      ctx.restore();
    }

    drawEdges() {
      const ctx = this.ctx;
      this.edges.forEach(edge => {
        if (edge.isSatellite && (!edge.to.visible || (edge.to.currentAlpha ?? 0) < 0.02)) return;
        const fa = edge.from.currentAlpha ?? 0;
        const ta = edge.to.currentAlpha ?? 0;
        const alpha = Math.min(fa, ta);
        if (alpha < 0.02) return;

        const isSel = this.selectedNode === edge.from || this.selectedNode === edge.to;
        const color = edge.color || '#1a1a1a';
        ctx.save();
        if (edge.isSatellite) {
          ctx.globalAlpha = alpha * 0.45;
          ctx.strokeStyle = color;
          ctx.lineWidth = 0.9;
          ctx.setLineDash([3, 4]);
        } else {
          if (!edge.to.active) { ctx.restore(); return; }
          ctx.globalAlpha = alpha * (isSel ? 0.65 : 0.28);
          ctx.strokeStyle = color;
          ctx.lineWidth = isSel ? 1.5 : 1.0;
        }
        ctx.beginPath();
        ctx.moveTo(edge.from.x, edge.from.y);
        ctx.lineTo(edge.to.x, edge.to.y);
        ctx.stroke();
        ctx.setLineDash([]);
        ctx.restore();
      });
    }

    drawNodes() {
      (['satellite', 'attr', 'anchor'] as const).forEach(kind => {
        this.nodes.filter(n => n.kind === kind).forEach(n => this.drawNode(n));
      });
    }

    drawNode(n: Node) {
      if (n.kind === 'satellite' && !n.visible) return;
      const alpha = n.currentAlpha ?? 0;
      if (alpha < 0.02 && n.kind !== 'anchor') return;
      const ctx = this.ctx;
      ctx.save();
      ctx.globalAlpha = Math.max(0, Math.min(1, alpha));
      if (n.kind === 'anchor')    this.drawAnchorNode(n);
      if (n.kind === 'attr')      this.drawAttrNode(n);
      if (n.kind === 'satellite') this.drawSatelliteNode(n);
      ctx.restore();
    }

    drawAnchorNode(n: Node) {
      const ctx = this.ctx;
      const wc = WORLD_COLORS[n.world || this.worldKey] || WORLD_COLORS['their-world'];
      // Outer pulse ring
      ctx.beginPath(); ctx.arc(0, 0, n.r + 8, 0, Math.PI * 2);
      ctx.strokeStyle = wc.accent; ctx.lineWidth = 1;
      ctx.globalAlpha *= 0.20; ctx.stroke(); ctx.globalAlpha /= 0.20;
      // Fill + border
      ctx.beginPath(); ctx.arc(0, 0, n.r, 0, Math.PI * 2);
      ctx.fillStyle = wc.bg; ctx.fill();
      ctx.strokeStyle = wc.accent; ctx.lineWidth = 1.8; ctx.stroke();
      // "current" above
      ctx.font = 'italic 10px Georgia, serif'; ctx.fillStyle = '#bbb';
      ctx.textAlign = 'center'; ctx.textBaseline = 'bottom';
      ctx.fillText('current', 0, -n.r - 12);
      // Title below
      ctx.font = '15px Georgia, serif'; ctx.fillStyle = '#1a1a1a';
      ctx.textBaseline = 'top';
      this.wrapText(n.title || '', 0, n.r + 12, 130, 18);
    }

    drawAttrNode(n: Node) {
      const ctx = this.ctx;
      const color = ATTR_COLORS[n.attrType!] || '#888';
      const isHov = this.hoveredNode === n;
      const isSel = this.selectedNode === n;
      const active = n.active ?? false;

      // Active: full presence. Inactive: clearly recessed (smaller, dimmer, italic label).
      const baseOpacity = active ? 1 : 0.28;
      ctx.globalAlpha *= baseOpacity;

      // Active nodes are slightly larger; inactive are deliberately smaller/quieter
      const baseR = active ? 9 : 5;
      const r = baseR * (isHov || isSel ? 1.7 : 1);

      // Soft outer aura for active nodes
      if (active && !isSel) {
        ctx.beginPath(); ctx.arc(n.x, n.y, r + 10, 0, Math.PI * 2);
        ctx.fillStyle = color; ctx.globalAlpha *= 0.15; ctx.fill(); ctx.globalAlpha /= 0.15;
      }

      // Dot
      ctx.beginPath(); ctx.arc(n.x, n.y, r, 0, Math.PI * 2);
      ctx.fillStyle = isSel ? '#1a1a1a' : color; ctx.fill();

      // Selection ring
      if (isSel) {
        ctx.beginPath(); ctx.arc(n.x, n.y, r + 6, 0, Math.PI * 2);
        ctx.strokeStyle = color; ctx.lineWidth = 0.9;
        ctx.globalAlpha *= 0.6; ctx.stroke(); ctx.globalAlpha /= 0.6;
      }

      // Label — radially outward from anchor (origin), adapts to actual node position
      const angle = Math.atan2(n.y, n.x);
      const deg = angle * 180 / Math.PI;
      const gap = r + 11;
      let lx = n.x, ly = n.y;
      let ta: CanvasTextAlign = 'center', tb: CanvasTextBaseline = 'middle';

      if (deg > -70 && deg < 70) {
        // Right side → label right
        lx = n.x + gap; ta = 'left';
      } else if (deg > 110 || deg < -110) {
        // Left side → label left
        lx = n.x - gap; ta = 'right';
      } else if (deg >= 70 && deg <= 110) {
        // Bottom → label below
        ly = n.y + gap + 2; tb = 'top'; ta = 'center';
      } else {
        // Top → label above
        ly = n.y - gap - 2; tb = 'bottom'; ta = 'center';
      }

      const fs = active ? 12.5 : 10.5;
      ctx.font = `${active ? '' : 'italic '}${fs}px Georgia, serif`;
      // Inactive labels: warmer muted neutral, clearly distinguishable from active
      ctx.fillStyle = isSel ? '#0a0a0a' : active ? '#1a1a1a' : '#c0b8b0';
      ctx.textAlign = ta; ctx.textBaseline = tb;
      ctx.fillText(this.formatLabel(n.value!), lx, ly);

      ctx.globalAlpha /= baseOpacity;
    }

    drawSatelliteNode(n: Node) {
      const ctx = this.ctx;
      const wc = WORLD_COLORS[n.world!] || WORLD_COLORS['their-world'];
      const isSel = this.selectedNode === n;
      const isHov = this.hoveredNode === n;
      const r = n.r;
      ctx.beginPath(); ctx.arc(n.x, n.y, r, 0, Math.PI * 2);
      ctx.fillStyle = isSel ? wc.soft : 'rgba(248,246,242,0.96)';
      ctx.fill();
      ctx.strokeStyle = isSel ? wc.accent : wc.soft;
      ctx.lineWidth = isSel ? 1.5 : 1;
      ctx.stroke();
      // Vol
      ctx.font = '10px Georgia, serif'; ctx.fillStyle = wc.accent;
      ctx.textAlign = 'center'; ctx.textBaseline = 'top';
      ctx.fillText(VOL_LABELS[n.world!] || '', n.x, n.y + r + 6);
      // Title
      const fs = isHov || isSel ? 13 : 11.5;
      ctx.font = `${fs}px Georgia, serif`;
      ctx.fillStyle = isHov || isSel ? '#1a1a1a' : '#444';
      this.wrapText(n.title || '', n.x, n.y + r + 18, 82, 14);
    }

    // ── Text helpers ──────────────────────────────────────────────────────────
    wrapText(text: string, x: number, y: number, maxW: number, lineH: number) {
      const ctx = this.ctx, words = text.split(' ');
      let line = '', cy = y;
      for (let i = 0; i < words.length; i++) {
        const test = line + words[i] + ' ';
        if (ctx.measureText(test).width > maxW && i > 0) {
          ctx.fillText(line.trim(), x, cy); line = words[i] + ' '; cy += lineH;
        } else line = test;
      }
      ctx.fillText(line.trim(), x, cy);
    }

    // ── Summary text ──────────────────────────────────────────────────────────
    buildSummaryText(): string {
      const poem = this.poem;
      if (!poem?.mode) return '';
      const nMode    = (poem.mode    || []).length;
      const nType    = (poem.type    || []).length;
      const nImagery = (poem.imagery || []).length;
      const parts: string[] = [];
      if (nMode    > 0) parts.push(`${nMode} speaker ${nMode    === 1 ? 'mode'  : 'modes'}`);
      if (nType    > 0) parts.push(`${nType} ${nType  === 1 ? 'act'    : 'acts'}`);
      if (nImagery > 0) parts.push(`${nImagery} imagery ${nImagery === 1 ? 'field' : 'fields'}`);
      if (parts.length === 0) return '';
      const listed = parts.length === 1 ? parts[0]
        : parts.slice(0, -1).join(', ') + ', and ' + parts[parts.length - 1];
      return `This poem activates ${listed}.`;
    }

    setSummary(text: string) {
      const el = document.getElementById('atlas-summary');
      if (el) el.textContent = text;
    }

    formatLabel(val: string) { return val.replace(/_/g, ' '); }

    // ── Hit testing ───────────────────────────────────────────────────────────
    hitTest(px: number, py: number): Node | null {
      const wx = (px - this.cx - this.tx) / this.scale;
      const wy = (py - this.cy - this.ty) / this.scale;
      let best: Node | null = null, bestDist = Infinity;
      for (const n of this.nodes) {
        if (n.kind === 'satellite' && !n.visible) continue;
        const dx = n.x - wx, dy = n.y - wy;
        const dist = Math.sqrt(dx * dx + dy * dy);
        const hitR = n.kind === 'anchor' ? n.r + 10
          : n.kind === 'satellite' ? Math.max(n.r + 12, 22)
          : Math.max(n.r + 18, 26);
        if (dist < hitR && dist < bestDist) { best = n; bestDist = dist; }
      }
      return best;
    }

    // ── Interaction ───────────────────────────────────────────────────────────
    clearSelection() {
      this.selectedNode = null;
      this.nodes.filter(n => n.kind === 'satellite').forEach(n => {
        n.visible = false; n.currentAlpha = 0; n.vx = 0; n.vy = 0;
      });
      document.getElementById('atlas-preview')?.classList.remove('is-visible');
      this.setSummary(this.buildSummaryText());
      this.updateHint(
        this.isStub
          ? 'tap any attribute to find poems with that quality'
          : 'highlighted attributes belong to this poem — tap to explore'
      );
      if (!this.rafId) this.draw(); // redraw immediately if loop is frozen
    }

    handleTap(px: number, py: number) {
      const hit = this.hitTest(px, py);
      if (!hit) { this.clearSelection(); return; }

      if (hit === this.selectedNode) {
        if (hit.kind === 'satellite') { window.location.href = hit.url || '#'; }
        else this.clearSelection();
        return;
      }

      // Hide previous satellites
      this.nodes.filter(n => n.kind === 'satellite').forEach(n => {
        n.visible = false; n.currentAlpha = 0; n.vx = 0; n.vy = 0;
      });
      this.selectedNode = hit;

      if (hit.kind === 'anchor')    { this.showAnchorInfo(); return; }
      if (hit.kind === 'attr')      { this.selectAttr(hit); return; }
      if (hit.kind === 'satellite') { this.showSatellitePreview(hit); return; }
    }

    // Select attr: satellites emerge into the field around the attr→anchor axis
    selectAttr(attrNode: Node) {
      const sats = this.nodes.filter(n => n.kind === 'satellite' && n.attrNodeRef === attrNode);
      const count = sats.length;

      // Compute home positions: spread perpendicularly along the attr→anchor midline
      const perpAngle = Math.atan2(attrNode.y, attrNode.x) + Math.PI / 2;
      const midX = attrNode.x * 0.48;
      const midY = attrNode.y * 0.48;
      const spreadPx = 52;

      sats.forEach((sat, i) => {
        const t = count > 1 ? i / (count - 1) - 0.5 : 0;
        sat.homeX = midX + Math.cos(perpAngle) * t * spreadPx;
        sat.homeY = midY + Math.sin(perpAngle) * t * spreadPx;
        // Spawn near attr node with small random offset
        sat.x = attrNode.x + (Math.random() - 0.5) * 18;
        sat.y = attrNode.y + (Math.random() - 0.5) * 18;
        sat.vx = 0; sat.vy = 0;
        sat.visible = true; sat.currentAlpha = 0;
        sat.delay = i * 0.06;
      });

      // One short re-layout burst, then freeze
      this.runRelayout();
      this.showAttrPanel(attrNode);
    }

    showAttrPanel(n: Node) {
      const ATTR_FULL: Record<string, string> = { mode: 'Speaker mode', type: 'Poem act', imagery: 'Imagery' };
      const label = this.formatLabel(n.value!);
      const typeLabel = ATTR_FULL[n.attrType!] || n.attrType!;
      const tagClass = `tag-${n.attrType}`;
      const matches = (atlas.poems as any[])
        .filter((p: any) => { const arr: string[] = p[n.attrType!] || []; return arr.includes(n.value!) && p.id !== this.poemId; })
        .slice(0, 6);

      const preview = document.getElementById('atlas-preview')!;
      preview.innerHTML = `
        <span class="atlas-preview-tag ${tagClass}">${typeLabel}</span>
        <h3 class="atlas-preview-title">${label}</h3>
        ${n.active
          ? `<p class="atlas-preview-active-note">↳ active in this poem</p>`
          : `<p class="atlas-preview-inactive-note">not in this poem</p>`}
        <ul class="atlas-attr-list">
          ${matches.map((p: any) => `
            <li><a href="${p.url}" class="atlas-attr-poem">
              <span class="atlas-attr-vol">${VOL_LABELS[p.world] || ''}</span>
              <span>${p.title}</span>
            </a></li>
          `).join('')}
          ${matches.length === 0 ? `<li style="font-size:11px;color:#aaa;font-style:italic;padding:4px 0">No other poems mapped yet</li>` : ''}
        </ul>
      `;
      preview.classList.add('is-visible');
      // Summary line: contextual interpretation
      const cnt = matches.length;
      this.setSummary(cnt > 0
        ? `${label} links this poem to ${cnt} related ${cnt === 1 ? 'poem' : 'poems'}.`
        : `${label} appears only in this poem so far.`);
      this.updateHint(cnt > 0 ? 'tap a poem node · tap again to navigate' : 'tap another attribute to continue');
    }

    showAnchorInfo() {
      const poem = this.poem;
      const preview = document.getElementById('atlas-preview')!;
      if (!poem?.mode) {
        preview.innerHTML = `
          <h3 class="atlas-preview-title">${poem?.title ?? this.poemId}</h3>
          <p class="atlas-preview-inactive-note">
            Position in atlas not yet mapped.<br>Tap any attribute to explore the field.
          </p>`;
        preview.classList.add('is-visible');
        this.updateHint('tap the attribute nodes to explore the collection');
        return;
      }
      const fmt = (v: string) => this.formatLabel(v);
      const modeList    = (poem.mode    || []).map(fmt).join(', ');
      const typeList    = (poem.type    || []).map(fmt).join(', ');
      const imageryList = (poem.imagery || []).map(fmt).join(', ');
      preview.innerHTML = `
        <h3 class="atlas-preview-title">${poem.title}</h3>
        ${modeList    ? `<p class="atlas-preview-reason"><em style="color:${ATTR_COLORS.mode}">speaker</em> &thinsp;${modeList}</p>`    : ''}
        ${typeList    ? `<p class="atlas-preview-reason"><em style="color:${ATTR_COLORS.type}">act</em> &thinsp;${typeList}</p>`          : ''}
        ${imageryList ? `<p class="atlas-preview-reason"><em style="color:${ATTR_COLORS.imagery}">image</em> &thinsp;${imageryList}</p>` : ''}
        <p style="font-size:11px;color:#aaa;font-style:italic;margin-top:8px">tap a highlighted attribute to see related poems</p>
      `;
      preview.classList.add('is-visible');
      this.setSummary(this.buildSummaryText());
      this.updateHint('tap speaker · act · image to explore');
    }

    showSatellitePreview(n: Node) {
      const parent = n.attrNodeRef;
      const parentLabel = parent ? this.formatLabel(parent.value!) : '';
      const parentColor = parent ? (ATTR_COLORS[parent.attrType!] || '#888') : '#888';
      const preview = document.getElementById('atlas-preview')!;
      preview.innerHTML = `
        <span class="atlas-preview-vol-label">${VOL_FULL[n.world!] || n.world}</span>
        <h3 class="atlas-preview-title">${n.title}</h3>
        ${n.firstLine ? `<p class="atlas-preview-firstline">"${n.firstLine}"</p>` : ''}
        <p class="atlas-preview-reason"><em style="color:${parentColor}">${parentLabel}</em></p>
        <a href="${n.url || '#'}" class="atlas-preview-cta">Read this poem →</a>
      `;
      preview.classList.add('is-visible');
      this.updateHint('tap again to navigate to this poem');
    }

    updateHint(text: string) {
      const el = document.getElementById('atlas-hint');
      if (el) el.textContent = text;
    }

    // ── Events ────────────────────────────────────────────────────────────────
    setupEvents() {
      const canvas = this.canvas;

      canvas.addEventListener('pointermove', (e: PointerEvent) => {
        if (this.isDragging && this.dragStart) {
          this.tx = this.dragStart.tx + (e.clientX - this.dragStart.x);
          this.ty = this.dragStart.ty + (e.clientY - this.dragStart.y);
          if (!this.rafId) this.draw(); // redraw pan when frozen
          return;
        }
        const rect = canvas.getBoundingClientRect();
        const hit = this.hitTest(e.clientX - rect.left, e.clientY - rect.top);
        if (hit !== this.hoveredNode) {
          this.hoveredNode = hit;
          canvas.style.cursor = hit ? 'pointer' : 'grab';
          if (!this.rafId) this.draw(); // redraw hover when frozen
        }
      });

      canvas.addEventListener('pointerdown', (e: PointerEvent) => {
        canvas.setPointerCapture(e.pointerId);
        this.pointerDownPos = { x: e.clientX, y: e.clientY };
        this.pointerDownTime = Date.now();
        this.dragStart = { x: e.clientX, y: e.clientY, tx: this.tx, ty: this.ty };
        canvas.style.cursor = 'grabbing';
      });

      canvas.addEventListener('pointerup', (e: PointerEvent) => {
        if (!this.pointerDownPos) return;
        const elapsed = Date.now() - this.pointerDownTime;
        const dx = e.clientX - this.pointerDownPos.x;
        const dy = e.clientY - this.pointerDownPos.y;
        if (elapsed < 350 && Math.sqrt(dx * dx + dy * dy) < 12) {
          const rect = canvas.getBoundingClientRect();
          this.handleTap(e.clientX - rect.left, e.clientY - rect.top);
        }
        this.isDragging = false; this.dragStart = null; this.pointerDownPos = null;
        canvas.style.cursor = this.hoveredNode ? 'pointer' : 'grab';
      });

      canvas.addEventListener('pointermove', (e: PointerEvent) => {
        if (!this.pointerDownPos || this.isDragging) return;
        const dx = e.clientX - this.pointerDownPos.x, dy = e.clientY - this.pointerDownPos.y;
        if (Math.sqrt(dx * dx + dy * dy) > 8) this.isDragging = true;
      });

      canvas.addEventListener('wheel', (e: WheelEvent) => {
        e.preventDefault();
        this.scale = Math.max(0.3, Math.min(3.5, this.scale * (e.deltaY > 0 ? 0.9 : 1.1)));
        if (!this.rafId) this.draw(); // redraw zoom when frozen
      }, { passive: false });

      const getPD = (e: TouchEvent) => {
        const dx = e.touches[0].clientX - e.touches[1].clientX;
        const dy = e.touches[0].clientY - e.touches[1].clientY;
        return Math.sqrt(dx * dx + dy * dy);
      };
      canvas.addEventListener('touchstart', (e: TouchEvent) => {
        if (e.touches.length === 2) { this.pinchStart = getPD(e); this.pinchScale = this.scale; }
      }, { passive: true });
      canvas.addEventListener('touchmove', (e: TouchEvent) => {
        if (e.touches.length === 2 && this.pinchStart !== null) {
          this.scale = Math.max(0.3, Math.min(3.5, this.pinchScale * (getPD(e) / this.pinchStart)));
          e.preventDefault();
          if (!this.rafId) this.draw(); // redraw pinch-zoom when frozen
        }
      }, { passive: false });
      canvas.addEventListener('touchend', () => { this.pinchStart = null; });

      window.addEventListener('resize', () => { this.resize(); this.fitToCanvas(); });
    }

    destroy() { cancelAnimationFrame(this.rafId); }
  }

  // ─── Overlay lifecycle ────────────────────────────────────────────────────
  let graph: AtlasGraph | null = null;
  const overlay  = document.getElementById('atlas-overlay')!;
  const trigger  = document.getElementById('atlas-trigger')!;
  const closeBtn = document.getElementById('atlas-close')!;
  const canvas   = document.getElementById('atlas-canvas') as HTMLCanvasElement;
  const poemId   = (overlay as HTMLElement).dataset.poemId!;
  const worldKey = (overlay as HTMLElement).dataset.world!;
  let savedScroll = 0;

  function openAtlas() {
    savedScroll = window.scrollY;
    overlay.setAttribute('aria-hidden', 'false');
    overlay.classList.add('is-open');
    gsap.fromTo(overlay, { opacity: 0, y: 8 }, { opacity: 1, y: 0, duration: 0.32, ease: 'power2.out' });
    if (graph) graph.destroy();
    graph = new AtlasGraph(canvas, poemId, worldKey);
    // Set interpretation summary
    const summaryEl = document.getElementById('atlas-summary');
    if (summaryEl) summaryEl.textContent = graph.buildSummaryText();
    document.getElementById('atlas-hint')!.textContent = graph.isStub
      ? 'tap any attribute to find poems with that quality — this poem\'s position is not yet mapped'
      : 'highlighted attributes belong to this poem — tap one to explore the field';
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }

  function closeAtlas() {
    gsap.to(overlay, {
      opacity: 0, y: 6, duration: 0.22, ease: 'power2.in',
      onComplete: () => {
        overlay.classList.remove('is-open');
        overlay.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        window.scrollTo({ top: savedScroll, behavior: 'instant' });
        trigger.focus();
      },
    });
  }

  trigger.addEventListener('click', openAtlas);
  closeBtn.addEventListener('click', closeAtlas);

  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape' && overlay.classList.contains('is-open')) closeAtlas();
  });

  overlay.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key !== 'Tab') return;
    const focusable = overlay.querySelectorAll<HTMLElement>('button, a, [tabindex="0"]');
    const first = focusable[0], last = focusable[focusable.length - 1];
    if (e.shiftKey) { if (document.activeElement === first) { e.preventDefault(); last.focus(); } }
    else            { if (document.activeElement === last)  { e.preventDefault(); first.focus(); } }
  });
</script>
