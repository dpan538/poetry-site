---
// AtlasOverlay.astro
// ATLAS — structural map for daipan.ink
// A static interpretive layer: shows the current poem's position in the attribute field.
interface Props {
  poemId: string;
  world: string;
}
const { poemId, world } = Astro.props;
---

<!-- ATLAS trigger button — fixed top-right on poem pages -->
<button
  id="atlas-trigger"
  class="atlas-trigger"
  aria-label="Open ATLAS — poem structural map"
  data-poem-id={poemId}
  data-world={world}
>
  ATLAS
</button>

<!-- ATLAS overlay -->
<div
  id="atlas-overlay"
  class="atlas-overlay"
  role="dialog"
  aria-label="ATLAS — structural map"
  aria-modal="true"
  aria-hidden="true"
  data-poem-id={poemId}
  data-world={world}
>
  <!-- Header bar -->
  <div class="atlas-header">
    <span class="atlas-wordmark">ATLAS</span>
    <span class="atlas-subtitle">structural map</span>
    <button id="atlas-close" class="atlas-close" aria-label="Close ATLAS">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.2">
        <line x1="1" y1="1" x2="13" y2="13"/>
        <line x1="13" y1="1" x2="1" y2="13"/>
      </svg>
    </button>
  </div>

  <!-- Legend — not aria-hidden; text labels carry the meaning, color dots are decorative -->
  <div class="atlas-legend">
    <span class="atlas-legend-item atlas-legend-mode">speaker mode</span>
    <span class="atlas-legend-sep">·</span>
    <span class="atlas-legend-item atlas-legend-type">poem act</span>
    <span class="atlas-legend-sep">·</span>
    <span class="atlas-legend-item atlas-legend-imagery">imagery</span>
    <span class="atlas-legend-desc">— highlighted = active in this poem</span>
  </div>

  <!-- Summary sentence — counts active attributes -->
  <p id="atlas-summary" class="atlas-summary" aria-live="polite"></p>

  <!-- Screen reader text alternative for the canvas — WCAG 1.1.1 / 1.3.1 -->
  <!-- Lists the poem's active attributes so AT users get the same structural information -->
  <p id="atlas-sr-attrs" class="atlas-sr-only" aria-live="polite"></p>

  <!-- Canvas — the attribute field (aria-hidden: AT gets info via atlas-sr-attrs above) -->
  <canvas id="atlas-canvas" class="atlas-canvas" aria-hidden="true"></canvas>

  <!-- Fixed footer zone: always reserves the same height so canvas never moves.
       Annotation and hint share this space; only one is visible at a time. -->
  <div class="atlas-footer">
    <!-- Annotation panel: fades in over the hint when an attribute is selected -->
    <div id="atlas-anno" class="atlas-anno" role="region" aria-label="Attribute annotation" aria-live="polite" aria-atomic="true"></div>
    <!-- Hint: centered in the footer, fades out when annotation is visible -->
    <p id="atlas-hint" class="atlas-hint">tap a quality to read its definition</p>
  </div>
</div>

<style>
  /* ── Trigger button ──────────────────────────────────────────────────────── */
  .atlas-trigger {
    position: fixed;
    top: calc(var(--site-nav-height, 56px) + var(--space-lg, 34px));
    right: max(var(--margin-x, 24px), 12px);
    z-index: 150;
    background: none;
    border: none;
    /* WCAG 2.5.5: 44×44px minimum touch target */
    padding: 12px 8px;
    min-height: 44px;
    display: flex;
    align-items: center;
    cursor: pointer;
    /* font-family: inherit respects per-world font (Helvetica Neue / Futura / Georgia) */
    font-family: inherit;
    font-size: 19px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    /* WCAG 1.4.3: #595959 on #f5f2ed = 6.27:1 ✅ (opacity:0.35 was only 2.17:1 ❌) */
    color: var(--color-meta, #595959);
    opacity: 1;
    line-height: 1.2;
    transition: color 0.2s;
  }

  .atlas-trigger:hover { color: var(--color-primary, #1a1a1a); }

  .atlas-trigger:focus-visible {
    outline: 2px solid var(--color-accent, #c0392b);
    outline-offset: 4px;
    border-radius: 1px;
  }

  /* ── Overlay ─────────────────────────────────────────────────────────────── */
  .atlas-overlay {
    position: fixed;
    inset: 0;
    z-index: 900;
    background: var(--color-bg, #f5f2ed);
    display: flex;
    flex-direction: column;
    opacity: 0;
    pointer-events: none;
  }

  .atlas-overlay.is-open { pointer-events: all; }

  /* ── Header ──────────────────────────────────────────────────────────────── */
  .atlas-header {
    display: flex;
    align-items: baseline;
    gap: 12px;
    padding: 20px var(--margin-x, 24px) 0;
    flex-shrink: 0;
  }

  .atlas-wordmark {
    font-size: 13px;
    letter-spacing: 0.16em;
    color: var(--color-primary, #1a1a1a);
    font-family: inherit;
  }

  .atlas-subtitle {
    font-size: 13px;
    letter-spacing: 0.06em;
    color: var(--color-meta, #595959);
    font-style: italic;
  }

  .atlas-close {
    margin-left: auto;
    background: transparent;
    border: none;
    /* WCAG 2.5.5: 44×44px minimum touch target (14px SVG + 30px padding = 44px) */
    padding: 15px;
    cursor: pointer;
    color: var(--color-meta, #595959);
    transition: color 0.15s ease, transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .atlas-close:hover { color: var(--color-primary, #1a1a1a); transform: rotate(90deg); }

  .atlas-close:focus-visible {
    outline: 2px solid var(--color-accent, #c0392b);
    outline-offset: 3px;
    border-radius: 1px;
  }

  /* ── Legend ──────────────────────────────────────────────────────────────── */
  .atlas-legend {
    display: flex;
    gap: 22px;
    align-items: center;
    padding: 14px var(--margin-x, 24px) 0;
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  .atlas-legend-sep {
    font-size: 12px;
    color: var(--color-meta, #595959);
    opacity: 0.40;
  }

  .atlas-legend-desc {
    font-size: 14px;
    letter-spacing: 0.02em;
    /* WCAG 1.4.3: opacity:0.75 was only 3.58:1 ❌ — removed, full #595959 = 6.27:1 ✅ */
    color: var(--color-meta, #595959);
    font-style: italic;
    margin-left: 2px;
  }

  .atlas-legend-item {
    font-size: 15px;
    letter-spacing: 0.04em;
    color: var(--color-meta, #595959);
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .atlas-legend-item::before {
    content: '';
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .atlas-legend-mode::before   { background: #b8a898; }
  .atlas-legend-type::before   { background: #8a96a8; }
  .atlas-legend-imagery::before { background: #8a9e8a; }

  /* ── Summary line ───────────────────────────────────────────────────────── */
  .atlas-summary {
    font-size: 16px;
    letter-spacing: 0.02em;
    color: var(--color-meta, #595959);
    font-style: italic;
    text-align: center;
    padding: 10px var(--margin-x, 24px) 0;
    flex-shrink: 0;
    min-height: 1.6em;
    margin: 0;
    line-height: 1.5;
  }

  /* ── Canvas ──────────────────────────────────────────────────────────────── */
  .atlas-canvas {
    flex: 1;
    width: 100%;
    display: block;
    touch-action: manipulation; /* allows tap; no pan/pinch (drag removed) */
    min-height: 0;
  }

  /* ── Fixed footer: canvas height is 100% stable regardless of interaction ── */
  /* Both annotation and hint live here; the space is always reserved in flex.  */
  .atlas-footer {
    flex-shrink: 0;
    height: 180px;           /* fixed — never changes → canvas never moves */
    position: relative;
    border-top: 0.5px solid rgba(26, 26, 26, 0.09);
  }

  /* Annotation: fills the footer, fades in on top of the hint */
  .atlas-anno {
    position: absolute;
    inset: 0;
    z-index: 1;              /* above hint */
    background: var(--color-bg, #f5f2ed);
    overflow: hidden;
    padding: 18px var(--margin-x, 24px) 14px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.22s ease;
  }

  .atlas-anno.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  /* Hide hint when annotation is visible */
  #atlas-anno.is-open ~ #atlas-hint {
    opacity: 0;
    pointer-events: none;
  }

  /* annotation internals (set by JS innerHTML) */
  :global(.atlas-anno-header) {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 9px;
  }

  :global(.atlas-anno-cat) {
    font-size: 12.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    flex-shrink: 0;
    line-height: 1.4;
    padding-top: 3px; /* optical baseline alignment with name */
  }

  /* WCAG 1.4.3: darkened from #9e8e7e/7a8696/728e72 (all ~2.8-3.3:1 ❌) to pass 4.5:1 ✅ */
  :global(.atlas-anno-cat.tag-mode)    { color: #776a5e; } /* 4.69:1 ✅ */
  :global(.atlas-anno-cat.tag-type)    { color: #5e6e80; } /* 4.68:1 ✅ */
  :global(.atlas-anno-cat.tag-imagery) { color: #547054; } /* 4.92:1 ✅ */

  :global(.atlas-anno-name) {
    font-size: 22px;
    font-weight: normal;
    font-family: Georgia, 'Times New Roman', serif;
    letter-spacing: -0.01em;
    color: var(--color-primary, #1a1a1a);
    margin: 0;
    line-height: 1.15;
  }

  :global(.atlas-anno-def) {
    margin: 0 0 10px;
    font-size: 15.5px;
    line-height: 1.7;
    color: var(--color-primary, #1a1a1a);
    font-style: italic;
    opacity: 0.80;
  }

  :global(.atlas-anno-meta) {
    font-size: 13.5px;
    letter-spacing: 0.03em;
    color: var(--color-meta, #595959);
    display: flex;
    gap: 7px;
    align-items: center;
    flex-wrap: wrap;
    line-height: 1.4;
  }

  :global(.atlas-anno-active) {
    color: var(--color-primary, #1a1a1a);
  }

  :global(.atlas-anno-inactive) {
    color: var(--color-meta, #595959);
    font-style: italic;
  }

  :global(.atlas-anno-sep) {
    opacity: 0.35;
    font-size: 13px;
  }

  :global(.atlas-anno-count) {
    color: var(--color-meta, #595959);
  }

  /* ── Screen reader only — text alternative for canvas ── */
  .atlas-sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Hint: centered inside the fixed footer, below annotation layer ── */
  .atlas-hint {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 15px;
    letter-spacing: 0.03em;
    color: var(--color-meta, #595959);
    font-style: italic;
    text-align: center;
    padding: 0 var(--margin-x, 24px);
    margin: 0;
    transition: opacity 0.22s ease;
  }
</style>


<script>
  import atlas from '../data/atlas.json';
  import gsap from 'gsap';

  // ─── Constants ────────────────────────────────────────────────────────────
  const WORLD_COLORS: Record<string, { accent: string; soft: string }> = {
    'their-world': { accent: '#c0392b', soft: '#e8c8c4' },
    'bless-you':   { accent: '#9b7b8b', soft: '#ddd0d8' },
    'still-life':  { accent: '#8a9e8a', soft: '#c8d8c8' },
  };

  const ATTR_COLORS: Record<string, string> = {
    mode:    '#b8a898',
    type:    '#8a96a8',
    imagery: '#8a9e8a',
  };

  const ATTR_LABELS: Record<string, string> = {
    mode: 'speaker mode', type: 'poem act', imagery: 'imagery',
  };

  // Controlled vocabulary — full attribute field.
  const VOCAB: Record<string, string[]> = {
    mode: [
      'solitary_witness', 'child_perception', 'observer', 'fractured_self',
      'addressed_speaker', 'devotional_speaker', 'plural_voice', 'absent_other_address',
    ],
    type: [
      'memory_fragment', 'scene', 'witness', 'monologue', 'confession',
      'lament', 'invocation', 'prayer', 'chant', 'manifesto', 'warning', 'farewell',
    ],
    imagery: [
      'shadow', 'child', 'room', 'house', 'window', 'glass',
      'light', 'eye', 'voice', 'flowers', 'faith', 'sky',
    ],
  };

  // Zone positions: mode upper-left, type upper-right, imagery below.
  // Zones are generously sized so repulsion can spread 32 nodes without overlap.
  const ZONES: Record<string, { cx: number; cy: number; sx: number; sy: number }> = {
    mode:    { cx: -225, cy: -80, sx: 105, sy: 165 },
    type:    { cx:  225, cy: -80, sx:  98, sy: 158 },
    imagery: { cx:    0, cy: 205, sx: 230, sy:  90 },
  };

  const ACTIVE_PULL = 0.35;

  // ─── Attribute definitions ────────────────────────────────────────────────
  const ATTR_DESCRIPTIONS: Record<string, string> = {
    solitary_witness:      'The poem speaks from a position of aloneness — observing without the possibility of intervention.',
    child_perception:      'The world is rendered through a child\'s consciousness: innocent, partial, uneasy with adult logic.',
    observer:              'A detached external viewpoint — watching without full participation or self-disclosure.',
    fractured_self:        'The speaker\'s identity is split, layered, or in contradiction with itself.',
    addressed_speaker:     'The poem speaks directly to another person, real or imagined, naming them into presence.',
    devotional_speaker:    'The speaker\'s address carries the quality of prayer or reverence toward something larger.',
    plural_voice:          'The poem speaks in a collective "we," dissolving individual identity into shared experience.',
    absent_other_address:  'The poem speaks to someone who is absent, gone, or unreachable — a one-sided conversation.',
    memory_fragment:       'A partial, non-linear recollection — the poem captures a piece of the past as it surfaces, incomplete.',
    scene:                 'A present-tense moment rendered in space — the poem unfolds as a place you can stand inside.',
    witness:               'The poem enacts the act of seeing and recording, as if giving testimony.',
    monologue:             'Extended address by a single voice, uninterrupted and self-contained.',
    confession:            'The disclosure of something difficult or hidden — the poem as an act of speaking what has been held.',
    lament:                'Sustained mourning — the poem dwells inside grief without seeking resolution.',
    invocation:            'The poem calls something forth: a person, a quality, a memory, a presence.',
    prayer:                'Appeal or devotion directed beyond the self, toward the uncertain or the unreachable.',
    chant:                 'A repetitive incantatory structure — meaning accumulates through rhythm and recurrence.',
    manifesto:             'Declarative and positional — the poem asserts a way of seeing as if staking ground.',
    warning:               'The poem speaks in a cautionary or prophetic register, addressed to the future.',
    farewell:              'Leave-taking — the poem as a form of ending or final departure.',
    shadow:                'The trace or absence that follows without being named — what a presence leaves behind.',
    child:                 'Youth, vulnerability, the past self as a living presence in the poem.',
    room:                  'Interior space as containment — the poem happens inside enclosure, bounded.',
    house:                 'Domestic structure as inheritance — what we are sheltered and burdened by.',
    window:                'A threshold for looking — the poem frames what can and cannot be crossed.',
    glass:                 'Transparency, fragility, reflection — the permeable border between inner and outer.',
    light:                 'Illumination as presence, arrival, or revelation — what makes visible.',
    eye:                   'The organ of witness — perception, judgment, the experience of being seen.',
    voice:                 'Speech without visible body — presence sustained through sound alone.',
    flowers:               'Beauty, transience, offering — what blooms briefly and cannot be held.',
    faith:                 'Belief, trust, devotion — the poem in relation to what cannot be verified.',
    sky:                   'Expanse, distance, what cannot be held or entered — openness as subject.',
  };

  // ─── Types ────────────────────────────────────────────────────────────────
  interface Node {
    kind: 'anchor' | 'attr';
    x: number; y: number; r: number;
    vx: number; vy: number;
    homeX: number; homeY: number;
    // anchor
    id?: string; title?: string; world?: string;
    // attr
    attrType?: string; value?: string; active?: boolean;
    // animation
    delay: number; currentAlpha: number;
  }

  interface Edge { from: Node; to: Node; color: string; }

  // ─── AtlasGraph ───────────────────────────────────────────────────────────
  class AtlasGraph {
    canvas: HTMLCanvasElement;
    ctx: CanvasRenderingContext2D;
    poemId: string; worldKey: string; poem: any;
    nodes: Node[]; edges: Edge[];
    selectedNode: Node | null; hoveredNode: Node | null;
    tx: number; ty: number; scale: number;
    cx: number; cy: number; dpr: number;
    isDragging: boolean;
    dragStart: { x: number; y: number; tx: number; ty: number } | null;
    pinchStart: number | null; pinchScale: number;
    pointerDownPos: { x: number; y: number } | null; pointerDownTime: number;
    rafId: number; isStub: boolean;

    constructor(canvas: HTMLCanvasElement, poemId: string, worldKey: string) {
      this.canvas = canvas;
      this.ctx = canvas.getContext('2d')!;
      this.poemId = poemId; this.worldKey = worldKey;
      this.poem = (atlas.poems as any[]).find((p: any) => p.id === poemId) ?? null;
      this.nodes = []; this.edges = [];
      this.selectedNode = null; this.hoveredNode = null;
      this.tx = 0; this.ty = 0; this.scale = 1;
      this.cx = 0; this.cy = 0; this.dpr = window.devicePixelRatio || 1;
      this.isDragging = false; this.dragStart = null;
      this.pinchStart = null; this.pinchScale = 1;
      this.pointerDownPos = null; this.pointerDownTime = 0;
      this.rafId = 0; this.isStub = !this.poem?.mode;

      this.resize();
      this.buildGraph();
      this.primeLayout(320); // settle positions synchronously — no visible motion
      this.fitToCanvas();
      this.setupEvents();
      this.startLoop();
    }

    // ── Deterministic hash ────────────────────────────────────────────────────
    hashStr(s: string): number {
      let h = 0;
      for (let i = 0; i < s.length; i++) h = (Math.imul(31, h) + s.charCodeAt(i)) | 0;
      return (h >>> 0) / 4294967296;
    }

    // ── Zone home position ────────────────────────────────────────────────────
    computeHome(attrType: string, value: string, active: boolean): { x: number; y: number } {
      const z = ZONES[attrType] || { cx: 0, cy: 0, sx: 80, sy: 80 };
      const hx = this.hashStr(value + '_hx') * 2 - 1;
      const hy = this.hashStr(value + '_hy') * 2 - 1;
      const rawX = z.cx + hx * z.sx;
      const rawY = z.cy + hy * z.sy;
      if (active) return { x: rawX * (1 - ACTIVE_PULL), y: rawY * (1 - ACTIVE_PULL) };
      return { x: rawX, y: rawY };
    }

    // ── Graph construction ─────────────────────────────────────────────────────
    buildGraph() {
      this.nodes = []; this.edges = [];
      const poem = this.poem;
      const activeSets: Record<string, Set<string>> = {
        mode:    new Set<string>(poem?.mode    || []),
        type:    new Set<string>(poem?.type    || []),
        imagery: new Set<string>(poem?.imagery || []),
      };

      // Anchor at origin
      const anchor: Node = {
        kind: 'anchor', x: 0, y: 0, r: 24, vx: 0, vy: 0, homeX: 0, homeY: 0,
        id: poem?.id, title: poem?.title ?? this.poemId,
        world: poem?.world ?? this.worldKey,
        delay: 0, currentAlpha: 1,
      };
      this.nodes.push(anchor);

      // Attr node for every vocabulary item
      ['mode', 'type', 'imagery'].forEach(attrType => {
        VOCAB[attrType].forEach((value, i) => {
          const active = activeSets[attrType].has(value);
          const home = this.computeHome(attrType, value, active);
          const jx = (this.hashStr(value + '_jx') - 0.5) * 12;
          const jy = (this.hashStr(value + '_jy') - 0.5) * 12;
          const n: Node = {
            kind: 'attr', attrType, value,
            x: home.x + jx, y: home.y + jy,
            vx: 0, vy: 0, homeX: home.x, homeY: home.y,
            r: active ? 10 : 5, active,
            delay: 0.04 + i * 0.042, currentAlpha: 0,
          };
          this.nodes.push(n);
          if (active) this.edges.push({ from: anchor, to: n, color: ATTR_COLORS[attrType] });
        });
      });
    }

    // ── Force simulation (used only by primeLayout — not called during render) ─
    simulateStep() {
      // Softer zone pull lets repulsion spread nodes freely across the larger zones.
      // Higher REPEL_K and minD (75px clearance) prevent dot+label overlap.
      const ZONE_K = 0.018, ANCHOR_K = 0.009, REPEL_K = 1.6, DAMPING = 0.76;
      const attrNodes = this.nodes.filter(n => n.kind === 'attr');
      attrNodes.forEach(n => {
        n.vx += (n.homeX - n.x) * ZONE_K;
        n.vy += (n.homeY - n.y) * ZONE_K;
        if (n.active) {
          n.vx += (0 - n.x) * ANCHOR_K;
          n.vy += (0 - n.y) * ANCHOR_K;
        }
        const allVis = [this.nodes[0], ...attrNodes];
        allVis.forEach(other => {
          if (other === n) return;
          const dx = n.x - other.x, dy = n.y - other.y;
          const dist = Math.sqrt(dx * dx + dy * dy) || 0.1;
          // 75px minimum gap between dot surfaces — enough room for label text
          const minD = n.r + other.r + 75;
          if (dist < minD) {
            const f = REPEL_K * (minD - dist) / dist;
            n.vx += dx * f; n.vy += dy * f;
          }
        });
        n.vx *= DAMPING; n.vy *= DAMPING;
        n.x += n.vx; n.y += n.vy;
      });
    }

    // Settle layout synchronously before first draw — more steps for larger zones
    primeLayout(steps = 800) {
      for (let i = 0; i < steps; i++) this.simulateStep();
    }

    // ── Fit canvas ────────────────────────────────────────────────────────────
    fitToCanvas() {
      // Larger span matches the expanded zone footprint
      const spanW = 760, spanH = 580;
      const scaleW = (this.cx * 2 * 0.82) / spanW;
      const scaleH = (this.cy * 2 * 0.82) / spanH;
      this.scale = Math.min(scaleW, scaleH, 1.3);
      this.ty = -30 * this.scale;
    }

    resize() {
      // Clear any stale explicit dimensions so CSS/flex controls display size
      this.canvas.style.width = '';
      this.canvas.style.height = '';
      // Measure the canvas's OWN CSS display rect (flex-determined, not the overlay's)
      // getBoundingClientRect() forces synchronous reflow — returns post-flex size
      const rect = this.canvas.getBoundingClientRect();
      const W = Math.max(rect.width,  1);
      const H = Math.max(rect.height, 1);
      // Set pixel dimensions to match CSS display size (×dpr for sharpness)
      this.canvas.width  = W * this.dpr;
      this.canvas.height = H * this.dpr;
      this.cx = W / 2; this.cy = H / 2;
    }

    // ── Entry animation — alpha fade in only, no position movement ────────────
    startLoop() {
      if (this.rafId) cancelAnimationFrame(this.rafId);
      const start = performance.now();
      const dur = 900;
      const tick = (now: number) => {
        const t = Math.min(1, (now - start) / dur);
        this.nodes.forEach(n => {
          if (n.kind === 'anchor') return;
          const p = Math.max(0, Math.min(1, (t - n.delay) / 0.35));
          n.currentAlpha = this.easeOut(p);
        });
        this.draw();
        if (t < 1) {
          this.rafId = requestAnimationFrame(tick);
        } else {
          this.rafId = 0;
        }
      };
      this.rafId = requestAnimationFrame(tick);
    }

    easeOut(t: number) { return 1 - Math.pow(1 - t, 3); }

    // ── Drawing ───────────────────────────────────────────────────────────────
    draw() {
      const ctx = this.ctx, dpr = this.dpr;
      const W = this.canvas.width / dpr, H = this.canvas.height / dpr;
      ctx.save();
      ctx.scale(dpr, dpr);
      ctx.clearRect(0, 0, W, H);
      ctx.translate(this.cx + this.tx, this.cy + this.ty);
      ctx.scale(this.scale, this.scale);
      this.drawEdges();
      this.drawNodes();
      ctx.restore();
    }

    // Subtle zone halos — fill + dashed ring + label
    drawZoneHalos() {
      const ctx = this.ctx;
      const zones = [
        { key: 'mode',    label: 'speaker mode', rx: ZONES.mode.sx + 50,    ry: ZONES.mode.sy + 28,    labelY: ZONES.mode.cy - ZONES.mode.sy - 18 },
        { key: 'type',    label: 'poem act',      rx: ZONES.type.sx + 50,    ry: ZONES.type.sy + 28,    labelY: ZONES.type.cy - ZONES.type.sy - 18 },
        { key: 'imagery', label: 'imagery',       rx: ZONES.imagery.sx + 40, ry: ZONES.imagery.sy + 46, labelY: ZONES.imagery.cy + ZONES.imagery.sy + 20 },
      ];

      zones.forEach(({ key, rx, ry }) => {
        const z = ZONES[key];
        ctx.save();
        ctx.globalAlpha = 0.07;
        ctx.beginPath(); ctx.ellipse(z.cx, z.cy, rx, ry, 0, 0, Math.PI * 2);
        ctx.fillStyle = ATTR_COLORS[key]; ctx.fill();
        ctx.restore();
      });

      zones.forEach(({ key, rx, ry }) => {
        const z = ZONES[key];
        ctx.save();
        ctx.globalAlpha = 0.13;
        ctx.beginPath(); ctx.ellipse(z.cx, z.cy, rx + 2, ry + 2, 0, 0, Math.PI * 2);
        ctx.strokeStyle = ATTR_COLORS[key]; ctx.lineWidth = 0.8;
        ctx.setLineDash([4, 5]); ctx.stroke(); ctx.setLineDash([]);
        ctx.restore();
      });

      ctx.save();
      ctx.font = 'italic 12px Georgia, serif';
      ctx.textBaseline = 'middle'; ctx.textAlign = 'center';
      zones.forEach(({ key, label, labelY }) => {
        ctx.globalAlpha = 0.58;
        ctx.fillStyle = ATTR_COLORS[key];
        ctx.fillText(label, ZONES[key].cx, labelY);
      });
      ctx.restore();
    }

    // Edges: anchor → active attr only
    drawEdges() {
      const ctx = this.ctx;
      this.edges.forEach(edge => {
        const alpha = edge.to.currentAlpha ?? 0;
        if (alpha < 0.02) return;
        const isSel = this.selectedNode === edge.to;
        ctx.save();
        ctx.globalAlpha = alpha * (isSel ? 0.65 : 0.28);
        ctx.strokeStyle = edge.color;
        ctx.lineWidth = isSel ? 1.5 : 1.0;
        ctx.beginPath();
        ctx.moveTo(edge.from.x, edge.from.y);
        ctx.lineTo(edge.to.x, edge.to.y);
        ctx.stroke();
        ctx.restore();
      });
    }

    drawNodes() {
      // Draw attr nodes first (below anchor)
      this.nodes.filter(n => n.kind === 'attr').forEach(n => this.drawNode(n));
      this.nodes.filter(n => n.kind === 'anchor').forEach(n => this.drawNode(n));
    }

    drawNode(n: Node) {
      const alpha = n.currentAlpha ?? 0;
      if (alpha < 0.02 && n.kind !== 'anchor') return;
      const ctx = this.ctx;
      ctx.save();
      ctx.globalAlpha = Math.max(0, Math.min(1, alpha));
      if (n.kind === 'anchor') this.drawAnchorNode(n);
      if (n.kind === 'attr')   this.drawAttrNode(n);
      ctx.restore();
    }

    drawAnchorNode(n: Node) {
      const ctx = this.ctx;
      const wc = WORLD_COLORS[n.world || this.worldKey] || WORLD_COLORS['their-world'];
      // Faint outer halo
      ctx.beginPath(); ctx.arc(0, 0, n.r + 12, 0, Math.PI * 2);
      ctx.strokeStyle = wc.accent; ctx.lineWidth = 0.8;
      ctx.globalAlpha *= 0.14; ctx.stroke(); ctx.globalAlpha /= 0.14;
      // Soft fill
      ctx.beginPath(); ctx.arc(0, 0, n.r, 0, Math.PI * 2);
      ctx.fillStyle = wc.soft;
      ctx.globalAlpha *= 0.24; ctx.fill(); ctx.globalAlpha /= 0.24;
      // Border
      ctx.beginPath(); ctx.arc(0, 0, n.r, 0, Math.PI * 2);
      ctx.strokeStyle = wc.accent; ctx.lineWidth = 1.8; ctx.stroke();
      // Title below — larger, comfortable to read
      ctx.font = '17px Georgia, serif'; ctx.fillStyle = '#1a1a1a';
      ctx.textAlign = 'center'; ctx.textBaseline = 'top';
      this.wrapText(n.title || '', 0, n.r + 11, 140, 20);
    }

    drawAttrNode(n: Node) {
      const ctx = this.ctx;
      const color = ATTR_COLORS[n.attrType!] || '#888';
      const isHov = this.hoveredNode === n;
      const isSel = this.selectedNode === n;
      const active = n.active ?? false;

      // Active nodes: full presence.
      // Inactive: clearly subordinate but still legible — not faint, just smaller and muted.
      const baseOpacity = active ? 1 : 0.58;
      ctx.globalAlpha *= baseOpacity;

      const baseR = active ? 10 : 5;
      const r = baseR * (isHov || isSel ? 1.5 : 1);

      // Soft aura for active nodes
      if (active && !isSel) {
        ctx.beginPath(); ctx.arc(n.x, n.y, r + 12, 0, Math.PI * 2);
        ctx.fillStyle = color; ctx.globalAlpha *= 0.13; ctx.fill(); ctx.globalAlpha /= 0.13;
      }

      // Dot
      ctx.beginPath(); ctx.arc(n.x, n.y, r, 0, Math.PI * 2);
      ctx.fillStyle = isSel ? '#1a1a1a' : color; ctx.fill();

      // Selection ring
      if (isSel) {
        ctx.beginPath(); ctx.arc(n.x, n.y, r + 6, 0, Math.PI * 2);
        ctx.strokeStyle = color; ctx.lineWidth = 1.0;
        ctx.globalAlpha *= 0.55; ctx.stroke(); ctx.globalAlpha /= 0.55;
      }

      // Label — radially outward from anchor, larger and more readable
      const angle = Math.atan2(n.y, n.x);
      const deg = angle * 180 / Math.PI;
      const gap = r + 14; // generous gap between dot and label start
      let lx = n.x, ly = n.y;
      let ta: CanvasTextAlign = 'center', tb: CanvasTextBaseline = 'middle';

      if (deg > -70 && deg < 70)          { lx = n.x + gap; ta = 'left'; }
      else if (deg > 110 || deg < -110)   { lx = n.x - gap; ta = 'right'; }
      else if (deg >= 70 && deg <= 110)   { ly = n.y + gap + 2; tb = 'top'; ta = 'center'; }
      else                                { ly = n.y - gap - 2; tb = 'bottom'; ta = 'center'; }

      // Active: 15px upright; inactive: 13px italic
      const fs = active ? 15 : 13;
      ctx.font = `${active ? '' : 'italic '}${fs}px Georgia, serif`;
      // WCAG 1.4.3: dot drawn at baseOpacity (0.58 for inactive) but text needs higher opacity.
      // #5a5452 at 58% → 2.62:1 ❌. At 88% → 4.98:1 ✅. Save/restore alpha around text only.
      const preTextAlpha = ctx.globalAlpha;
      if (!active) {
        // Raise text opacity: divide out baseOpacity (0.58), multiply by 0.88 of fade alpha
        ctx.globalAlpha = (preTextAlpha / baseOpacity) * 0.88;
      }
      ctx.fillStyle = isSel ? '#0a0a0a' : active ? '#1a1a1a' : '#5a5452';
      ctx.textAlign = ta; ctx.textBaseline = tb;
      ctx.fillText(this.formatLabel(n.value!), lx, ly);
      ctx.globalAlpha = preTextAlpha; // restore dot opacity for correct restore at end

      ctx.globalAlpha /= baseOpacity;
    }

    // ── Text helpers ──────────────────────────────────────────────────────────
    wrapText(text: string, x: number, y: number, maxW: number, lineH: number) {
      const ctx = this.ctx, words = text.split(' ');
      let line = '', cy = y;
      for (let i = 0; i < words.length; i++) {
        const test = line + words[i] + ' ';
        if (ctx.measureText(test).width > maxW && i > 0) {
          ctx.fillText(line.trim(), x, cy); line = words[i] + ' '; cy += lineH;
        } else line = test;
      }
      ctx.fillText(line.trim(), x, cy);
    }

    formatLabel(val: string) { return val.replace(/_/g, ' '); }

    // ── Summary + annotation text ─────────────────────────────────────────────
    buildSummaryText(): string {
      const poem = this.poem;
      if (!poem?.mode) return '';
      const nMode = (poem.mode || []).length;
      const nType = (poem.type || []).length;
      const nImg  = (poem.imagery || []).length;
      const parts: string[] = [];
      if (nMode > 0) parts.push(`${nMode} speaker ${nMode === 1 ? 'mode' : 'modes'}`);
      if (nType > 0) parts.push(`${nType} ${nType === 1 ? 'act' : 'acts'}`);
      if (nImg  > 0) parts.push(`${nImg} imagery ${nImg === 1 ? 'field' : 'fields'}`);
      if (!parts.length) return '';
      const listed = parts.length === 1 ? parts[0]
        : parts.slice(0, -1).join(', ') + ', and ' + parts[parts.length - 1];
      return `This poem activates ${listed}.`;
    }

    setSummary(text: string) {
      const el = document.getElementById('atlas-summary');
      if (el) el.textContent = text;
    }

    // Show attribute annotation panel (no poem lists — pure definition)
    showAttrAnnotation(n: Node) {
      const label = this.formatLabel(n.value!);
      const catLabel = ATTR_LABELS[n.attrType!] || n.attrType!;
      const description = ATTR_DESCRIPTIONS[n.value!] || '';
      const active = n.active ?? false;

      // Count mapped poems sharing this attribute (not including current poem)
      const sharedCount = (atlas.poems as any[]).filter((p: any) => {
        const arr: string[] = p[n.attrType!] || [];
        return arr.includes(n.value!) && p.id !== this.poemId && p[n.attrType!]?.length > 0;
      }).length;

      const annoEl = document.getElementById('atlas-anno')!;
      annoEl.innerHTML = `
        <div class="atlas-anno-header">
          <span class="atlas-anno-cat tag-${n.attrType}">${catLabel}</span>
          <h3 class="atlas-anno-name">${label}</h3>
        </div>
        ${description ? `<p class="atlas-anno-def">${description}</p>` : ''}
        <p class="atlas-anno-meta">
          <span class="${active ? 'atlas-anno-active' : 'atlas-anno-inactive'}">
            ${active ? 'active in this poem' : 'not present in this poem'}
          </span>
          ${sharedCount > 0 ? `<span class="atlas-anno-sep">·</span><span class="atlas-anno-count">appears in ${sharedCount} other poem${sharedCount > 1 ? 's' : ''} in the collection</span>` : ''}
        </p>
      `;
      annoEl.classList.add('is-open');

      // Update summary with contextual sentence
      this.setSummary(active
        ? `${label}: one of this poem's active ${catLabel === 'imagery' ? 'image' : catLabel} qualities.`
        : `${label}: a quality in the field, not drawn on by this poem.`
      );

      if (!this.rafId) this.draw();
    }

    hideAnnotation() {
      const el = document.getElementById('atlas-anno');
      if (el) el.classList.remove('is-open');
    }

    // ── Hit testing (anchor + attr only) ──────────────────────────────────────
    // Hit radius is large enough to include the text label, not just the dot.
    // Closest-node wins, so overlapping zones resolve correctly.
    hitTest(px: number, py: number): Node | null {
      const wx = (px - this.cx - this.tx) / this.scale;
      const wy = (py - this.cy - this.ty) / this.scale;
      let best: Node | null = null, bestDist = Infinity;
      for (const n of this.nodes) {
        const dx = n.x - wx, dy = n.y - wy;
        const dist = Math.sqrt(dx * dx + dy * dy);
        // Active attr: large radius (65px) covers dot + label fully.
        // Inactive attr: 50px — generous but yields to nearer active nodes.
        // Anchor: fixed radius around the circle border.
        const hitR = n.kind === 'anchor' ? n.r + 14
          : (n.active ? 65 : 50);
        if (dist < hitR && dist < bestDist) { best = n; bestDist = dist; }
      }
      return best;
    }

    // ── Interaction ───────────────────────────────────────────────────────────
    clearSelection() {
      this.selectedNode = null;
      this.hideAnnotation();
      this.setSummary(this.buildSummaryText());
      document.getElementById('atlas-hint')!.textContent =
        this.isStub ? 'tap any attribute to read its definition'
                    : 'tap a highlighted attribute to read its definition';
      if (!this.rafId) this.draw();
    }

    handleTap(px: number, py: number) {
      const hit = this.hitTest(px, py);
      if (!hit || hit.kind === 'anchor') { this.clearSelection(); return; }
      if (hit === this.selectedNode) { this.clearSelection(); return; }
      this.selectedNode = hit;
      if (hit.kind === 'attr') this.showAttrAnnotation(hit);
    }

    // ── Events — hover + tap only (drag/pan/zoom removed) ────────────────────
    setupEvents() {
      const canvas = this.canvas;

      // Hover: update cursor and hovered node for visual feedback
      canvas.addEventListener('pointermove', (e: PointerEvent) => {
        const rect = canvas.getBoundingClientRect();
        const hit = this.hitTest(e.clientX - rect.left, e.clientY - rect.top);
        const attrHit = hit?.kind === 'attr' ? hit : null;
        if (attrHit !== this.hoveredNode) {
          this.hoveredNode = attrHit;
          canvas.style.cursor = attrHit ? 'pointer' : 'default';
          if (!this.rafId) this.draw();
        }
      });

      // Tap: record press position
      canvas.addEventListener('pointerdown', (e: PointerEvent) => {
        canvas.setPointerCapture(e.pointerId);
        this.pointerDownPos = { x: e.clientX, y: e.clientY };
        this.pointerDownTime = Date.now();
      });

      // Tap: fire if pointer didn't move much and elapsed < 350ms
      canvas.addEventListener('pointerup', (e: PointerEvent) => {
        if (!this.pointerDownPos) return;
        const elapsed = Date.now() - this.pointerDownTime;
        const dx = e.clientX - this.pointerDownPos.x;
        const dy = e.clientY - this.pointerDownPos.y;
        if (elapsed < 350 && Math.sqrt(dx * dx + dy * dy) < 12) {
          const rect = canvas.getBoundingClientRect();
          this.handleTap(e.clientX - rect.left, e.clientY - rect.top);
        }
        this.pointerDownPos = null;
      });

      window.addEventListener('resize', () => { this.resize(); this.fitToCanvas(); if (!this.rafId) this.draw(); });
    }

    destroy() { cancelAnimationFrame(this.rafId); }
  }

  // ─── Overlay lifecycle ────────────────────────────────────────────────────
  let graph: AtlasGraph | null = null;
  const overlay  = document.getElementById('atlas-overlay')!;
  const trigger  = document.getElementById('atlas-trigger')!;
  const closeBtn = document.getElementById('atlas-close')!;
  const canvas   = document.getElementById('atlas-canvas') as HTMLCanvasElement;
  const poemId   = (overlay as HTMLElement).dataset.poemId!;
  const worldKey = (overlay as HTMLElement).dataset.world!;
  let savedScroll = 0;

  // Build accessible text summary of active attributes for screen readers
  function buildSrAttrsText(g: AtlasGraph): string {
    const poem = g.poem;
    if (!poem?.mode) return 'No structural data available for this poem.';
    const lines: string[] = [];
    const labels: Record<string, string> = { mode: 'Speaker mode', type: 'Poem act', imagery: 'Imagery' };
    (['mode', 'type', 'imagery'] as const).forEach(k => {
      const active: string[] = poem[k] || [];
      if (active.length) {
        const names = active.map((v: string) => v.replace(/_/g, ' ')).join(', ');
        lines.push(`${labels[k]}: ${names}.`);
      }
    });
    return lines.length ? 'Active structural qualities — ' + lines.join(' ') : '';
  }

  function openAtlas() {
    savedScroll = window.scrollY;
    overlay.setAttribute('aria-hidden', 'false');
    overlay.classList.add('is-open');
    // Reset annotation panel
    const annoEl = document.getElementById('atlas-anno');
    if (annoEl) { annoEl.classList.remove('is-open'); annoEl.innerHTML = ''; }
    gsap.fromTo(overlay, { opacity: 0, y: 8 }, { opacity: 1, y: 0, duration: 0.32, ease: 'power2.out' });
    if (graph) graph.destroy();
    graph = new AtlasGraph(canvas, poemId, worldKey);
    document.getElementById('atlas-summary')!.textContent = graph.buildSummaryText();
    document.getElementById('atlas-hint')!.textContent = graph.isStub
      ? 'tap any attribute to read its definition'
      : 'tap a highlighted attribute to read its definition';
    // Populate screen reader text alternative for the canvas (WCAG 1.1.1)
    const srEl = document.getElementById('atlas-sr-attrs');
    if (srEl) srEl.textContent = buildSrAttrsText(graph);
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }

  function closeAtlas() {
    gsap.to(overlay, {
      opacity: 0, y: 6, duration: 0.22, ease: 'power2.in',
      onComplete: () => {
        overlay.classList.remove('is-open');
        overlay.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        window.scrollTo({ top: savedScroll, behavior: 'instant' });
        trigger.focus();
      },
    });
  }

  trigger.addEventListener('click', openAtlas);
  closeBtn.addEventListener('click', closeAtlas);

  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape' && overlay.classList.contains('is-open')) closeAtlas();
  });

  overlay.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key !== 'Tab') return;
    const focusable = overlay.querySelectorAll<HTMLElement>('button, a, [tabindex="0"]');
    const first = focusable[0], last = focusable[focusable.length - 1];
    if (e.shiftKey) { if (document.activeElement === first) { e.preventDefault(); last.focus(); } }
    else            { if (document.activeElement === last)  { e.preventDefault(); first.focus(); } }
  });
</script>
