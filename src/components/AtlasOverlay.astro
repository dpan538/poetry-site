---
// AtlasOverlay.astro
// ATLAS — relational reading map for daipan.ink
// Poem ID and world are passed as props; atlas data is read via data-attr and imported in <script>
interface Props {
  poemId: string;
  world: string;
}
const { poemId, world } = Astro.props;
---

<!-- ATLAS trigger button — fixed top-right on poem pages -->
<button
  id="atlas-trigger"
  class="atlas-trigger"
  aria-label="Open ATLAS — poem relation map"
  data-poem-id={poemId}
  data-world={world}
>
  ATLAS
</button>

<!-- ATLAS overlay -->
<div
  id="atlas-overlay"
  class="atlas-overlay"
  role="dialog"
  aria-label="ATLAS — poem relation map"
  aria-modal="true"
  aria-hidden="true"
  data-poem-id={poemId}
  data-world={world}
>
  <!-- Header bar -->
  <div class="atlas-header">
    <span class="atlas-wordmark">ATLAS</span>
    <span class="atlas-subtitle">relation map</span>
    <button id="atlas-close" class="atlas-close" aria-label="Close ATLAS">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.2">
        <line x1="1" y1="1" x2="13" y2="13"/>
        <line x1="13" y1="1" x2="1" y2="13"/>
      </svg>
    </button>
  </div>

  <!-- Legend -->
  <div class="atlas-legend" aria-hidden="true">
    <span class="atlas-legend-item atlas-legend-mode">speaker mode</span>
    <span class="atlas-legend-sep">·</span>
    <span class="atlas-legend-item atlas-legend-type">poem act</span>
    <span class="atlas-legend-sep">·</span>
    <span class="atlas-legend-item atlas-legend-imagery">imagery</span>
    <span class="atlas-legend-desc">— highlighted = active in this poem</span>
  </div>

  <!-- Canvas -->
  <canvas id="atlas-canvas" class="atlas-canvas" aria-hidden="true"></canvas>

  <!-- Hint text -->
  <p id="atlas-hint" class="atlas-hint" aria-live="polite">
    tap speaker · act · image to explore the poem's structural position
  </p>

  <!-- Preview card (shown on poem node click) -->
  <div id="atlas-preview" class="atlas-preview" aria-live="polite" aria-atomic="true"></div>
</div>

<style>
  /* ── Trigger button — mirrors INDEX visual logic, top-right below nav ─────── */
  .atlas-trigger {
    position: fixed;
    top: calc(var(--site-nav-height, 56px) + var(--space-lg, 34px));
    right: max(var(--margin-x, 24px), 12px);
    z-index: 150;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 19px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary, #1a1a1a);
    opacity: 0.35;
    line-height: 1.2;
    transition: opacity 0.2s;
  }

  .atlas-trigger:hover {
    opacity: 1;
    color: var(--color-accent, #1a1a1a);
  }

  .atlas-trigger:focus-visible {
    outline: 2px solid var(--color-accent, #c0392b);
    outline-offset: 4px;
    border-radius: 1px;
  }

  /* ── Overlay ─────────────────────────────────────────────────────────────── */
  .atlas-overlay {
    position: fixed;
    inset: 0;
    z-index: 900;
    background: var(--color-bg, #f5f2ed);
    display: flex;
    flex-direction: column;
    opacity: 0;
    pointer-events: none;
    /* will-change managed by GSAP */
  }

  .atlas-overlay.is-open {
    pointer-events: all;
  }

  /* ── Header ──────────────────────────────────────────────────────────────── */
  .atlas-header {
    display: flex;
    align-items: baseline;
    gap: 10px;
    padding: 16px var(--margin-x, 24px) 0;
    flex-shrink: 0;
  }

  .atlas-wordmark {
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--color-primary, #1a1a1a);
    font-family: inherit;
  }

  .atlas-subtitle {
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--color-meta, #595959);
    font-style: italic;
  }

  .atlas-close {
    margin-left: auto;
    background: transparent;
    border: none;
    padding: 6px;
    cursor: pointer;
    color: var(--color-meta, #595959);
    transition: color 0.15s ease, transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .atlas-close:hover {
    color: var(--color-primary, #1a1a1a);
    transform: rotate(90deg);
  }

  .atlas-close:focus-visible {
    outline: 2px solid var(--color-accent, #c0392b);
    outline-offset: 3px;
    border-radius: 1px;
  }

  /* ── Legend ──────────────────────────────────────────────────────────────── */
  .atlas-legend {
    display: flex;
    gap: 18px;
    align-items: center;
    padding: 10px var(--margin-x, 24px) 0;
    flex-shrink: 0;
  }

  .atlas-legend-sep {
    font-size: 10px;
    color: var(--color-meta, #595959);
    opacity: 0.45;
  }

  .atlas-legend-desc {
    font-size: 10px;
    letter-spacing: 0.03em;
    color: var(--color-meta, #595959);
    font-style: italic;
    margin-left: 6px;
    opacity: 0.7;
  }

  .atlas-legend-item {
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--color-meta, #595959);
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .atlas-legend-item::before {
    content: '';
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .atlas-legend-mode::before   { background: #b8a898; }
  .atlas-legend-type::before   { background: #8a96a8; }
  .atlas-legend-imagery::before { background: #8a9e8a; }

  .atlas-legend-transform {
    font-style: italic;
    color: var(--color-meta, #595959);
  }

  .atlas-legend-transform::before {
    display: none;
  }

  /* ── Canvas ──────────────────────────────────────────────────────────────── */
  .atlas-canvas {
    flex: 1;
    width: 100%;
    display: block;
    touch-action: none;
  }

  /* ── Hint ────────────────────────────────────────────────────────────────── */
  .atlas-hint {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 13px;
    letter-spacing: 0.04em;
    color: var(--color-meta, #595959);
    font-style: italic;
    pointer-events: none;
    text-align: center;
    transition: opacity 0.3s ease;
    white-space: nowrap;
  }

  .atlas-hint.is-hidden {
    opacity: 0;
  }

  /* ── Preview card ────────────────────────────────────────────────────────── */
  .atlas-preview {
    position: absolute;
    bottom: 48px;
    left: 50%;
    transform: translateX(-50%);
    width: min(380px, calc(100vw - 48px));
    background: var(--color-bg, #f5f2ed);
    border: 0.5px solid rgba(26, 26, 26, 0.12);
    padding: 18px 20px 16px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.22s ease, transform 0.22s cubic-bezier(0.16, 1, 0.3, 1);
    transform: translateX(-50%) translateY(6px);
  }

  .atlas-preview.is-visible {
    opacity: 1;
    pointer-events: all;
    transform: translateX(-50%) translateY(0);
  }

  /* preview card internals (set by JS innerHTML) */
  :global(.atlas-preview-tag) {
    display: inline-block;
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--color-meta, #595959);
    margin-bottom: 6px;
  }

  :global(.atlas-preview-tag.tag-mode)    { color: #b8a898; }
  :global(.atlas-preview-tag.tag-type)    { color: #8a96a8; }
  :global(.atlas-preview-tag.tag-imagery) { color: #8a9e8a; }

  :global(.atlas-preview-vol-label) {
    display: block;
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--color-meta, #595959);
    margin-bottom: 4px;
  }

  :global(.atlas-preview-title) {
    margin: 0 0 7px;
    font-size: 19px;
    font-weight: normal;
    letter-spacing: -0.01em;
    color: var(--color-primary, #1a1a1a);
    line-height: 1.25;
  }

  :global(.atlas-preview-firstline) {
    margin: 0 0 10px;
    font-size: 13px;
    line-height: 1.6;
    color: var(--color-meta, #595959);
    font-style: italic;
  }

  :global(.atlas-preview-reason) {
    margin: 0 0 14px;
    font-size: 11.5px;
    letter-spacing: 0.04em;
    color: var(--color-meta, #595959);
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 3px;
  }

  :global(.atlas-reason-tag) {
    font-size: 11px;
    letter-spacing: 0.05em;
    font-style: italic;
  }

  :global(.atlas-reason-sep) {
    font-size: 11px;
    color: var(--color-meta, #595959);
    opacity: 0.5;
  }

  :global(.atlas-preview-active-note) {
    margin: 0 0 10px;
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--color-accent, #c0392b);
    font-style: italic;
  }

  :global(.atlas-preview-inactive-note) {
    margin: 0 0 10px;
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--color-meta, #595959);
    font-style: italic;
    opacity: 0.7;
  }

  :global(.atlas-transform-badge) {
    font-style: italic;
    color: var(--color-accent, #c0392b);
    margin-left: 4px;
  }

  :global(.atlas-preview-cta) {
    display: inline-block;
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--color-primary, #1a1a1a);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 0.15s ease;
  }

  :global(.atlas-preview-cta:hover) {
    opacity: 0.65;
  }

  :global(.atlas-attr-list) {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  :global(.atlas-attr-poem) {
    display: flex;
    align-items: baseline;
    gap: 8px;
    font-size: 12.5px;
    color: var(--color-primary, #1a1a1a);
    text-decoration: none;
    padding: 3px 0;
    border-bottom: 0.5px solid rgba(26,26,26,0.06);
    transition: padding-left 0.15s ease;
  }

  :global(.atlas-attr-poem:last-child) {
    border-bottom: none;
  }

  :global(.atlas-attr-poem:hover) {
    padding-left: 4px;
  }

  :global(.atlas-attr-vol) {
    font-size: 10px;
    letter-spacing: 0.06em;
    color: var(--color-meta, #595959);
    min-width: 16px;
  }
</style>


<script>
  import atlas from '../data/atlas.json';
  import gsap from 'gsap';

  // ─── Constants ────────────────────────────────────────────────────────────
  const WORLD_COLORS: Record<string, { accent: string; soft: string; bg: string }> = {
    'their-world': { accent: '#c0392b', soft: '#e8c8c4', bg: '#f5f2ed' },
    'bless-you':   { accent: '#9b7b8b', soft: '#ddd0d8', bg: '#f2ede4' },
    'still-life':  { accent: '#8a9e8a', soft: '#c8d8c8', bg: '#f8f7f4' },
  };

  const ATTR_COLORS: Record<string, string> = {
    mode:    '#b8a898',
    type:    '#8a96a8',
    imagery: '#8a9e8a',
  };

  const VOL_LABELS: Record<string, string> = {
    'their-world': 'I',
    'bless-you':   'II',
    'still-life':  'III',
  };

  const VOL_FULL: Record<string, string> = {
    'their-world': 'I — Their World',
    'bless-you':   'II — Bless You',
    'still-life':  'III — Still Life',
  };

  // Controlled vocabulary — the full conceptual field of the collection.
  // Active attributes for the current poem are highlighted; everything else
  // is shown at low opacity so the reader sees the poem's position in context.
  const VOCAB: Record<string, string[]> = {
    mode: [
      'solitary_witness', 'child_perception', 'observer', 'fractured_self',
      'addressed_speaker', 'devotional_speaker', 'plural_voice', 'absent_other_address',
    ],
    type: [
      'memory_fragment', 'scene', 'witness', 'monologue', 'confession',
      'lament', 'invocation', 'prayer', 'chant', 'manifesto', 'warning', 'farewell',
    ],
    imagery: [
      'shadow', 'child', 'room', 'house', 'window', 'glass',
      'light', 'eye', 'voice', 'flowers', 'faith', 'sky',
    ],
  };

  const ATTR_FULL: Record<string, string> = {
    mode: 'Speaker mode', type: 'Poem act', imagery: 'Imagery',
  };

  // ─── Types ────────────────────────────────────────────────────────────────
  interface Node {
    kind: 'anchor' | 'attr' | 'satellite';
    x: number; y: number; r: number;
    // anchor + satellite
    id?: string; title?: string; world?: string; order?: number;
    firstLine?: string; url?: string;
    // attr
    attrType?: string; value?: string; active?: boolean;
    // satellite
    attrNodeRef?: Node; visible?: boolean;
    // animation
    alpha: number; delay: number; currentAlpha: number;
  }

  interface Edge {
    from: Node; to: Node;
    color?: string; isSatellite?: boolean;
  }

  // ─── AtlasGraph ───────────────────────────────────────────────────────────
  class AtlasGraph {
    canvas: HTMLCanvasElement;
    ctx: CanvasRenderingContext2D;
    poemId: string;
    worldKey: string;
    poem: any;
    nodes: Node[];
    edges: Edge[];
    selectedNode: Node | null;
    hoveredNode: Node | null;
    tx: number; ty: number; scale: number;
    cx: number; cy: number;
    dpr: number;
    isDragging: boolean;
    dragStart: { x: number; y: number; tx: number; ty: number } | null;
    pinchStart: number | null;
    pinchScale: number;
    pointerDownPos: { x: number; y: number } | null;
    pointerDownTime: number;
    rafId: number;
    isStub: boolean;

    constructor(canvas: HTMLCanvasElement, poemId: string, worldKey: string) {
      this.canvas = canvas;
      this.ctx = canvas.getContext('2d')!;
      this.poemId = poemId;
      this.worldKey = worldKey;
      this.poem = (atlas.poems as any[]).find((p: any) => p.id === poemId) ?? null;
      this.nodes = [];
      this.edges = [];
      this.selectedNode = null;
      this.hoveredNode = null;
      this.tx = 0; this.ty = 0; this.scale = 1;
      this.cx = 0; this.cy = 0;
      this.dpr = window.devicePixelRatio || 1;
      this.isDragging = false;
      this.dragStart = null;
      this.pinchStart = null;
      this.pinchScale = 1;
      this.pointerDownPos = null;
      this.pointerDownTime = 0;
      this.rafId = 0;
      this.isStub = !this.poem?.mode;

      this.resize();
      this.buildGraph();
      this.fitToCanvas();
      this.setupEvents();
      this.startLoop();
    }

    // ── Graph construction ────────────────────────────────────────────────────
    // Architecture: attribute-first.
    //   • All vocabulary attr nodes are always pre-rendered.
    //   • Active attrs (belonging to current poem) are full opacity.
    //   • Inactive attrs are 22% opacity — visible as context, not as clutter.
    //   • Poem (anchor) sits at center as a positional marker.
    //   • Satellite poems appear around an attr node when it is tapped.
    buildGraph() {
      this.nodes = [];
      this.edges = [];
      const poem = this.poem;

      // Current poem's active attribute sets
      const activeSets: Record<string, Set<string>> = {
        mode:    new Set<string>(poem?.mode    || []),
        type:    new Set<string>(poem?.type    || []),
        imagery: new Set<string>(poem?.imagery || []),
      };

      // ── Anchor (current poem) — the positional marker ──────────────────────
      const anchor: Node = {
        kind: 'anchor',
        x: 0, y: 0, r: 26,
        id: poem?.id, title: poem?.title ?? this.poemId,
        world: poem?.world ?? this.worldKey,
        alpha: 1, delay: 0, currentAlpha: 1,
      };
      this.nodes.push(anchor);

      // ── Mode column — left (x = −252) ─────────────────────────────────────
      const modeColX = -252;
      const modeSpacing = 40;
      VOCAB.mode.forEach((value, i) => {
        const y = (i - (VOCAB.mode.length - 1) / 2) * modeSpacing;
        const active = activeSets.mode.has(value);
        const n: Node = {
          kind: 'attr', attrType: 'mode', value,
          x: modeColX, y, r: 7,
          active, alpha: 0, delay: 0.04 + i * 0.045, currentAlpha: 0,
        };
        this.nodes.push(n);
        if (active) this.edges.push({ from: anchor, to: n, color: ATTR_COLORS.mode });
        this.buildSatellites(n, -1, 0);
      });

      // ── Type column — right (x = +258) ────────────────────────────────────
      const typeColX = 258;
      const typeSpacing = 34;
      VOCAB.type.forEach((value, i) => {
        const y = (i - (VOCAB.type.length - 1) / 2) * typeSpacing;
        const active = activeSets.type.has(value);
        const n: Node = {
          kind: 'attr', attrType: 'type', value,
          x: typeColX, y, r: 7,
          active, alpha: 0, delay: 0.06 + i * 0.04, currentAlpha: 0,
        };
        this.nodes.push(n);
        if (active) this.edges.push({ from: anchor, to: n, color: ATTR_COLORS.type });
        this.buildSatellites(n, 1, 0);
      });

      // ── Imagery row — bottom (y = +198) ───────────────────────────────────
      const imageryRowY = 198;
      const imagerySpacing = 46;
      const imageryTotalW = (VOCAB.imagery.length - 1) * imagerySpacing;
      VOCAB.imagery.forEach((value, i) => {
        const x = i * imagerySpacing - imageryTotalW / 2;
        const active = activeSets.imagery.has(value);
        const n: Node = {
          kind: 'attr', attrType: 'imagery', value,
          x, y: imageryRowY, r: 7,
          active, alpha: 0, delay: 0.08 + i * 0.04, currentAlpha: 0,
        };
        this.nodes.push(n);
        if (active) this.edges.push({ from: anchor, to: n, color: ATTR_COLORS.imagery });
        this.buildSatellites(n, 0, 1);
      });
    }

    // Build satellite poem nodes fanning outward from an attr node.
    // dirX/dirY is the unit direction from anchor zone to attr zone (−1/0/1).
    buildSatellites(attrNode: Node, dirX: number, dirY: number) {
      const matches = (atlas.poems as any[])
        .filter((p: any) => {
          if (p.id === this.poemId) return false;
          const arr: string[] = p[attrNode.attrType!] || [];
          return arr.includes(attrNode.value!);
        })
        .slice(0, 5);

      const count = matches.length;
      const fanAngle = Math.PI * 0.5; // 90° spread
      const baseAngle = Math.atan2(dirY, dirX);
      const satDist = 68;

      matches.forEach((p: any, i: number) => {
        const t = count > 1 ? i / (count - 1) : 0.5;
        const angle = baseAngle + (t - 0.5) * fanAngle;
        const sat: Node = {
          kind: 'satellite',
          attrNodeRef: attrNode,
          id: p.id, title: p.title, world: p.world,
          firstLine: p.firstLine, url: p.url,
          x: attrNode.x + Math.cos(angle) * satDist,
          y: attrNode.y + Math.sin(angle) * satDist,
          r: 15, visible: false,
          alpha: 0, delay: i * 0.06, currentAlpha: 0,
        };
        this.nodes.push(sat);
        this.edges.push({
          from: attrNode, to: sat,
          color: ATTR_COLORS[attrNode.attrType!], isSatellite: true,
        });
      });
    }

    // ── Fit the full vocabulary field into the visible canvas on open ─────────
    fitToCanvas() {
      // Layout extents: mode x=−252, type x=258, imagery y=198+label, top ≈−200
      const spanW = 560;  // total horizontal span
      const spanH = 450;  // total vertical span
      const scaleW = (this.cx * 2 * 0.86) / spanW;
      const scaleH = (this.cy * 2 * 0.86) / spanH;
      this.scale = Math.min(scaleW, scaleH, 1.2);
      // Bias ty upward slightly so imagery row has breathing room
      this.ty = -18 * this.scale;
    }

    // ── Layout helpers ────────────────────────────────────────────────────────
    resize() {
      const el = this.canvas.parentElement!;
      const rect = el.getBoundingClientRect();
      const W = rect.width;
      const H = el.clientHeight || rect.height;
      this.canvas.width  = W * this.dpr;
      this.canvas.height = H * this.dpr;
      this.canvas.style.width  = W + 'px';
      this.canvas.style.height = H + 'px';
      this.cx = W / 2;
      this.cy = H / 2;
    }

    // ── Entry animation — runs once on open ───────────────────────────────────
    // Satellites are excluded here; their alpha is managed by selectAttr().
    startLoop() {
      const start = performance.now();
      const totalDur = 1200;
      const tick = (now: number) => {
        const t = Math.min(1, (now - start) / totalDur);
        this.nodes.forEach(n => {
          if (n.kind === 'satellite') return;
          const progress = Math.max(0, Math.min(1, (t - n.delay) / 0.35));
          n.currentAlpha = this.easeOut(progress);
        });
        this.draw();
        if (t < 1) this.rafId = requestAnimationFrame(tick);
      };
      this.rafId = requestAnimationFrame(tick);
    }

    easeOut(t: number) { return 1 - Math.pow(1 - t, 3); }

    // ── Drawing ───────────────────────────────────────────────────────────────
    draw() {
      const ctx = this.ctx;
      const dpr = this.dpr;
      const W = this.canvas.width / dpr;
      const H = this.canvas.height / dpr;
      ctx.save();
      ctx.scale(dpr, dpr);
      ctx.clearRect(0, 0, W, H);
      ctx.translate(this.cx + this.tx, this.cy + this.ty);
      ctx.scale(this.scale, this.scale);
      this.drawZoneLabels();
      this.drawEdges();
      this.drawNodes();
      ctx.restore();
    }

    // Faint column/row labels (MODE / TYPE / IMAGE) for spatial orientation
    drawZoneLabels() {
      const ctx = this.ctx;
      ctx.save();

      const modeTopY  = -(VOCAB.mode.length - 1) / 2 * 40 - 22;
      const typeTopY  = -(VOCAB.type.length - 1) / 2 * 34 - 22;
      const imageryX  = -(VOCAB.imagery.length - 1) * 46 / 2 - 20;

      ctx.font = `10px Georgia, serif`;
      ctx.textBaseline = 'bottom';

      ctx.fillStyle = ATTR_COLORS.mode;
      ctx.globalAlpha = 0.45;
      ctx.textAlign = 'right';
      ctx.fillText('MODE', -252 + 6, modeTopY);

      ctx.fillStyle = ATTR_COLORS.type;
      ctx.textAlign = 'left';
      ctx.fillText('TYPE', 258 - 6, typeTopY);

      ctx.fillStyle = ATTR_COLORS.imagery;
      ctx.textAlign = 'right';
      ctx.textBaseline = 'middle';
      ctx.fillText('IMAGE', imageryX, 198);

      ctx.restore();
    }

    drawEdges() {
      const ctx = this.ctx;
      this.edges.forEach(edge => {
        if (edge.isSatellite) {
          if (!edge.to.visible || (edge.to.currentAlpha ?? 0) <= 0.01) return;
        }
        const fa = edge.from.currentAlpha ?? 0;
        const ta = edge.to.currentAlpha ?? 0;
        const alpha = Math.min(fa, ta);
        if (alpha <= 0.01) return;

        const isSel = this.selectedNode === edge.from || this.selectedNode === edge.to;
        const color = edge.color || '#1a1a1a';

        ctx.save();
        if (edge.isSatellite) {
          ctx.globalAlpha = alpha * 0.4;
          ctx.strokeStyle = color;
          ctx.lineWidth = 0.8;
          ctx.setLineDash([3, 4]);
        } else {
          // Anchor→attr edges: only active attrs; inactive stay unconnected
          if (!edge.to.active) { ctx.restore(); return; }
          ctx.globalAlpha = alpha * (isSel ? 0.55 : 0.2);
          ctx.strokeStyle = color;
          ctx.lineWidth = isSel ? 1.3 : 0.9;
        }
        ctx.beginPath();
        ctx.moveTo(edge.from.x, edge.from.y);
        ctx.lineTo(edge.to.x, edge.to.y);
        ctx.stroke();
        ctx.setLineDash([]);
        ctx.restore();
      });
    }

    drawNodes() {
      // Render order: satellite (deepest) → attr → anchor (topmost)
      (['satellite', 'attr', 'anchor'] as const).forEach(kind => {
        this.nodes.filter(n => n.kind === kind).forEach(n => this.drawNode(n));
      });
    }

    drawNode(node: Node) {
      if (node.kind === 'satellite' && !node.visible) return;
      const alpha = node.currentAlpha ?? 0;
      if (alpha <= 0.01 && node.kind !== 'anchor') return;
      const ctx = this.ctx;
      ctx.save();
      ctx.globalAlpha = Math.max(0, Math.min(1, alpha));
      if (node.kind === 'anchor')    this.drawAnchorNode(node);
      if (node.kind === 'attr')      this.drawAttrNode(node);
      if (node.kind === 'satellite') this.drawSatelliteNode(node);
      ctx.restore();
    }

    drawAnchorNode(node: Node) {
      const ctx = this.ctx;
      const wc = WORLD_COLORS[node.world || this.worldKey] || WORLD_COLORS['their-world'];
      const r = node.r;
      // Outer pulse ring
      ctx.beginPath();
      ctx.arc(node.x, node.y, r + 7, 0, Math.PI * 2);
      ctx.strokeStyle = wc.accent;
      ctx.lineWidth = 1;
      ctx.globalAlpha *= 0.22;
      ctx.stroke();
      ctx.globalAlpha /= 0.22;
      // Fill
      ctx.beginPath();
      ctx.arc(node.x, node.y, r, 0, Math.PI * 2);
      ctx.fillStyle = wc.bg;
      ctx.fill();
      ctx.strokeStyle = wc.accent;
      ctx.lineWidth = 1.8;
      ctx.stroke();
      // Label above
      ctx.font = `italic 10px Georgia, serif`;
      ctx.fillStyle = '#bbb';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'bottom';
      ctx.fillText('current', node.x, node.y - r - 11);
      // Title below
      ctx.font = `15px Georgia, serif`;
      ctx.fillStyle = '#1a1a1a';
      ctx.textBaseline = 'top';
      this.wrapText(node.title || '', node.x, node.y + r + 12, 130, 18);
    }

    drawAttrNode(node: Node) {
      const ctx = this.ctx;
      const color = ATTR_COLORS[node.attrType!] || '#888';
      const isHovered  = this.hoveredNode === node;
      const isSelected = this.selectedNode === node;
      const active     = node.active ?? false;

      // Active: full opacity. Inactive: 22% — present but receded.
      const baseOpacity = active ? 1 : 0.22;
      ctx.globalAlpha *= baseOpacity;

      const r = node.r * (isHovered || isSelected ? 1.75 : 1);

      // Dot
      ctx.beginPath();
      ctx.arc(node.x, node.y, r, 0, Math.PI * 2);
      ctx.fillStyle = isSelected ? '#1a1a1a' : color;
      ctx.fill();

      // Selection ring
      if (isSelected) {
        ctx.beginPath();
        ctx.arc(node.x, node.y, r + 5, 0, Math.PI * 2);
        ctx.strokeStyle = color;
        ctx.lineWidth = 0.9;
        ctx.globalAlpha *= 0.6;
        ctx.stroke();
        ctx.globalAlpha /= 0.6;
      }

      // Label — direction depends on zone
      const gap = r + 11;
      let lx = node.x, ly = node.y;
      let ta: CanvasTextAlign     = 'center';
      let tb: CanvasTextBaseline  = 'middle';

      if (node.attrType === 'mode') {
        lx = node.x - gap; ta = 'right';
      } else if (node.attrType === 'type') {
        lx = node.x + gap; ta = 'left';
      } else {
        // imagery: label below dot
        ly = node.y + gap + 2; tb = 'top';
      }

      const fs = active ? 13 : 11;
      ctx.font = `${active ? '' : 'italic '}${fs}px Georgia, serif`;
      ctx.fillStyle = isSelected ? '#1a1a1a' : active ? '#222' : '#aaa';
      ctx.textAlign = ta;
      ctx.textBaseline = tb;
      ctx.fillText(this.formatLabel(node.value!), lx, ly);

      ctx.globalAlpha /= baseOpacity;
    }

    drawSatelliteNode(node: Node) {
      const ctx = this.ctx;
      const wc = WORLD_COLORS[node.world!] || WORLD_COLORS['their-world'];
      const isSel = this.selectedNode === node;
      const isHov = this.hoveredNode  === node;
      const r = node.r;
      // Circle
      ctx.beginPath();
      ctx.arc(node.x, node.y, r, 0, Math.PI * 2);
      ctx.fillStyle = isSel ? wc.soft : 'rgba(248,246,242,0.95)';
      ctx.fill();
      ctx.strokeStyle = isSel ? wc.accent : wc.soft;
      ctx.lineWidth = isSel ? 1.5 : 1;
      ctx.stroke();
      // Vol label
      ctx.font = `10px Georgia, serif`;
      ctx.fillStyle = wc.accent;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'top';
      ctx.fillText(VOL_LABELS[node.world!] || '', node.x, node.y + r + 6);
      // Title
      const titleFs = isHov || isSel ? 13 : 11.5;
      ctx.font = `${titleFs}px Georgia, serif`;
      ctx.fillStyle = isHov || isSel ? '#1a1a1a' : '#444';
      this.wrapText(node.title || '', node.x, node.y + r + 18, 80, 14);
    }

    // ── Text helpers ──────────────────────────────────────────────────────────
    wrapText(text: string, x: number, y: number, maxW: number, lineH: number) {
      const ctx = this.ctx;
      const words = text.split(' ');
      let line = '', cy = y;
      for (let i = 0; i < words.length; i++) {
        const test = line + words[i] + ' ';
        if (ctx.measureText(test).width > maxW && i > 0) {
          ctx.fillText(line.trim(), x, cy);
          line = words[i] + ' ';
          cy += lineH;
        } else { line = test; }
      }
      ctx.fillText(line.trim(), x, cy);
    }

    formatLabel(val: string) { return val.replace(/_/g, ' '); }

    // ── Hit testing ───────────────────────────────────────────────────────────
    hitTest(px: number, py: number): Node | null {
      const wx = (px - this.cx - this.tx) / this.scale;
      const wy = (py - this.cy - this.ty) / this.scale;
      let best: Node | null = null, bestDist = Infinity;
      for (const n of this.nodes) {
        if (n.kind === 'satellite' && !n.visible) continue;
        const dx = n.x - wx, dy = n.y - wy;
        const dist = Math.sqrt(dx * dx + dy * dy);
        const hitR = n.kind === 'anchor'
          ? n.r + 10
          : n.kind === 'satellite'
            ? Math.max(n.r + 14, 22)
            : Math.max(n.r + 16, 24); // attr nodes get generous hit area
        if (dist < hitR && dist < bestDist) { best = n; bestDist = dist; }
      }
      return best;
    }

    // ── Interaction ───────────────────────────────────────────────────────────
    clearSelection() {
      this.selectedNode = null;
      this.nodes.filter(n => n.kind === 'satellite').forEach(n => {
        n.visible = false;
        n.currentAlpha = 0;
      });
      document.getElementById('atlas-preview')?.classList.remove('is-visible');
      this.updateHint(
        this.isStub
          ? 'tap an attribute to find poems with that quality'
          : 'tap speaker · act · image to explore this poem\'s position'
      );
      this.draw();
    }

    handleTap(px: number, py: number) {
      const hit = this.hitTest(px, py);
      if (!hit) { this.clearSelection(); return; }

      // Second tap on same node
      if (hit === this.selectedNode) {
        if (hit.kind === 'satellite') {
          window.location.href = hit.url || '#';
        } else {
          this.clearSelection();
        }
        return;
      }

      // Hide any active satellites first
      this.nodes.filter(n => n.kind === 'satellite').forEach(n => {
        n.visible = false; n.currentAlpha = 0;
      });
      this.selectedNode = hit;

      if (hit.kind === 'anchor')    { this.showAnchorInfo(); this.draw(); return; }
      if (hit.kind === 'attr')      { this.selectAttr(hit); return; }
      if (hit.kind === 'satellite') { this.showSatellitePreview(hit); this.draw(); return; }
    }

    // Select an attr node: animate its satellite poems in
    selectAttr(node: Node) {
      const sats = this.nodes.filter(n => n.kind === 'satellite' && n.attrNodeRef === node);
      sats.forEach((n, i) => { n.visible = true; n.currentAlpha = 0; n.delay = i * 0.06; });

      const start = performance.now();
      const dur = 420;
      const tick = (now: number) => {
        const t = Math.min(1, (now - start) / dur);
        sats.forEach(n => {
          const p = Math.max(0, Math.min(1, (t - n.delay) / 0.35));
          n.currentAlpha = this.easeOut(p);
        });
        this.draw();
        if (t < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);

      this.showAttrPanel(node);
    }

    showAttrPanel(node: Node) {
      const typeLabel = ATTR_FULL[node.attrType!] || node.attrType!;
      const label = this.formatLabel(node.value!);
      const tagClass = `tag-${node.attrType}`;
      const active = node.active;
      const matches = (atlas.poems as any[])
        .filter((p: any) => {
          const arr: string[] = p[node.attrType!] || [];
          return arr.includes(node.value!) && p.id !== this.poemId;
        })
        .slice(0, 6);

      const preview = document.getElementById('atlas-preview')!;
      preview.innerHTML = `
        <span class="atlas-preview-tag ${tagClass}">${typeLabel}</span>
        <h3 class="atlas-preview-title">${label}</h3>
        ${active
          ? `<p class="atlas-preview-active-note">↳ active in this poem</p>`
          : `<p class="atlas-preview-inactive-note">not in this poem</p>`
        }
        <ul class="atlas-attr-list">
          ${matches.map((p: any) => `
            <li>
              <a href="${p.url}" class="atlas-attr-poem">
                <span class="atlas-attr-vol">${VOL_LABELS[p.world] || ''}</span>
                <span>${p.title}</span>
              </a>
            </li>
          `).join('')}
          ${matches.length === 0
            ? `<li style="font-size:11px;color:#aaa;font-style:italic;padding:4px 0">No other poems mapped yet</li>`
            : ''}
        </ul>
      `;
      preview.classList.add('is-visible');
      this.updateHint(
        matches.length > 0
          ? 'tap a poem node to preview · tap again to read'
          : 'drag · scroll to zoom · tap another attribute'
      );
    }

    showAnchorInfo() {
      const poem = this.poem;
      const preview = document.getElementById('atlas-preview')!;
      if (!poem?.mode) {
        preview.innerHTML = `
          <h3 class="atlas-preview-title">${poem?.title ?? this.poemId}</h3>
          <p class="atlas-preview-inactive-note">
            This poem's position in the atlas has not yet been mapped.<br>
            Tap any attribute node to find poems that share that quality.
          </p>
        `;
        preview.classList.add('is-visible');
        this.updateHint('tap the attribute nodes to explore the collection');
        return;
      }
      const modeList    = (poem.mode    || []).map((v: string) => this.formatLabel(v)).join(', ');
      const typeList    = (poem.type    || []).map((v: string) => this.formatLabel(v)).join(', ');
      const imageryList = (poem.imagery || []).map((v: string) => this.formatLabel(v)).join(', ');
      preview.innerHTML = `
        <h3 class="atlas-preview-title">${poem.title}</h3>
        ${modeList    ? `<p class="atlas-preview-reason"><span style="color:${ATTR_COLORS.mode};font-style:italic">speaker</span> &thinsp;${modeList}</p>`    : ''}
        ${typeList    ? `<p class="atlas-preview-reason"><span style="color:${ATTR_COLORS.type};font-style:italic">act</span> &thinsp;${typeList}</p>`    : ''}
        ${imageryList ? `<p class="atlas-preview-reason"><span style="color:${ATTR_COLORS.imagery};font-style:italic">image</span> &thinsp;${imageryList}</p>` : ''}
        <p style="font-size:11px;color:#aaa;font-style:italic;margin-top:8px">
          tap an attribute node to see related poems
        </p>
      `;
      preview.classList.add('is-visible');
      this.updateHint('tap speaker · act · image to explore');
    }

    showSatellitePreview(node: Node) {
      const parent = node.attrNodeRef;
      const parentLabel = parent ? this.formatLabel(parent.value!) : '';
      const parentColor = parent ? (ATTR_COLORS[parent.attrType!] || '#888') : '#888';
      const preview = document.getElementById('atlas-preview')!;
      preview.innerHTML = `
        <span class="atlas-preview-vol-label">${VOL_FULL[node.world!] || node.world}</span>
        <h3 class="atlas-preview-title">${node.title}</h3>
        ${node.firstLine ? `<p class="atlas-preview-firstline">"${node.firstLine}"</p>` : ''}
        <p class="atlas-preview-reason">
          <span style="color:${parentColor};font-style:italic">${parentLabel}</span>
        </p>
        <a href="${node.url || '#'}" class="atlas-preview-cta">Read this poem →</a>
      `;
      preview.classList.add('is-visible');
      this.updateHint('tap again to navigate to this poem');
    }

    updateHint(text: string) {
      const el = document.getElementById('atlas-hint');
      if (el) el.textContent = text;
    }

    // ── Events ────────────────────────────────────────────────────────────────
    setupEvents() {
      const canvas = this.canvas;

      canvas.addEventListener('pointermove', (e: PointerEvent) => {
        if (this.isDragging && this.dragStart) {
          this.tx = this.dragStart.tx + (e.clientX - this.dragStart.x);
          this.ty = this.dragStart.ty + (e.clientY - this.dragStart.y);
          this.draw(); return;
        }
        const rect = canvas.getBoundingClientRect();
        const hit = this.hitTest(e.clientX - rect.left, e.clientY - rect.top);
        if (hit !== this.hoveredNode) {
          this.hoveredNode = hit;
          canvas.style.cursor = hit ? 'pointer' : 'grab';
          this.draw();
        }
      });

      canvas.addEventListener('pointerdown', (e: PointerEvent) => {
        canvas.setPointerCapture(e.pointerId);
        this.pointerDownPos  = { x: e.clientX, y: e.clientY };
        this.pointerDownTime = Date.now();
        this.dragStart = { x: e.clientX, y: e.clientY, tx: this.tx, ty: this.ty };
        canvas.style.cursor = 'grabbing';
      });

      canvas.addEventListener('pointerup', (e: PointerEvent) => {
        if (!this.pointerDownPos) return;
        const elapsed = Date.now() - this.pointerDownTime;
        const dx = e.clientX - this.pointerDownPos.x;
        const dy = e.clientY - this.pointerDownPos.y;
        if (elapsed < 350 && Math.sqrt(dx * dx + dy * dy) < 12) {
          const rect = canvas.getBoundingClientRect();
          this.handleTap(e.clientX - rect.left, e.clientY - rect.top);
        }
        this.isDragging = false;
        this.dragStart  = null;
        this.pointerDownPos = null;
        canvas.style.cursor = this.hoveredNode ? 'pointer' : 'grab';
        this.draw();
      });

      // Drag detection
      canvas.addEventListener('pointermove', (e: PointerEvent) => {
        if (!this.pointerDownPos || this.isDragging) return;
        const dx = e.clientX - this.pointerDownPos.x;
        const dy = e.clientY - this.pointerDownPos.y;
        if (Math.sqrt(dx * dx + dy * dy) > 8) this.isDragging = true;
      });

      // Wheel zoom
      canvas.addEventListener('wheel', (e: WheelEvent) => {
        e.preventDefault();
        this.scale = Math.max(0.3, Math.min(3.5, this.scale * (e.deltaY > 0 ? 0.9 : 1.1)));
        this.draw();
      }, { passive: false });

      // Pinch zoom
      const getPinchDist = (e: TouchEvent) => {
        const dx = e.touches[0].clientX - e.touches[1].clientX;
        const dy = e.touches[0].clientY - e.touches[1].clientY;
        return Math.sqrt(dx * dx + dy * dy);
      };
      canvas.addEventListener('touchstart', (e: TouchEvent) => {
        if (e.touches.length === 2) { this.pinchStart = getPinchDist(e); this.pinchScale = this.scale; }
      }, { passive: true });
      canvas.addEventListener('touchmove', (e: TouchEvent) => {
        if (e.touches.length === 2 && this.pinchStart !== null) {
          this.scale = Math.max(0.3, Math.min(3.5, this.pinchScale * (getPinchDist(e) / this.pinchStart)));
          this.draw(); e.preventDefault();
        }
      }, { passive: false });
      canvas.addEventListener('touchend', () => { this.pinchStart = null; });

      window.addEventListener('resize', () => { this.resize(); this.fitToCanvas(); this.draw(); });
    }

    destroy() { cancelAnimationFrame(this.rafId); }
  }

  // ─── Overlay lifecycle ────────────────────────────────────────────────────
  let graph: AtlasGraph | null = null;
  const overlay  = document.getElementById('atlas-overlay')!;
  const trigger  = document.getElementById('atlas-trigger')!;
  const closeBtn = document.getElementById('atlas-close')!;
  const canvas   = document.getElementById('atlas-canvas') as HTMLCanvasElement;
  const poemId   = (overlay as HTMLElement).dataset.poemId!;
  const worldKey = (overlay as HTMLElement).dataset.world!;
  let savedScroll = 0;

  function openAtlas() {
    savedScroll = window.scrollY;
    overlay.setAttribute('aria-hidden', 'false');
    overlay.classList.add('is-open');
    gsap.fromTo(overlay,
      { opacity: 0, y: 8 },
      { opacity: 1, y: 0, duration: 0.32, ease: 'power2.out' }
    );
    if (graph) graph.destroy();
    graph = new AtlasGraph(canvas, poemId, worldKey);
    document.getElementById('atlas-hint')!.textContent = graph.isStub
      ? 'tap any attribute to find poems with that quality — this poem\'s position is not yet mapped'
      : 'highlighted attributes belong to this poem — tap one to explore the field';
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }

  function closeAtlas() {
    gsap.to(overlay, {
      opacity: 0, y: 6, duration: 0.22, ease: 'power2.in',
      onComplete: () => {
        overlay.classList.remove('is-open');
        overlay.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        window.scrollTo({ top: savedScroll, behavior: 'instant' });
        trigger.focus();
      },
    });
  }

  trigger.addEventListener('click', openAtlas);
  closeBtn.addEventListener('click', closeAtlas);

  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape' && overlay.classList.contains('is-open')) closeAtlas();
  });

  overlay.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key !== 'Tab') return;
    const focusable = overlay.querySelectorAll<HTMLElement>('button, a, [tabindex="0"]');
    const first = focusable[0], last = focusable[focusable.length - 1];
    if (e.shiftKey) {
      if (document.activeElement === first) { e.preventDefault(); last.focus(); }
    } else {
      if (document.activeElement === last)  { e.preventDefault(); first.focus(); }
    }
  });
</script>
