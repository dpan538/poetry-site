  function addValues(target: Set<string>, values: string[]) {
    values.forEach((value) => target.add(value));
  }

  function inferAtlasValues(poem: any): Record<string, Set<string>> {
    const contentTypes = poemContentTypes[poem?.id as keyof typeof poemContentTypes] ?? [];
    const values: Record<string, Set<string>> = {
      mode: new Set<string>(poem?.mode || []),
      type: new Set<string>(poem?.type || []),
      imagery: new Set<string>(poem?.imagery || []),
      pressure: new Set<string>(poem?.pressure || []),
      form: new Set<string>(poem?.form || []),
      sense: new Set<string>(poem?.sense || []),
    };

    contentTypes.forEach((type) => values.form.add(type));

    if (contentTypes.includes('narrative')) {
      addValues(values.type, ['memory_fragment', 'scene']);
      addValues(values.pressure, ['memory_pressure', 'time_pressure']);
      addValues(values.mode, ['threshold_speaker']);
      values.sense.add('motion');
    }
    if (contentTypes.includes('observation')) {
      values.type.add('witness');
      values.mode.add('observer');
      values.sense.add('visual');
    }
    if (contentTypes.includes('incantatory')) {
      addValues(values.type, ['chant', 'invocation']);
      addValues(values.form, ['ritual_repetition']);
      values.sense.add('auditory');
    }
    if (contentTypes.includes('political')) {
      addValues(values.type, ['manifesto', 'warning']);
      addValues(values.pressure, ['institutional_pressure', 'public_noise']);
      values.mode.add('public_voice');
    }
    if (contentTypes.includes('spiritual')) {
      addValues(values.type, ['prayer', 'invocation']);
      values.pressure.add('belief_pressure');
      values.mode.add('devotional_speaker');
    }
    if (contentTypes.includes('fragmented')) {
      values.mode.add('fractured_self');
      values.form.add('fragmented');
      values.type.add('meditation');
    }
    if (contentTypes.includes('love')) {
      addValues(values.mode, ['addressed_speaker', 'absent_other']);
      values.pressure.add('intimacy_pressure');
      values.type.add('letter');
    }

    return values;
  }

  // ─── Types ────────────────────────────────────────────────────────────────
  interface Node {
    kind: 'anchor' | 'attr';
    x: number; y: number; r: number;
    vx: number; vy: number;
    homeX: number; homeY: number;
    // anchor
    id?: string; title?: string; world?: string;
    // attr
    attrType?: string; value?: string; active?: boolean;
    // animation
    delay: number; currentAlpha: number;
  }

  interface Edge { from: Node; to: Node; color: string; role?: 'poem' | 'cross'; }

  // ─── AtlasGraph ───────────────────────────────────────────────────────────
  class AtlasGraph {
    canvas: HTMLCanvasElement;
    ctx: CanvasRenderingContext2D;
    poemId: string; worldKey: string; poem: any;
    nodes: Node[]; edges: Edge[];
    selectedNode: Node | null; hoveredNode: Node | null;
    tx: number; ty: number; scale: number;
    fitTx: number; fitTy: number; fitScale: number;
    cx: number; cy: number; dpr: number;
    isDragging: boolean;
    dragStart: { x: number; y: number; tx: number; ty: number } | null;
    pinchStart: number | null; pinchScale: number;
    pointerDownPos: { x: number; y: number } | null; pointerDownTime: number;
    rafId: number; isStub: boolean;
    pulseStart: number;
    primaryColor: string; metaColor: string;

    constructor(canvas: HTMLCanvasElement, poemId: string, worldKey: string) {
      this.canvas = canvas;
      this.ctx = canvas.getContext('2d')!;
      this.poemId = poemId; this.worldKey = worldKey;
      this.poem = (atlas.poems as any[]).find((p: any) => p.id === poemId) ?? null;
      this.nodes = []; this.edges = [];
      this.selectedNode = null; this.hoveredNode = null;
      this.tx = 0; this.ty = 0; this.scale = 1;
      this.fitTx = 0; this.fitTy = 0; this.fitScale = 1;
      this.cx = 0; this.cy = 0; this.dpr = window.devicePixelRatio || 1;
      this.isDragging = false; this.dragStart = null;
      this.pinchStart = null; this.pinchScale = 1;
      this.pointerDownPos = null; this.pointerDownTime = 0;
      this.rafId = 0; this.isStub = !this.poem?.mode;
      this.pulseStart = 0;
      this.primaryColor = '#1a1a1a';
      this.metaColor = '#4f4f4f';

      this.resize();
      this.readThemeColors();
      this.buildGraph();
      this.primeLayout(820); // settle positions synchronously — no visible motion
      this.fitToCanvas();
      this.setupEvents();
      this.startLoop();
    }

    // ── Deterministic hash ────────────────────────────────────────────────────
    hashStr(s: string): number {
      let h = 0;
      for (let i = 0; i < s.length; i++) h = (Math.imul(31, h) + s.charCodeAt(i)) | 0;
      return (h >>> 0) / 4294967296;
    }

    readThemeColors() {
      const styles = getComputedStyle(document.documentElement);
      const p = styles.getPropertyValue('--color-primary').trim();
      const m = styles.getPropertyValue('--color-meta').trim();
      if (p) this.primaryColor = p;
      if (m) this.metaColor = m;
    }

    // ── Zone home position ────────────────────────────────────────────────────
    computeHome(attrType: string, value: string, active: boolean): { x: number; y: number } {
      const z = ZONES[attrType] || { cx: 0, cy: 0, sx: 80, sy: 80 };
      const vocab = VOCAB[attrType] || [];
      const n = Math.max(vocab.length, 1);
      const idx = Math.max(0, vocab.indexOf(value));
      // Golden-angle distribution gives a much more even, deterministic spread than hash XY.
      const GOLDEN_ANGLE = 2.399963229728653;
      const angleSeed = this.hashStr(`${attrType}_angle_seed`) * Math.PI * 2;
      const angle = angleSeed + idx * GOLDEN_ANGLE;
      const ring = Math.sqrt((idx + 0.5) / n);
      const rJitter = 0.92 + this.hashStr(value + '_r') * 0.16;
      const rawX = z.cx + Math.cos(angle) * z.sx * ring * rJitter;
      const rawY = z.cy + Math.sin(angle) * z.sy * ring * rJitter;
      if (active) return { x: rawX * (1 - ACTIVE_PULL), y: rawY * (1 - ACTIVE_PULL) };
      return { x: rawX, y: rawY };
    }

    displayValues(attrType: string, activeSet: Set<string>): string[] {
      const vocab = VOCAB[attrType] || [];
      const active = vocab.filter((value) => activeSet.has(value));
      const limit = DISPLAY_LIMITS[attrType] ?? vocab.length;
      const context = vocab
        .filter((value) => !activeSet.has(value))
        .sort((a, b) => this.hashStr(`${this.poemId}:${attrType}:${a}`) - this.hashStr(`${this.poemId}:${attrType}:${b}`))
        .slice(0, Math.max(0, limit - active.length));
      return [...active, ...context];
    }

    // ── Graph construction ─────────────────────────────────────────────────────
    buildGraph() {
      this.nodes = []; this.edges = [];
      const poem = this.poem;
      const activeSets = inferAtlasValues(poem);

      // Anchor at origin
      const anchor: Node = {
        kind: 'anchor', x: 0, y: 0, r: 18, vx: 0, vy: 0, homeX: 0, homeY: 0,
        id: poem?.id, title: poem?.title ?? this.poemId,
        world: poem?.world ?? this.worldKey,
        delay: 0, currentAlpha: 1,
      };
      this.nodes.push(anchor);

      const activeAttrNodes: Node[] = [];

      // Attr nodes are concrete feature nodes; category names stay in cards/legend.
      CATEGORY_KEYS.forEach(attrType => {
        this.displayValues(attrType, activeSets[attrType]).forEach((value, i) => {
          const active = activeSets[attrType].has(value);
          const home = this.computeHome(attrType, value, active);
          const jx = (this.hashStr(value + '_jx') - 0.5) * 8;
          const jy = (this.hashStr(value + '_jy') - 0.5) * 8;
          const n: Node = {
            kind: 'attr', attrType, value,
            x: home.x + jx, y: home.y + jy,
            vx: 0, vy: 0, homeX: home.x, homeY: home.y,
            r: active ? 10 : 5, active,
            delay: 0.04 + i * 0.042, currentAlpha: 0,
          };
          this.nodes.push(n);
          if (active) {
            activeAttrNodes.push(n);
          }
        });
      });

      this.selectPoemEdgeNodes(activeAttrNodes).forEach((node) => {
        this.edges.push({ from: anchor, to: node, color: ATTR_COLORS[node.attrType!], role: 'poem' });
      });

      // A few cross-field links make the map read like parallel triggers:
      // relation appears between active fields, while the poem remains context.
      const linkPairs: Array<[string, string]> = [
        ['mode', 'type'],
        ['type', 'pressure'],
        ['pressure', 'imagery'],
        ['imagery', 'sense'],
        ['form', 'type'],
      ];
      const crossDegree = new Map<Node, number>();
      linkPairs.forEach(([a, b]) => {
        const from = activeAttrNodes.find((n) => n.attrType === a);
        const to = activeAttrNodes.find((n) => n.attrType === b);
        if (!from || !to) return;
        const fromDegree = crossDegree.get(from) ?? 0;
        const toDegree = crossDegree.get(to) ?? 0;
        if (fromDegree >= 2 || toDegree >= 2) return;
        crossDegree.set(from, fromDegree + 1);
        crossDegree.set(to, toDegree + 1);
        this.edges.push({ from, to, color: this.metaColor, role: 'cross' });
      });
    }

    selectPoemEdgeNodes(nodes: Node[]): Node[] {
      const representatives = CATEGORY_KEYS
        .map((key) => {
          const candidates = nodes.filter((node) => node.attrType === key);
          if (!candidates.length) return null;
          return candidates
            .slice()
            .sort((a, b) => {
              const da = Math.hypot(a.x, a.y);
              const db = Math.hypot(b.x, b.y);
              return db - da;
            })[0];
        })
        .filter(Boolean) as Node[];

      const selected: Node[] = [];
      const minAngle = 0.34;
      representatives
        .slice()
        .sort((a, b) => Math.hypot(b.x, b.y) - Math.hypot(a.x, a.y))
        .forEach((node) => {
          const angle = Math.atan2(node.y, node.x);
          const crowded = selected.some((other) => {
            const delta = Math.abs(Math.atan2(Math.sin(angle - Math.atan2(other.y, other.x)), Math.cos(angle - Math.atan2(other.y, other.x))));
            return delta < minAngle;
          });
          if (!crowded || selected.length < 3) selected.push(node);
        });

      return selected.slice(0, 5);
    }

    // ── Force simulation (used only by primeLayout — not called during render) ─
    simulateStep() {
      // Softer zone pull lets repulsion spread nodes freely across the larger zones.
      // Higher REPEL_K and larger minD reduce label overlap, especially in dense clusters.
      const ZONE_K = 0.026, ANCHOR_K = 0.001, REPEL_K = 2.7, DAMPING = 0.72;
      const attrNodes = this.nodes.filter(n => n.kind === 'attr');
      attrNodes.forEach(n => {
        n.vx += (n.homeX - n.x) * ZONE_K;
        n.vy += (n.homeY - n.y) * ZONE_K;
        if (n.active) {
          n.vx += (0 - n.x) * ANCHOR_K;
          n.vy += (0 - n.y) * ANCHOR_K;
        }
        const allVis = this.nodes;
        allVis.forEach(other => {
          if (other === n) return;
          const dx = n.x - other.x, dy = n.y - other.y;
          const dist = Math.sqrt(dx * dx + dy * dy) || 0.1;
          // More conservative minimum gap between dot surfaces for label breathing room.
          const labelA = n.kind === 'attr' ? this.labelFootprint(n) : n.r + 82;
          const labelB = other.kind === 'attr' ? this.labelFootprint(other) : other.r + 82;
          const baseGap = Math.max(n.r + other.r + 158, (labelA + labelB) * 0.62);
          // Same-category nodes tend to sit near each other; push them a bit farther apart.
          const typeBoost = n.kind === 'attr' && other.kind === 'attr' && n.attrType === other.attrType ? 46 : 0;
          const minD = baseGap + typeBoost;
          if (dist < minD) {
            const f = REPEL_K * (minD - dist) / dist;
            n.vx += dx * f; n.vy += dy * f;
          }
        });
        n.vx *= DAMPING; n.vy *= DAMPING;
        n.x += n.vx; n.y += n.vy;
      });
    }

    labelFootprint(n: Node): number {
      if (n.kind !== 'attr') return n.r + 82;
      const labelLen = this.formatLabel(n.value || '').length;
      const textSize = n.active ? 29 : 22;
      return n.r + 56 + Math.min(300, labelLen * textSize * 0.48);
    }

    // Settle layout synchronously before first draw — more steps for larger zones
    primeLayout(steps = 800) {
      for (let i = 0; i < steps; i++) this.simulateStep();
    }

    // ── Fit canvas ────────────────────────────────────────────────────────────
    fitToCanvas() {
      // Auto-fit to actual settled node positions.
      // We reserve a larger bottom safe area so the annotation panel never covers nodes.
      const xs = this.nodes.map(n => n.x);
      const ys = this.nodes.map(n => n.y);
      const minX = Math.min(...xs), maxX = Math.max(...xs);
      const minY = Math.min(...ys), maxY = Math.max(...ys);
      const labelPadX = 72;
      const topSafe = 34;
      const bottomSafe = 72;

      const contentW = (maxX - minX) + labelPadX * 2;
      const contentH = (maxY - minY) + topSafe + bottomSafe;
      const usableW = Math.max(this.cx * 2, 1);
      const usableH = Math.max(this.cy * 2, 1);
      const scaleW = usableW / contentW;
      const scaleH = usableH / contentH;
      this.scale = Math.min(scaleW, scaleH, 1.82);

      // Place content inside asymmetric top/bottom paddings (centered in remaining space).
      const freeW = Math.max(0, usableW - (labelPadX * 2 + (maxX - minX)) * this.scale);
      const freeH = Math.max(0, usableH - (topSafe + bottomSafe + (maxY - minY)) * this.scale);
      const padLeft = labelPadX * this.scale + freeW / 2;
      const padTop = topSafe * this.scale + freeH / 2;

      this.tx = padLeft - this.cx - minX * this.scale;
      this.ty = padTop - this.cy - minY * this.scale;
      this.fitScale = this.scale;
      this.fitTx = this.tx;
      this.fitTy = this.ty;
    }

    resize() {
      // Clear any stale explicit dimensions so CSS/flex controls display size
      this.canvas.style.width = '';
      this.canvas.style.height = '';
      // Measure the canvas's OWN CSS display rect (flex-determined, not the overlay's)
      // getBoundingClientRect() forces synchronous reflow — returns post-flex size
      const rect = this.canvas.getBoundingClientRect();
      const W = Math.max(rect.width,  1);
      const H = Math.max(rect.height, 1);
      // Set pixel dimensions to match CSS display size (×dpr for sharpness)
      this.canvas.width  = W * this.dpr;
      this.canvas.height = H * this.dpr;
      this.cx = W / 2; this.cy = H / 2;
    }

    // ── Entry animation — alpha fade in only, no position movement ────────────
    startLoop() {
      if (this.rafId) cancelAnimationFrame(this.rafId);
      const start = performance.now();
      const dur = 900;
      const tick = (now: number) => {
        const t = Math.min(1, (now - start) / dur);
        this.nodes.forEach(n => {
          if (n.kind === 'anchor') return;
          const p = Math.max(0, Math.min(1, (t - n.delay) / 0.35));
          n.currentAlpha = this.easeOut(p);
        });
        this.draw();
        if (t < 1) {
          this.rafId = requestAnimationFrame(tick);
        } else {
          this.rafId = 0;
        }
      };
      this.rafId = requestAnimationFrame(tick);
    }

    easeOut(t: number) { return 1 - Math.pow(1 - t, 3); }

    animateFor(ms = 460) {
      const started = performance.now();
      const tick = (now: number) => {
        this.draw();
        if (now - started < ms) {
          this.rafId = requestAnimationFrame(tick);
        } else {
          this.rafId = 0;
          this.draw();
        }
      };
      if (!this.rafId) this.rafId = requestAnimationFrame(tick);
    }

    // ── Drawing ───────────────────────────────────────────────────────────────
    draw() {
      const ctx = this.ctx, dpr = this.dpr;
      const W = this.canvas.width / dpr, H = this.canvas.height / dpr;
      ctx.save();
      ctx.scale(dpr, dpr);
      ctx.clearRect(0, 0, W, H);
      ctx.translate(this.cx + this.tx, this.cy + this.ty);
      ctx.scale(this.scale, this.scale);
      this.drawEdges();
      this.drawNodes();
      ctx.restore();
    }

    // Edges: anchor → active attr only
    drawEdges() {
      const ctx = this.ctx;
      this.edges.forEach(edge => {
        const alpha = edge.to.currentAlpha ?? 0;
        if (alpha < 0.02) return;
        const isSel = this.selectedNode === edge.to || this.selectedNode === edge.from;
        const roleOpacity: Record<string, number> = {
          poem: 0.38,
          cross: 0.68,
        };
        const roleWidth: Record<string, number> = {
          poem: 1.05,
          cross: 1.65,
        };
        ctx.save();
        ctx.globalAlpha = alpha * (isSel ? 0.88 : roleOpacity[edge.role || 'poem']);
        ctx.strokeStyle = edge.color;
        ctx.lineWidth = isSel ? 1.9 : roleWidth[edge.role || 'poem'];
        if (edge.role === 'poem') ctx.setLineDash([4, 8]);
        ctx.beginPath();
        ctx.moveTo(edge.from.x, edge.from.y);
        ctx.lineTo(edge.to.x, edge.to.y);
        ctx.stroke();
        ctx.setLineDash([]);
        ctx.restore();
      });
    }

    drawNodes() {
      // Draw attr nodes first (below anchor)
      this.nodes.filter(n => n.kind === 'attr').forEach(n => this.drawNode(n));
      this.nodes.filter(n => n.kind === 'anchor').forEach(n => this.drawNode(n));
    }

    drawNode(n: Node) {
      const alpha = n.currentAlpha ?? 0;
      if (alpha < 0.02 && n.kind !== 'anchor') return;
      const ctx = this.ctx;
      ctx.save();
      ctx.globalAlpha = Math.max(0, Math.min(1, alpha));
      if (n.kind === 'anchor') this.drawAnchorNode(n);
      if (n.kind === 'attr')   this.drawAttrNode(n);
      ctx.restore();
    }

    drawAnchorNode(n: Node) {
      const ctx = this.ctx;
      const wc = WORLD_COLORS[n.world || this.worldKey] || WORLD_COLORS['their-world'];
      const isSel = this.selectedNode === n;
      const pulse = isSel ? this.selectionPulse() : 0;
      const r = n.r * (isSel ? 1.16 + pulse * 0.08 : 1);
      // Faint outer halo
      ctx.beginPath(); ctx.arc(0, 0, r + 12, 0, Math.PI * 2);
      ctx.strokeStyle = wc.accent; ctx.lineWidth = 1.15;
      ctx.globalAlpha *= isSel ? 0.46 : 0.28; ctx.stroke(); ctx.globalAlpha /= isSel ? 0.46 : 0.28;
      // Soft fill
      ctx.beginPath(); ctx.arc(0, 0, r, 0, Math.PI * 2);
      ctx.fillStyle = wc.soft;
      ctx.globalAlpha *= isSel ? 0.5 : 0.36; ctx.fill(); ctx.globalAlpha /= isSel ? 0.5 : 0.36;
      // Border
      ctx.beginPath(); ctx.arc(0, 0, r, 0, Math.PI * 2);
      ctx.strokeStyle = wc.accent; ctx.lineWidth = isSel ? 2.6 : 2.1; ctx.stroke();
      if (pulse > 0) {
        ctx.beginPath(); ctx.arc(0, 0, r + 16 + pulse * 12, 0, Math.PI * 2);
        ctx.strokeStyle = wc.accent; ctx.lineWidth = 1.0;
        ctx.globalAlpha *= 0.2 * pulse; ctx.stroke(); ctx.globalAlpha /= 0.2 * pulse;
      }
      // Title below — larger, comfortable to read
      ctx.font = '36px Georgia, serif'; ctx.fillStyle = this.primaryColor;
      ctx.textAlign = 'center'; ctx.textBaseline = 'top';
      this.wrapText(n.title || '', 0, r + 16, 310, 40);
    }

    drawAttrNode(n: Node) {
      const ctx = this.ctx;
      const color = ATTR_COLORS[n.attrType!] || '#888';
      const isSel = this.selectedNode === n;
      const active = n.active ?? false;

      // Active nodes: full presence.
      // Inactive: clearly subordinate but still legible — not faint, just smaller and muted.
      const baseOpacity = active ? 1 : 0.88;
      ctx.globalAlpha *= baseOpacity;

      const pulse = isSel ? this.selectionPulse() : 0;
      const baseR = active ? 10 : 5;
      const r = baseR * (isSel ? 1.24 + pulse * 0.1 : 1);

      // Soft aura for active nodes
      if (active && !isSel) {
        ctx.beginPath(); ctx.arc(n.x, n.y, r + 12, 0, Math.PI * 2);
        ctx.fillStyle = color; ctx.globalAlpha *= 0.26; ctx.fill(); ctx.globalAlpha /= 0.26;
      }

      // Dot
      ctx.beginPath(); ctx.arc(n.x, n.y, r, 0, Math.PI * 2);
      ctx.fillStyle = isSel ? '#1a1a1a' : color; ctx.fill();

      // Selection ring
      if (isSel) {
        ctx.beginPath(); ctx.arc(n.x, n.y, r + 6, 0, Math.PI * 2);
        ctx.strokeStyle = color; ctx.lineWidth = 1.25;
        ctx.globalAlpha *= 0.72; ctx.stroke(); ctx.globalAlpha /= 0.72;
        if (pulse > 0) {
          ctx.beginPath(); ctx.arc(n.x, n.y, r + 12 + pulse * 10, 0, Math.PI * 2);
          ctx.strokeStyle = color; ctx.lineWidth = 0.9;
          ctx.globalAlpha *= 0.18 * pulse; ctx.stroke(); ctx.globalAlpha /= 0.18 * pulse;
        }
      }

      // Label — radially outward from anchor, larger and more readable
      const angle = Math.atan2(n.y, n.x);
      const deg = angle * 180 / Math.PI;
      const gap = r + 14; // generous gap between dot and label start
      let lx = n.x, ly = n.y;
      let ta: CanvasTextAlign = 'center', tb: CanvasTextBaseline = 'middle';

      if (deg > -70 && deg < 70)          { lx = n.x + gap; ta = 'left'; }
      else if (deg > 110 || deg < -110)   { lx = n.x - gap; ta = 'right'; }
      else if (deg >= 70 && deg <= 110)   { ly = n.y + gap + 2; tb = 'top'; ta = 'center'; }
      else                                { ly = n.y - gap - 2; tb = 'bottom'; ta = 'center'; }

      // Active labels are close to the main reading scale; inactive labels stay legible.
      const fs = active ? 29 : 22;
      ctx.font = `${active ? '' : 'italic '}${fs}px Georgia, serif`;
      // WCAG 1.4.3: dot drawn at baseOpacity (0.58 for inactive) but text needs higher opacity.
      // #5a5452 at 58% → 2.62:1 ❌. At 88% → 4.98:1 ✅. Save/restore alpha around text only.
      const preTextAlpha = ctx.globalAlpha;
      if (!active) {
        // Raise text opacity: divide out baseOpacity, keep near-full fade alpha for readability.
        ctx.globalAlpha = (preTextAlpha / baseOpacity) * 0.98;
      }
      ctx.fillStyle = isSel ? '#0a0a0a' : active ? this.primaryColor : this.metaColor;
      ctx.textAlign = ta; ctx.textBaseline = tb;
      ctx.fillText(this.formatLabel(n.value!), lx, ly);
      ctx.globalAlpha = preTextAlpha; // restore dot opacity for correct restore at end

      ctx.globalAlpha /= baseOpacity;
    }

    // ── Text helpers ──────────────────────────────────────────────────────────
    selectionPulse(): number {
      if (!this.pulseStart) return 0;
      const t = Math.min(1, (performance.now() - this.pulseStart) / 460);
      return Math.sin(t * Math.PI) * (1 - t * 0.28);
    }

    wrapText(text: string, x: number, y: number, maxW: number, lineH: number) {
      const ctx = this.ctx, words = text.split(' ');
      let line = '', cy = y;
      for (let i = 0; i < words.length; i++) {
        const test = line + words[i] + ' ';
        if (ctx.measureText(test).width > maxW && i > 0) {
          ctx.fillText(line.trim(), x, cy); line = words[i] + ' '; cy += lineH;
        } else line = test;
      }
      ctx.fillText(line.trim(), x, cy);
    }

    formatLabel(val: string) { return val.replace(/_/g, ' '); }

    sentenceList(values: string[]): string {
      if (values.length <= 1) return values[0] || '';
      if (values.length === 2) return `${values[0]} and ${values[1]}`;
      return `${values.slice(0, -1).join(', ')}, and ${values[values.length - 1]}`;
    }

    featurePhrase(active: Record<string, Set<string>>, keys: string[], maxPerKey = 4): string {
      return keys
        .flatMap((key) => [...active[key]].slice(0, maxPerKey).map((value) => this.formatLabel(value)))
        .filter(Boolean)
        .join(', ');
    }

    // Show attribute annotation panel (no poem lists — pure definition)
    showAttrAnnotation(n: Node) {
      const label = this.formatLabel(n.value!);
      const catLabel = ATTR_LABELS[n.attrType!] || n.attrType!;
      const description = ATTR_DESCRIPTIONS[n.value!] || '';
      const annoEl = document.getElementById('atlas-anno')!;
      annoEl.innerHTML = `
        <div class="atlas-anno-header">
          <span class="atlas-anno-cat tag-${n.attrType}">${catLabel}</span>
          <h3 class="atlas-anno-name">${label}</h3>
        </div>
        ${description ? `<p class="atlas-anno-def">${description}</p>` : ''}
      `;
      annoEl.classList.add('is-open');
      if (!this.rafId) this.draw();
    }

    showPoemAnnotation(n: Node) {
      const poem = this.poem;
      const active = inferAtlasValues(poem);
      const voice = this.featurePhrase(active, ['mode']);
      const actForm = this.featurePhrase(active, ['type', 'form'], 3);
      const imageSense = this.featurePhrase(active, ['imagery', 'sense'], 4);
      const pressure = this.featurePhrase(active, ['pressure']);
      const connectedFields = CATEGORY_KEYS.filter((key) => active[key].size > 0).map((key) => ATTR_LABELS[key]);
      const overview = connectedFields.length
        ? `This poem sits at the center of ${this.sentenceList(connectedFields)}.`
        : 'This poem is the center of the current ATLAS view.';
      const annoEl = document.getElementById('atlas-anno')!;
      annoEl.innerHTML = `
        <div class="atlas-anno-header">
          <span class="atlas-anno-cat tag-${poem?.world || this.worldKey}">poem</span>
          <h3 class="atlas-anno-name">${n.title || this.poemId}</h3>
        </div>
        <div class="atlas-anno-body">
          <p class="atlas-anno-lede">${overview} Dashed links show the poem's direct feature anchors; solid links show structural relations among those features.</p>
          ${voice ? `<div class="atlas-anno-section"><span class="atlas-anno-section-title">Voice Position</span><p>The speaking position leans toward <span class="atlas-anno-active">${voice}</span>.</p></div>` : ''}
          ${actForm ? `<div class="atlas-anno-section"><span class="atlas-anno-section-title">Poetic Action</span><p>Its movement is shaped by <span class="atlas-anno-active">${actForm}</span>.</p></div>` : ''}
          ${imageSense ? `<div class="atlas-anno-section"><span class="atlas-anno-section-title">Image And Sense</span><p>The sensory field gathers around <span class="atlas-anno-active">${imageSense}</span>.</p></div>` : ''}
          ${pressure ? `<div class="atlas-anno-section"><span class="atlas-anno-section-title">Pressure</span><p>The poem is held under <span class="atlas-anno-active">${pressure}</span>.</p></div>` : ''}
        </div>
      `;
      annoEl.classList.add('is-open');
      if (!this.rafId) this.draw();
    }

    hideAnnotation() {
      const el = document.getElementById('atlas-anno');
      if (el) el.classList.remove('is-open');
    }

    // ── Hit testing (anchor + attr only) ──────────────────────────────────────
    // Hit radius is large enough to include the text label, not just the dot.
    // Closest-node wins, so overlapping zones resolve correctly.
    hitTest(px: number, py: number): Node | null {
      const wx = (px - this.cx - this.tx) / this.scale;
      const wy = (py - this.cy - this.ty) / this.scale;
      let best: Node | null = null, bestDist = Infinity;
      for (const n of this.nodes) {
        const dx = n.x - wx, dy = n.y - wy;
        const dist = Math.sqrt(dx * dx + dy * dy);
        // Active attr: large radius (65px) covers dot + label fully.
        // Inactive attr: 50px — generous but yields to nearer active nodes.
        // Anchor: fixed radius around the circle border.
        const hitR = n.kind === 'anchor' ? n.r + 92 : (n.active ? 72 : 56);
        if (dist < hitR && dist < bestDist) { best = n; bestDist = dist; }
      }
      return best;
    }

    // ── Interaction ───────────────────────────────────────────────────────────
    clearSelection() {
      this.selectedNode = null;
      this.hideAnnotation();
      if (!this.rafId) this.draw();
    }

    zoomAt(px: number, py: number, factor: number) {
      const nextScale = Math.max(this.fitScale, Math.min(2.45, this.scale * factor));
      if (factor < 1 && nextScale <= this.fitScale * 1.01) {
        this.resetView();
        return;
      }
      const worldX = (px - this.cx - this.tx) / this.scale;
      const worldY = (py - this.cy - this.ty) / this.scale;
      this.scale = nextScale;
      this.tx = px - this.cx - worldX * this.scale;
      this.ty = py - this.cy - worldY * this.scale;
      if (!this.rafId) this.draw();
    }

    resetView() {
      this.scale = this.fitScale;
      this.tx = this.fitTx;
      this.ty = this.fitTy;
      if (!this.rafId) this.draw();
    }

    handleTap(px: number, py: number) {
      const hit = this.hitTest(px, py);
      if (!hit) { this.clearSelection(); return; }
      if (hit === this.selectedNode) { this.clearSelection(); return; }
      this.selectedNode = hit;
      this.pulseStart = performance.now();
      if (hit.kind === 'attr') this.showAttrAnnotation(hit);
      if (hit.kind === 'anchor') this.showPoemAnnotation(hit);
      this.animateFor(520);
    }

    // ── Events — pan, wheel zoom, double-click reset, tap select ─────────────
    setupEvents() {
      const canvas = this.canvas;

      canvas.addEventListener('wheel', (e: WheelEvent) => {
        e.preventDefault();
        const rect = canvas.getBoundingClientRect();
        const factor = Math.exp(-e.deltaY * 0.0012);
        this.zoomAt(e.clientX - rect.left, e.clientY - rect.top, factor);
      }, { passive: false });

      canvas.addEventListener('dblclick', () => this.resetView());

      // Hover or drag: update cursor, selected hover, and pan when pointer is held.
      canvas.addEventListener('pointermove', (e: PointerEvent) => {
        if (this.pointerDownPos) {
          const dx = e.clientX - this.pointerDownPos.x;
          const dy = e.clientY - this.pointerDownPos.y;
          if (this.isDragging || Math.sqrt(dx * dx + dy * dy) > 8) {
            this.isDragging = true;
            if (this.dragStart) {
              this.tx = this.dragStart.tx + dx;
              this.ty = this.dragStart.ty + dy;
              canvas.style.cursor = 'grabbing';
              if (!this.rafId) this.draw();
            }
            return;
          }
        }

        const rect = canvas.getBoundingClientRect();
        const hit = this.hitTest(e.clientX - rect.left, e.clientY - rect.top);
        const attrHit = hit?.kind === 'attr' ? hit : null;
        if (attrHit !== this.hoveredNode) {
          this.hoveredNode = attrHit;
          canvas.style.cursor = attrHit ? 'pointer' : 'grab';
          if (!this.rafId) this.draw();
        }
      });

      // Tap: record press position
      canvas.addEventListener('pointerdown', (e: PointerEvent) => {
        canvas.setPointerCapture(e.pointerId);
        this.pointerDownPos = { x: e.clientX, y: e.clientY };
        this.dragStart = { x: e.clientX, y: e.clientY, tx: this.tx, ty: this.ty };
        this.isDragging = false;
        this.pointerDownTime = Date.now();
      });

      // Tap: fire if pointer didn't move much and elapsed < 350ms
      canvas.addEventListener('pointerup', (e: PointerEvent) => {
        if (!this.pointerDownPos) return;
        const elapsed = Date.now() - this.pointerDownTime;
        const dx = e.clientX - this.pointerDownPos.x;
        const dy = e.clientY - this.pointerDownPos.y;
        if (!this.isDragging && elapsed < 350 && Math.sqrt(dx * dx + dy * dy) < 12) {
          const rect = canvas.getBoundingClientRect();
          this.handleTap(e.clientX - rect.left, e.clientY - rect.top);
        }
        this.pointerDownPos = null;
        this.dragStart = null;
        this.isDragging = false;
        canvas.style.cursor = this.hoveredNode ? 'pointer' : 'grab';
      });

      window.addEventListener('resize', () => { this.resize(); this.fitToCanvas(); if (!this.rafId) this.draw(); });
    }

    destroy() { cancelAnimationFrame(this.rafId); }
  }

  // ─── Overlay lifecycle ────────────────────────────────────────────────────
  let graph: AtlasGraph | null = null;
  const overlay  = document.getElementById('atlas-overlay')!;
  const trigger  = document.getElementById('atlas-trigger')!;
  const closeBtn = document.getElementById('atlas-close')!;
  const zoomOutBtn = document.getElementById('atlas-zoom-out')!;
  const zoomInBtn = document.getElementById('atlas-zoom-in')!;
  const canvas   = document.getElementById('atlas-canvas') as HTMLCanvasElement;
  const poemId   = (overlay as HTMLElement).dataset.poemId!;
  const worldKey = (overlay as HTMLElement).dataset.world!;
  let savedScroll = 0;

  // Build accessible text summary of active attributes for screen readers
  function buildSrAttrsText(g: AtlasGraph): string {
    const poem = g.poem;
    if (!poem) return 'No structural data available for this poem.';
    const lines: string[] = [];
    const activeValues = inferAtlasValues(poem);
    CATEGORY_KEYS.forEach(k => {
      const active = [...activeValues[k]];
      if (active.length) {
        const names = active.map((v: string) => v.replace(/_/g, ' ')).join(', ');
        lines.push(`${ATTR_LABELS[k]}: ${names}.`);
      }
    });
    return lines.length ? 'Active structural qualities — ' + lines.join(' ') : '';
  }

  function openAtlas() {
    savedScroll = window.scrollY;
    overlay.setAttribute('aria-hidden', 'false');
    overlay.classList.add('is-open');
    // Reset annotation panel
    const annoEl = document.getElementById('atlas-anno');
    if (annoEl) { annoEl.classList.remove('is-open'); annoEl.innerHTML = ''; }
    gsap.fromTo(
      overlay,
      { opacity: 0, scale: 0.985 },
      { opacity: 1, scale: 1, duration: 0.32, ease: 'expo.out' },
    );
    if (graph) graph.destroy();
    graph = new AtlasGraph(canvas, poemId, worldKey);
    // Populate screen reader text alternative for the canvas (WCAG 1.1.1)
    const srEl = document.getElementById('atlas-sr-attrs');
    if (srEl) srEl.textContent = buildSrAttrsText(graph);
    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }

  function closeAtlas() {
    gsap.to(overlay, {
      opacity: 0, scale: 0.995, duration: 0.22, ease: 'power1.in',
      onComplete: () => {
        overlay.classList.remove('is-open');
        overlay.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        window.scrollTo({ top: savedScroll, behavior: 'instant' });
        trigger.focus();
      },
    });
  }

  trigger.addEventListener('click', openAtlas);
  closeBtn.addEventListener('click', closeAtlas);
  zoomOutBtn.addEventListener('click', () => graph?.zoomAt(canvas.clientWidth / 2, canvas.clientHeight / 2, 0.86));
  zoomInBtn.addEventListener('click', () => graph?.zoomAt(canvas.clientWidth / 2, canvas.clientHeight / 2, 1.16));

  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape' && overlay.classList.contains('is-open')) closeAtlas();
    if (!overlay.classList.contains('is-open')) return;
    if (e.key === '+' || e.key === '=') graph?.zoomAt(canvas.clientWidth / 2, canvas.clientHeight / 2, 1.12);
    if (e.key === '-' || e.key === '_') graph?.zoomAt(canvas.clientWidth / 2, canvas.clientHeight / 2, 0.9);
    if (e.key === '0') graph?.resetView();
  });

  overlay.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key !== 'Tab') return;
    const focusable = overlay.querySelectorAll<HTMLElement>('button, a, [tabindex="0"]');
    const first = focusable[0], last = focusable[focusable.length - 1];
    if (e.shiftKey) { if (document.activeElement === first) { e.preventDefault(); last.focus(); } }
    else            { if (document.activeElement === last)  { e.preventDefault(); first.focus(); } }
  });
</script>
