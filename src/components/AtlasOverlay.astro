---
// AtlasOverlay.astro
// ATLAS — relational reading map for daipan.ink
// Poem ID and world are passed as props; atlas data is read via data-attr and imported in <script>
interface Props {
  poemId: string;
  world: string;
}
const { poemId, world } = Astro.props;
---

<!-- ATLAS trigger button — fixed top-right on poem pages -->
<button
  id="atlas-trigger"
  class="atlas-trigger"
  aria-label="Open ATLAS — poem relation map"
  data-poem-id={poemId}
  data-world={world}
>
  ATLAS
</button>

<!-- ATLAS overlay -->
<div
  id="atlas-overlay"
  class="atlas-overlay"
  role="dialog"
  aria-label="ATLAS — poem relation map"
  aria-modal="true"
  aria-hidden="true"
  data-poem-id={poemId}
  data-world={world}
>
  <!-- Header bar -->
  <div class="atlas-header">
    <span class="atlas-wordmark">ATLAS</span>
    <span class="atlas-subtitle">relation map</span>
    <button id="atlas-close" class="atlas-close" aria-label="Close ATLAS">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.2">
        <line x1="1" y1="1" x2="13" y2="13"/>
        <line x1="13" y1="1" x2="1" y2="13"/>
      </svg>
    </button>
  </div>

  <!-- Legend -->
  <div class="atlas-legend" aria-hidden="true">
    <span class="atlas-legend-label">attributes —</span>
    <span class="atlas-legend-item atlas-legend-mode">speaker</span>
    <span class="atlas-legend-item atlas-legend-type">act</span>
    <span class="atlas-legend-item atlas-legend-imagery">image</span>
    <span class="atlas-legend-sep">·</span>
    <span class="atlas-legend-item atlas-legend-transform">↻ transform</span>
  </div>

  <!-- Canvas -->
  <canvas id="atlas-canvas" class="atlas-canvas" aria-hidden="true"></canvas>

  <!-- Hint text -->
  <p id="atlas-hint" class="atlas-hint" aria-live="polite">
    tap a node to explore — drag to pan — scroll to zoom
  </p>

  <!-- Preview card (shown on poem node click) -->
  <div id="atlas-preview" class="atlas-preview" aria-live="polite" aria-atomic="true"></div>
</div>

<style>
  /* ── Trigger button — mirrors INDEX visual logic, top-right below nav ─────── */
  .atlas-trigger {
    position: fixed;
    top: calc(var(--site-nav-height, 56px) + var(--space-lg, 34px));
    right: max(var(--margin-x, 24px), 12px);
    z-index: 150;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font-family: Georgia, 'Times New Roman', serif;
    font-size: 19px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary, #1a1a1a);
    opacity: 0.35;
    line-height: 1.2;
    transition: opacity 0.2s;
  }

  .atlas-trigger:hover {
    opacity: 1;
    color: var(--color-accent, #1a1a1a);
  }

  .atlas-trigger:focus-visible {
    outline: 2px solid var(--color-accent, #c0392b);
    outline-offset: 4px;
    border-radius: 1px;
  }

  /* ── Overlay ─────────────────────────────────────────────────────────────── */
  .atlas-overlay {
    position: fixed;
    inset: 0;
    z-index: 900;
    background: var(--color-bg, #f5f2ed);
    display: flex;
    flex-direction: column;
    opacity: 0;
    pointer-events: none;
    /* will-change managed by GSAP */
  }

  .atlas-overlay.is-open {
    pointer-events: all;
  }

  /* ── Header ──────────────────────────────────────────────────────────────── */
  .atlas-header {
    display: flex;
    align-items: baseline;
    gap: 10px;
    padding: 16px var(--margin-x, 24px) 0;
    flex-shrink: 0;
  }

  .atlas-wordmark {
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--color-primary, #1a1a1a);
    font-family: inherit;
  }

  .atlas-subtitle {
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--color-meta, #595959);
    font-style: italic;
  }

  .atlas-close {
    margin-left: auto;
    background: transparent;
    border: none;
    padding: 6px;
    cursor: pointer;
    color: var(--color-meta, #595959);
    transition: color 0.15s ease, transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .atlas-close:hover {
    color: var(--color-primary, #1a1a1a);
    transform: rotate(90deg);
  }

  .atlas-close:focus-visible {
    outline: 2px solid var(--color-accent, #c0392b);
    outline-offset: 3px;
    border-radius: 1px;
  }

  /* ── Legend ──────────────────────────────────────────────────────────────── */
  .atlas-legend {
    display: flex;
    gap: 18px;
    align-items: center;
    padding: 10px var(--margin-x, 24px) 0;
    flex-shrink: 0;
  }

  .atlas-legend-label {
    font-size: 10px;
    letter-spacing: 0.05em;
    color: var(--color-meta, #595959);
    font-style: italic;
    margin-right: 2px;
  }

  .atlas-legend-sep {
    font-size: 10px;
    color: var(--color-meta, #595959);
    opacity: 0.5;
  }

  .atlas-legend-item {
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--color-meta, #595959);
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .atlas-legend-item::before {
    content: '';
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .atlas-legend-mode::before   { background: #b8a898; }
  .atlas-legend-type::before   { background: #8a96a8; }
  .atlas-legend-imagery::before { background: #8a9e8a; }

  .atlas-legend-transform {
    font-style: italic;
    color: var(--color-meta, #595959);
  }

  .atlas-legend-transform::before {
    display: none;
  }

  /* ── Canvas ──────────────────────────────────────────────────────────────── */
  .atlas-canvas {
    flex: 1;
    width: 100%;
    display: block;
    touch-action: none;
  }

  /* ── Hint ────────────────────────────────────────────────────────────────── */
  .atlas-hint {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 13px;
    letter-spacing: 0.04em;
    color: var(--color-meta, #595959);
    font-style: italic;
    pointer-events: none;
    text-align: center;
    transition: opacity 0.3s ease;
    white-space: nowrap;
  }

  .atlas-hint.is-hidden {
    opacity: 0;
  }

  /* ── Preview card ────────────────────────────────────────────────────────── */
  .atlas-preview {
    position: absolute;
    bottom: 48px;
    left: 50%;
    transform: translateX(-50%);
    width: min(380px, calc(100vw - 48px));
    background: var(--color-bg, #f5f2ed);
    border: 0.5px solid rgba(26, 26, 26, 0.12);
    padding: 18px 20px 16px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.22s ease, transform 0.22s cubic-bezier(0.16, 1, 0.3, 1);
    transform: translateX(-50%) translateY(6px);
  }

  .atlas-preview.is-visible {
    opacity: 1;
    pointer-events: all;
    transform: translateX(-50%) translateY(0);
  }

  /* preview card internals (set by JS innerHTML) */
  :global(.atlas-preview-tag) {
    display: inline-block;
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--color-meta, #595959);
    margin-bottom: 6px;
  }

  :global(.atlas-preview-tag.tag-mode)    { color: #b8a898; }
  :global(.atlas-preview-tag.tag-type)    { color: #8a96a8; }
  :global(.atlas-preview-tag.tag-imagery) { color: #8a9e8a; }

  :global(.atlas-preview-vol-label) {
    display: block;
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--color-meta, #595959);
    margin-bottom: 4px;
  }

  :global(.atlas-preview-title) {
    margin: 0 0 7px;
    font-size: 19px;
    font-weight: normal;
    letter-spacing: -0.01em;
    color: var(--color-primary, #1a1a1a);
    line-height: 1.25;
  }

  :global(.atlas-preview-firstline) {
    margin: 0 0 10px;
    font-size: 13px;
    line-height: 1.6;
    color: var(--color-meta, #595959);
    font-style: italic;
  }

  :global(.atlas-preview-reason) {
    margin: 0 0 14px;
    font-size: 11.5px;
    letter-spacing: 0.04em;
    color: var(--color-meta, #595959);
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 3px;
  }

  :global(.atlas-reason-tag) {
    font-size: 11px;
    letter-spacing: 0.05em;
    font-style: italic;
  }

  :global(.atlas-reason-sep) {
    font-size: 11px;
    color: var(--color-meta, #595959);
    opacity: 0.5;
  }

  :global(.atlas-transform-badge) {
    font-style: italic;
    color: var(--color-accent, #c0392b);
    margin-left: 4px;
  }

  :global(.atlas-preview-cta) {
    display: inline-block;
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--color-primary, #1a1a1a);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 0.15s ease;
  }

  :global(.atlas-preview-cta:hover) {
    opacity: 0.65;
  }

  :global(.atlas-attr-list) {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  :global(.atlas-attr-poem) {
    display: flex;
    align-items: baseline;
    gap: 8px;
    font-size: 12.5px;
    color: var(--color-primary, #1a1a1a);
    text-decoration: none;
    padding: 3px 0;
    border-bottom: 0.5px solid rgba(26,26,26,0.06);
    transition: padding-left 0.15s ease;
  }

  :global(.atlas-attr-poem:last-child) {
    border-bottom: none;
  }

  :global(.atlas-attr-poem:hover) {
    padding-left: 4px;
  }

  :global(.atlas-attr-vol) {
    font-size: 10px;
    letter-spacing: 0.06em;
    color: var(--color-meta, #595959);
    min-width: 16px;
  }
</style>

<script>
  import atlas from '../data/atlas.json';
  import gsap from 'gsap';

  // ─── Constants ────────────────────────────────────────────────────────────
  const WORLD_COLORS: Record<string, { accent: string; soft: string; bg: string }> = {
    'their-world': { accent: '#c0392b', soft: '#e8c8c4', bg: '#f5f2ed' },
    'bless-you':   { accent: '#9b7b8b', soft: '#ddd0d8', bg: '#f2ede4' },
    'still-life':  { accent: '#8a9e8a', soft: '#c8d8c8', bg: '#f8f7f4' },
  };

  const ATTR_COLORS: Record<string, string> = {
    mode:    '#b8a898',
    type:    '#8a96a8',
    imagery: '#8a9e8a',
  };

  const VOL_LABELS: Record<string, string> = {
    'their-world': 'I',
    'bless-you':   'II',
    'still-life':  'III',
  };

  const VOL_FULL: Record<string, string> = {
    'their-world': 'I — Their World',
    'bless-you':   'II — Bless You',
    'still-life':  'III — Still Life',
  };

  const ATTR_FULL: Record<string, string> = {
    mode: 'Speaker mode',
    type: 'Poem act',
    imagery: 'Imagery',
  };

  // ─── Types ────────────────────────────────────────────────────────────────
  interface Node {
    kind: 'center' | 'attr' | 'related';
    x: number; y: number;
    r: number;
    // center / related fields
    id?: string; title?: string; world?: string; order?: number;
    firstLine?: string; transform?: boolean; weight?: number;
    reason?: string[];
    // attr fields
    attrType?: string; value?: string;
    // animation
    alpha: number; delay: number;
    currentAlpha?: number;
  }

  interface Edge {
    from: Node; to: Node;
    isTransform?: boolean;
  }

  // ─── AtlasGraph ───────────────────────────────────────────────────────────
  class AtlasGraph {
    canvas: HTMLCanvasElement;
    ctx: CanvasRenderingContext2D;
    poemId: string;
    worldKey: string;
    poem: any;
    nodes: Node[];
    edges: Edge[];
    selectedNode: Node | null;
    hoveredNode: Node | null;
    tx: number; ty: number; scale: number;
    cx: number; cy: number;
    dpr: number;
    isDragging: boolean;
    dragStart: { x: number; y: number; tx: number; ty: number } | null;
    pinchStart: number | null;
    pinchScale: number;
    pointerDownPos: { x: number; y: number } | null;
    pointerDownTime: number;
    rafId: number;
    isStub: boolean;

    constructor(canvas: HTMLCanvasElement, poemId: string, worldKey: string) {
      this.canvas = canvas;
      this.ctx = canvas.getContext('2d')!;
      this.poemId = poemId;
      this.worldKey = worldKey;
      this.poem = atlas.poems.find((p: any) => p.id === poemId) ?? null;
      this.nodes = [];
      this.edges = [];
      this.selectedNode = null;
      this.hoveredNode = null;
      this.tx = 0; this.ty = 0; this.scale = 1;
      this.cx = 0; this.cy = 0;
      this.dpr = window.devicePixelRatio || 1;
      this.isDragging = false;
      this.dragStart = null;
      this.pinchStart = null;
      this.pinchScale = 1;
      this.pointerDownPos = null;
      this.pointerDownTime = 0;
      this.rafId = 0;
      this.isStub = false;

      this.resize();
      this.buildGraph();
      this.setupEvents();
      this.startLoop();
    }

    // ── Deterministic hash (0-1) for organic jitter ─────────────────────────
    hashStr(s: string): number {
      let h = 0;
      for (let i = 0; i < s.length; i++) h = (Math.imul(31, h) + s.charCodeAt(i)) | 0;
      return (h >>> 0) / 4294967296;
    }

    // ── Graph construction ──────────────────────────────────────────────────
    buildGraph() {
      this.nodes = [];
      this.edges = [];
      const poem = this.poem;

      // Center node
      const center: Node = {
        kind: 'center', id: poem?.id, title: poem?.title ?? this.poemId,
        world: poem?.world ?? this.worldKey,
        x: 0, y: 0, r: 32, alpha: 1, delay: 0, currentAlpha: 1,
      };
      this.nodes.push(center);

      if (!poem?.mode) {
        // Stub poem — relations not yet mapped.
        // Show the nearest poems from the same world by order as navigable neighbours,
        // with organic jitter so they don't form a rigid circle.
        this.isStub = true;
        const currentOrder: number = poem?.order ?? 0;
        const worldPoems = (atlas.poems as any[])
          .filter((p: any) => p.world === this.worldKey && p.id !== this.poemId)
          .map((p: any) => ({ ...p, _dist: Math.abs(p.order - currentOrder) }))
          .sort((a: any, b: any) => a._dist - b._dist)
          .slice(0, 6);

        worldPoems.forEach((rp: any, i: number) => {
          // Organic angle: base from even spacing + jitter from id hash
          const baseAngle = (i / worldPoems.length) * Math.PI * 2 - Math.PI / 2;
          const jitter = (this.hashStr(rp.id) - 0.5) * 0.55;
          const angle = baseAngle + jitter;
          const radius = 190 + Math.floor(this.hashStr(rp.id + '_r') * 55);
          const node: Node = {
            kind: 'related', id: rp.id, title: rp.title,
            world: rp.world, order: rp.order,
            firstLine: rp.firstLine,
            weight: 1,
            reason: ['sequential'],
            transform: false,
            x: Math.cos(angle) * radius, y: Math.sin(angle) * radius,
            r: 22, alpha: 0, delay: 0.15 + i * 0.1,
            currentAlpha: 0,
          };
          this.nodes.push(node);
          this.edges.push({ from: center, to: node });
        });
        return;
      }

      // ── Attribute nodes — grouped by type into organic sectors ─────────────
      // mode: upper-left quadrant, type: upper-right, imagery: lower half
      const SECTORS: Record<string, { base: number; span: number }> = {
        mode:    { base: 195, span: 90 },   // 195–285° (left side)
        type:    { base: 285, span: 90 },   // 285–375° / 285–15° (upper right)
        imagery: { base: 30,  span: 150 },  // 30–180° (right & bottom)
      };
      // Track sector usage to space values within sector
      const sectorCounts: Record<string, number> = { mode: 0, type: 0, imagery: 0 };
      const sectorTotals: Record<string, number> = {
        mode: (poem.mode || []).length,
        type: (poem.type || []).length,
        imagery: (poem.imagery || []).length,
      };

      const attrs: { attrType: string; value: string }[] = [];
      (poem.mode    || []).forEach((v: string) => attrs.push({ attrType: 'mode',    value: v }));
      (poem.type    || []).forEach((v: string) => attrs.push({ attrType: 'type',    value: v }));
      (poem.imagery || []).forEach((v: string) => attrs.push({ attrType: 'imagery', value: v }));

      const attrNodes: Node[] = attrs.map((a, i) => {
        const sector = SECTORS[a.attrType] || { base: 0, span: 120 };
        const idx    = sectorCounts[a.attrType]++;
        const total  = sectorTotals[a.attrType] || 1;
        // Spread evenly within sector + small hash jitter (±12°)
        const tFrac  = total > 1 ? idx / (total - 1) : 0.5;
        const jitter = (this.hashStr(a.value + '_a') - 0.5) * 0.21;  // ±12°
        const deg    = sector.base + tFrac * sector.span;
        const angle  = (deg * Math.PI / 180) + jitter;
        // Radius variation: 145–190 based on value hash
        const radius = 145 + Math.floor(this.hashStr(a.value + '_r') * 48);

        return {
          kind: 'attr' as const, attrType: a.attrType, value: a.value,
          x: Math.cos(angle) * radius, y: Math.sin(angle) * radius,
          r: 7, alpha: 0, delay: 0.08 + i * 0.055, currentAlpha: 0,
        };
      });
      attrNodes.forEach(n => {
        this.nodes.push(n);
        this.edges.push({ from: center, to: n });
      });

      // ── Related poem nodes — outer ring with organic jitter ─────────────────
      const related = poem.related_poems || [];
      related.forEach((rel: any, i: number) => {
        const rp = (atlas.poems as any[]).find((p: any) => p.id === rel.id);
        if (!rp) return;
        const baseAngle = (i / related.length) * Math.PI * 2 - Math.PI / 4;
        const jitter    = (this.hashStr(rel.id + '_pa') - 0.5) * 0.5;
        const angle     = baseAngle + jitter;
        const radius    = 285 + Math.floor(this.hashStr(rel.id + '_pr') * 60);
        const node: Node = {
          kind: 'related', id: rp.id, title: rp.title,
          world: rp.world, order: rp.order,
          firstLine: rp.firstLine,
          weight: rel.weight, reason: rel.reason,
          transform: rel.relation === 'transform',
          x: Math.cos(angle) * radius, y: Math.sin(angle) * radius,
          r: 22, alpha: 0, delay: 0.5 + i * 0.09, currentAlpha: 0,
        };
        this.nodes.push(node);
        this.edges.push({ from: center, to: node, isTransform: rel.relation === 'transform' });
      });
    }

    // ── Layout helpers ──────────────────────────────────────────────────────
    resize() {
      const el = this.canvas.parentElement!;
      const rect = el.getBoundingClientRect();
      const W = rect.width;
      const H = el.clientHeight || rect.height;
      this.canvas.width  = W * this.dpr;
      this.canvas.height = H * this.dpr;
      this.canvas.style.width  = W + 'px';
      this.canvas.style.height = H + 'px';
      this.cx = W / 2;
      this.cy = H / 2;
    }

    // ── Render loop ─────────────────────────────────────────────────────────
    // Runs only for the entry animation (1 s). All subsequent redraws are
    // event-driven: pointermove, pointerup, wheel, and handleTap each call draw().
    startLoop() {
      const start = performance.now();
      const totalDur = 1000;

      const tick = (now: number) => {
        const t = Math.min(1, (now - start) / totalDur);
        // Advance per-node alpha
        this.nodes.forEach(n => {
          const progress = Math.max(0, Math.min(1, (t - n.delay) / 0.35));
          n.currentAlpha = this.easeOut(progress);
        });
        this.draw();
        if (t < 1) {
          this.rafId = requestAnimationFrame(tick);
        }
      };
      this.rafId = requestAnimationFrame(tick);
    }

    easeOut(t: number) {
      return 1 - Math.pow(1 - t, 3);
    }

    // ── Drawing ─────────────────────────────────────────────────────────────
    draw() {
      const ctx = this.ctx;
      const dpr = this.dpr;
      const W = this.canvas.width / dpr;
      const H = this.canvas.height / dpr;

      ctx.save();
      ctx.scale(dpr, dpr);
      ctx.clearRect(0, 0, W, H);

      ctx.translate(this.cx + this.tx, this.cy + this.ty);
      ctx.scale(this.scale, this.scale);

      this.drawEdges();
      this.drawNodes();
      this.drawSectorLabels();
      if (this.isStub) this.drawStubNote();

      ctx.restore();
    }

    drawEdges() {
      const ctx = this.ctx;
      this.edges.forEach(edge => {
        const fa = edge.from.currentAlpha ?? 0;
        const ta = edge.to.currentAlpha ?? 0;
        const alpha = Math.min(fa, ta);
        if (alpha <= 0) return;

        const isHighlighted =
          this.selectedNode === edge.from ||
          this.selectedNode === edge.to   ||
          (this.hoveredNode && (this.hoveredNode === edge.from || this.hoveredNode === edge.to));

        ctx.save();
        ctx.globalAlpha = alpha * (isHighlighted ? 0.4 : (edge.isTransform ? 0.18 : 0.1));
        ctx.strokeStyle = '#1a1a1a';
        ctx.lineWidth = edge.isTransform ? 1 : 0.6;
        if (edge.isTransform) ctx.setLineDash([3, 5]);
        ctx.beginPath();
        ctx.moveTo(edge.from.x, edge.from.y);
        ctx.lineTo(edge.to.x, edge.to.y);
        ctx.stroke();
        ctx.setLineDash([]);
        ctx.restore();
      });

      // If attr node selected: phantom connections to all matching related poems
      if (this.selectedNode?.kind === 'attr') {
        const sel = this.selectedNode;
        const matchingIds = this.getAttrMatches(sel.attrType!, sel.value!).map((p: any) => p.id);
        this.nodes.filter(n => n.kind === 'related' && matchingIds.includes(n.id!)).forEach(n => {
          if ((n.currentAlpha ?? 0) <= 0) return;
          ctx.save();
          ctx.globalAlpha = 0.4;
          ctx.strokeStyle = ATTR_COLORS[sel.attrType!] || '#888';
          ctx.lineWidth = 1.2;
          ctx.setLineDash([4, 4]);
          ctx.beginPath();
          ctx.moveTo(sel.x, sel.y);
          ctx.lineTo(n.x, n.y);
          ctx.stroke();
          ctx.setLineDash([]);
          ctx.restore();
        });
      }

      // If related poem selected: draw colored pathways through matching attr nodes
      if (this.selectedNode?.kind === 'related') {
        const sel = this.selectedNode;
        const reasons = sel.reason || [];
        reasons.forEach((reason: string) => {
          const color = ATTR_COLORS[reason] || '#888';
          this.nodes
            .filter(n => n.kind === 'attr' && n.attrType === reason)
            .forEach(attrNode => {
              if ((attrNode.currentAlpha ?? 0) <= 0) return;
              ctx.save();
              ctx.globalAlpha = 0.55;
              ctx.strokeStyle = color;
              ctx.lineWidth = 1.5;
              ctx.setLineDash([4, 5]);
              ctx.beginPath();
              ctx.moveTo(attrNode.x, attrNode.y);
              ctx.lineTo(sel.x, sel.y);
              ctx.stroke();
              ctx.setLineDash([]);
              ctx.restore();
            });
        });
      }
    }

    drawNodes() {
      // Draw in order: edges first, then related, attr, center last (on top)
      const order = ['related', 'attr', 'center'];
      order.forEach(kind => {
        this.nodes.filter(n => n.kind === kind).forEach(n => this.drawNode(n));
      });
    }

    drawNode(node: Node) {
      const alpha = node.currentAlpha ?? 0;
      if (alpha <= 0) return;
      const ctx = this.ctx;
      ctx.save();
      ctx.globalAlpha = alpha;

      if (node.kind === 'center')  this.drawCenterNode(node);
      if (node.kind === 'attr')    this.drawAttrNode(node);
      if (node.kind === 'related') this.drawRelatedNode(node);

      ctx.restore();
    }

    drawCenterNode(node: Node) {
      const ctx = this.ctx;
      const wc = WORLD_COLORS[node.world || this.worldKey] || WORLD_COLORS['their-world'];
      const r = node.r;

      // Outer ring
      ctx.beginPath();
      ctx.arc(0, 0, r + 5, 0, Math.PI * 2);
      ctx.strokeStyle = wc.accent;
      ctx.lineWidth = 1.5;
      ctx.globalAlpha *= 0.5;
      ctx.stroke();
      ctx.globalAlpha /= 0.5;

      // Fill
      ctx.beginPath();
      ctx.arc(0, 0, r, 0, Math.PI * 2);
      ctx.fillStyle = wc.bg;
      ctx.fill();
      ctx.strokeStyle = wc.accent;
      ctx.lineWidth = 1.5;
      ctx.stroke();

      // "current" label above — italic, muted
      ctx.font = `italic 11px Georgia, serif`;
      ctx.fillStyle = '#aaa';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'bottom';
      ctx.fillText('current', 0, -r - 12);

      // Title below — 15px, well below the ring
      ctx.font = `15px Georgia, serif`;
      ctx.fillStyle = '#1a1a1a';
      ctx.textBaseline = 'top';
      this.wrapText(node.title || '', 0, r + 14, 130, 19);
    }

    drawAttrNode(node: Node) {
      const ctx = this.ctx;
      const color = ATTR_COLORS[node.attrType!] || '#888';
      const isHovered  = this.hoveredNode === node;
      const isSelected = this.selectedNode === node;
      // Is this attr node in the pathway of a selected related poem?
      const isPathway = this.selectedNode?.kind === 'related' &&
        (this.selectedNode.reason || []).includes(node.attrType!);

      const r = node.r * (isHovered || isSelected || isPathway ? 1.85 : 1);

      ctx.beginPath();
      ctx.arc(node.x, node.y, r, 0, Math.PI * 2);
      ctx.fillStyle = isSelected ? '#1a1a1a' : isPathway ? color : color;
      ctx.globalAlpha *= isPathway ? 1 : 1;
      ctx.fill();
      ctx.globalAlpha /= isPathway ? 1 : 1;

      if (isSelected || isPathway) {
        ctx.beginPath();
        ctx.arc(node.x, node.y, r + 5, 0, Math.PI * 2);
        ctx.strokeStyle = color;
        ctx.lineWidth = 1;
        ctx.globalAlpha *= 0.6;
        ctx.stroke();
        ctx.globalAlpha /= 0.6;
      }

      // Label — radially outward, larger and more readable
      const angle = Math.atan2(node.y, node.x);
      const labelDist = r + 11;
      const lx = node.x + Math.cos(angle) * labelDist;
      const ly = node.y + Math.sin(angle) * labelDist;

      ctx.font = `italic 12px Georgia, serif`;
      ctx.fillStyle = isSelected || isPathway ? '#1a1a1a' : '#5a5a5a';
      ctx.textBaseline = 'middle';

      // Horizontal alignment based on angle
      const deg = angle * 180 / Math.PI;
      if (deg > -60 && deg < 60) {
        ctx.textAlign = 'left';
      } else if (deg > 120 || deg < -120) {
        ctx.textAlign = 'right';
      } else {
        ctx.textAlign = 'center';
      }
      ctx.fillText(this.formatLabel(node.value!), lx, ly);
    }

    drawRelatedNode(node: Node) {
      const ctx = this.ctx;
      const wc = WORLD_COLORS[node.world!] || WORLD_COLORS['their-world'];
      const isHovered  = this.hoveredNode === node;
      const isSelected = this.selectedNode === node;
      const r = node.r * (isHovered ? 1.12 : 1);

      // Is this node highlighted by an attr selection?
      let attrHighlighted = false;
      if (this.selectedNode?.kind === 'attr') {
        const matches = this.getAttrMatches(this.selectedNode.attrType!, this.selectedNode.value!);
        attrHighlighted = matches.some((p: any) => p.id === node.id);
      }

      // Fill
      ctx.beginPath();
      ctx.arc(node.x, node.y, r, 0, Math.PI * 2);
      ctx.fillStyle = isSelected || attrHighlighted ? wc.soft : 'rgba(248,246,242,0.9)';
      ctx.fill();

      // Ring
      ctx.beginPath();
      ctx.arc(node.x, node.y, r, 0, Math.PI * 2);
      ctx.strokeStyle = isSelected || attrHighlighted ? wc.accent : wc.soft;
      ctx.lineWidth = isSelected ? 1.8 : 1;
      ctx.stroke();

      // Transformation marker — centred glyph
      if (node.transform) {
        ctx.font = `10px Georgia, serif`;
        ctx.fillStyle = wc.accent;
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText('↻', node.x, node.y);
      }

      // Volume label — tiny, sits directly below the circle
      const volLabel = VOL_LABELS[node.world!] || '';
      const titleTopY = node.y + r + 9;
      ctx.font = `10px Georgia, serif`;
      ctx.fillStyle = wc.accent;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'top';
      ctx.fillText(volLabel, node.x, titleTopY);

      // Title — below vol label, 13px so it's readable
      const titleFontSize = isHovered || isSelected ? 14 : 13;
      ctx.font = `${titleFontSize}px Georgia, serif`;
      ctx.fillStyle = isHovered || isSelected ? '#1a1a1a' : '#333';
      ctx.textBaseline = 'top';
      this.wrapText(node.title || '', node.x, titleTopY + 13, 96, 16);
    }

    // ── Sector group labels (annotated poems only) ───────────────────────────
    // Floats at the centroid of each attr-type cluster, gives spatial context.
    drawSectorLabels() {
      if (this.isStub) return;
      const ctx = this.ctx;

      // Compute centroid per attr type from actual node positions
      const centroids: Record<string, { sx: number; sy: number; n: number }> = {
        mode:    { sx: 0, sy: 0, n: 0 },
        type:    { sx: 0, sy: 0, n: 0 },
        imagery: { sx: 0, sy: 0, n: 0 },
      };
      this.nodes.filter(nd => nd.kind === 'attr').forEach(nd => {
        const key = nd.attrType!;
        if (centroids[key]) {
          centroids[key].sx += nd.x;
          centroids[key].sy += nd.y;
          centroids[key].n++;
        }
      });

      const LABELS: Record<string, string> = {
        mode: 'speaker', type: 'act', imagery: 'image',
      };
      const avgAlpha = this.nodes.filter(n => n.kind === 'attr')
        .reduce((s, n) => s + (n.currentAlpha ?? 0), 0) /
        Math.max(1, this.nodes.filter(n => n.kind === 'attr').length);

      if (avgAlpha < 0.05) return;

      ctx.save();
      ctx.globalAlpha = avgAlpha * 0.38;
      Object.entries(centroids).forEach(([key, c]) => {
        if (c.n === 0) return;
        // Place label 28px further outward from centroid
        const cx = c.sx / c.n;
        const cy = c.sy / c.n;
        const dist = Math.sqrt(cx * cx + cy * cy) || 1;
        const lx = cx + (cx / dist) * 28;
        const ly = cy + (cy / dist) * 28;

        ctx.font = `10px Georgia, serif`;
        ctx.fillStyle = ATTR_COLORS[key] || '#888';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.letterSpacing = '0.08em';
        ctx.fillText(LABELS[key] || key, lx, ly);
      });
      ctx.restore();
    }

    // ── Stub annotation ─────────────────────────────────────────────────────
    drawStubNote() {
      const ctx = this.ctx;
      ctx.save();
      // Note below the title — r=32, title starts at 46, title is ~19px tall,
      // so safe position is r + 14 + 19 + 14 = 79+. Use 90 to be safe.
      ctx.font = `italic 11px Georgia, serif`;
      ctx.fillStyle = 'rgba(100,90,80,0.45)';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'top';
      ctx.fillText('relation data not yet mapped', 0, 90);
      ctx.restore();
    }

    // ── Text utilities ──────────────────────────────────────────────────────
    wrapText(text: string, x: number, y: number, maxW: number, lineH: number) {
      const ctx = this.ctx;
      const words = text.split(' ');
      let line = '';
      let cy = y;
      for (let i = 0; i < words.length; i++) {
        const test = line + words[i] + ' ';
        if (ctx.measureText(test).width > maxW && i > 0) {
          ctx.fillText(line.trim(), x, cy);
          line = words[i] + ' ';
          cy += lineH;
        } else {
          line = test;
        }
      }
      ctx.fillText(line.trim(), x, cy);
    }

    formatLabel(val: string) {
      return val.replace(/_/g, ' ');
    }

    // ── Hit testing ─────────────────────────────────────────────────────────
    hitTest(px: number, py: number): Node | null {
      // Convert screen px → world coords
      const wx = (px - this.cx - this.tx) / this.scale;
      const wy = (py - this.cy - this.ty) / this.scale;

      let best: Node | null = null;
      let bestDist = Infinity;
      for (const n of this.nodes) {
        if (n.kind === 'center') continue;
        const dx = n.x - wx, dy = n.y - wy;
        const dist = Math.sqrt(dx * dx + dy * dy);
        const hitR = Math.max(n.r + 14, 20);
        if (dist < hitR && dist < bestDist) {
          best = n;
          bestDist = dist;
        }
      }
      return best;
    }

    // ── Attr-based matching ─────────────────────────────────────────────────
    getAttrMatches(attrType: string, value: string): any[] {
      return atlas.poems.filter((p: any) => {
        const arr: string[] = p[attrType] || [];
        return arr.includes(value) && p.id !== this.poemId;
      });
    }

    // ── Interaction handlers ────────────────────────────────────────────────
    handleTap(x: number, y: number) {
      const hit = this.hitTest(x, y);
      if (!hit) {
        this.selectedNode = null;
        this.updatePreview(null);
        const defaultHint = this.isStub
          ? 'nearby poems in this volume — tap to preview'
          : 'tap a node to explore — drag to pan — scroll to zoom';
        this.updateHint(defaultHint);
        this.draw();
        return;
      }
      if (hit === this.selectedNode) {
        // Second tap on same node — navigate to poem or deselect attr
        if (hit.kind === 'related') {
          window.location.href = (atlas.poems as any[]).find((p: any) => p.id === hit.id)?.url || '#';
        } else {
          this.selectedNode = null;
          this.updatePreview(null);
          this.draw();
        }
        return;
      }
      this.selectedNode = hit;
      if (hit.kind === 'attr')    this.showAttrPanel(hit);
      if (hit.kind === 'related') this.showPoemPreview(hit);
      this.draw(); // ensure selected-state highlight renders immediately
    }

    showAttrPanel(node: Node) {
      const matches = this.getAttrMatches(node.attrType!, node.value!).slice(0, 6);
      const typeLabel = ATTR_FULL[node.attrType!] || node.attrType!;
      const label = this.formatLabel(node.value!);
      const tagClass = `tag-${node.attrType}`;

      const preview = document.getElementById('atlas-preview')!;
      preview.innerHTML = `
        <span class="atlas-preview-tag ${tagClass}">${typeLabel}</span>
        <h3 class="atlas-preview-title">${label}</h3>
        <ul class="atlas-attr-list">
          ${matches.map(p => `
            <li>
              <a href="${p.url}" class="atlas-attr-poem">
                <span class="atlas-attr-vol">${VOL_LABELS[p.world] || ''}</span>
                <span>${p.title}</span>
              </a>
            </li>
          `).join('')}
          ${matches.length === 0 ? `<li style="font-size:11px;color:#888;font-style:italic;padding:4px 0">Only this poem in the map</li>` : ''}
        </ul>
      `;
      preview.classList.add('is-visible');
      this.updateHint('tap a poem to preview · tap again to read');
    }

    showPoemPreview(node: Node) {
      const REASON_LABELS: Record<string, string> = {
        sequential: 'in this volume',
        mode:       'same speaker',
        type:       'same act',
        imagery:    'shared image',
      };
      const REASON_COLORS: Record<string, string> = {
        mode:    '#b8a898',
        type:    '#8a96a8',
        imagery: '#8a9e8a',
      };

      const reasonTags = (node.reason || [])
        .map(r => {
          const color = REASON_COLORS[r] || 'inherit';
          const label = REASON_LABELS[r] || r;
          return `<span class="atlas-reason-tag" style="color:${color}">${label}</span>`;
        })
        .join('<span class="atlas-reason-sep"> · </span>');

      const transformBadge = node.transform
        ? `<span class="atlas-transform-badge">↻ transformation</span>` : '';

      const rp = (atlas.poems as any[]).find((p: any) => p.id === node.id);
      const url = rp?.url || '#';

      const preview = document.getElementById('atlas-preview')!;
      preview.innerHTML = `
        <span class="atlas-preview-vol-label">${VOL_FULL[node.world!] || node.world}</span>
        <h3 class="atlas-preview-title">${node.title}</h3>
        ${node.firstLine ? `<p class="atlas-preview-firstline">"${node.firstLine}"</p>` : ''}
        <p class="atlas-preview-reason">${reasonTags}${transformBadge}</p>
        <a href="${url}" class="atlas-preview-cta">Read this poem →</a>
      `;
      preview.classList.add('is-visible');
      this.updateHint('tap again to navigate to this poem');
    }

    updatePreview(node: Node | null) {
      const preview = document.getElementById('atlas-preview')!;
      if (!node) {
        preview.classList.remove('is-visible');
      }
    }

    updateHint(text: string) {
      const hint = document.getElementById('atlas-hint')!;
      hint.textContent = text;
    }

    // ── Events ──────────────────────────────────────────────────────────────
    setupEvents() {
      const canvas = this.canvas;

      // Pointer move — hover
      canvas.addEventListener('pointermove', (e: PointerEvent) => {
        if (this.isDragging && this.dragStart) {
          const dx = e.clientX - this.dragStart.x;
          const dy = e.clientY - this.dragStart.y;
          this.tx = this.dragStart.tx + dx;
          this.ty = this.dragStart.ty + dy;
          this.draw();
          return;
        }
        const rect = canvas.getBoundingClientRect();
        const hit = this.hitTest(e.clientX - rect.left, e.clientY - rect.top);
        if (hit !== this.hoveredNode) {
          this.hoveredNode = hit;
          canvas.style.cursor = hit ? 'pointer' : 'grab';
          this.draw();
        }
      });

      // Pointer down
      canvas.addEventListener('pointerdown', (e: PointerEvent) => {
        canvas.setPointerCapture(e.pointerId);
        this.pointerDownPos = { x: e.clientX, y: e.clientY };
        this.pointerDownTime = Date.now();
        this.dragStart = { x: e.clientX, y: e.clientY, tx: this.tx, ty: this.ty };
        canvas.style.cursor = 'grabbing';
      });

      // Pointer up — distinguish tap vs drag
      canvas.addEventListener('pointerup', (e: PointerEvent) => {
        if (!this.pointerDownPos) return;
        const elapsed = Date.now() - this.pointerDownTime;
        const dx = e.clientX - this.pointerDownPos.x;
        const dy = e.clientY - this.pointerDownPos.y;
        const moved = Math.sqrt(dx * dx + dy * dy);

        if (elapsed < 350 && moved < 12) {
          const rect = canvas.getBoundingClientRect();
          this.handleTap(e.clientX - rect.left, e.clientY - rect.top);
        }

        this.isDragging = false;
        this.dragStart = null;
        this.pointerDownPos = null;
        canvas.style.cursor = this.hoveredNode ? 'pointer' : 'grab';
        this.draw();
      });

      // Mark as dragging once movement threshold exceeded
      canvas.addEventListener('pointermove', (e: PointerEvent) => {
        if (!this.pointerDownPos || this.isDragging) return;
        const dx = e.clientX - this.pointerDownPos.x;
        const dy = e.clientY - this.pointerDownPos.y;
        if (Math.sqrt(dx * dx + dy * dy) > 8) {
          this.isDragging = true;
        }
      });

      // Wheel zoom
      canvas.addEventListener('wheel', (e: WheelEvent) => {
        e.preventDefault();
        const factor = e.deltaY > 0 ? 0.9 : 1.1;
        this.scale = Math.max(0.35, Math.min(2.8, this.scale * factor));
        this.draw();
      }, { passive: false });

      // Pinch zoom (touch)
      const getPinchDist = (e: TouchEvent) => {
        const dx = e.touches[0].clientX - e.touches[1].clientX;
        const dy = e.touches[0].clientY - e.touches[1].clientY;
        return Math.sqrt(dx * dx + dy * dy);
      };

      canvas.addEventListener('touchstart', (e: TouchEvent) => {
        if (e.touches.length === 2) {
          this.pinchStart = getPinchDist(e);
          this.pinchScale = this.scale;
        }
      }, { passive: true });

      canvas.addEventListener('touchmove', (e: TouchEvent) => {
        if (e.touches.length === 2 && this.pinchStart !== null) {
          const dist = getPinchDist(e);
          const ratio = dist / this.pinchStart;
          this.scale = Math.max(0.35, Math.min(2.8, this.pinchScale * ratio));
          this.draw();
          e.preventDefault();
        }
      }, { passive: false });

      canvas.addEventListener('touchend', () => { this.pinchStart = null; });

      // Resize
      window.addEventListener('resize', () => {
        this.resize();
        this.draw();
      });
    }

    destroy() {
      cancelAnimationFrame(this.rafId);
    }
  }

  // ─── Overlay lifecycle ────────────────────────────────────────────────────
  let graph: AtlasGraph | null = null;
  const overlay = document.getElementById('atlas-overlay')!;
  const trigger = document.getElementById('atlas-trigger')!;
  const closeBtn = document.getElementById('atlas-close')!;
  const canvas = document.getElementById('atlas-canvas') as HTMLCanvasElement;

  const poemId  = (overlay as HTMLElement).dataset.poemId!;
  const worldKey = (overlay as HTMLElement).dataset.world!;

  // Save scroll position when ATLAS opens
  let savedScroll = 0;

  function openAtlas() {
    savedScroll = window.scrollY;
    overlay.setAttribute('aria-hidden', 'false');
    overlay.classList.add('is-open');

    gsap.fromTo(overlay,
      { opacity: 0, y: 8 },
      { opacity: 1, y: 0, duration: 0.32, ease: 'power2.out' }
    );

    // Build / rebuild graph each open (handles resize)
    if (graph) graph.destroy();
    graph = new AtlasGraph(canvas, poemId, worldKey);

    // Set contextual hint based on whether this poem has relation data
    const hint = document.getElementById('atlas-hint')!;
    hint.textContent = graph.isStub
      ? 'nearby poems in this volume — tap to preview · relation map coming soon'
      : 'tap speaker · act · image nodes to find shared poems';

    document.body.style.overflow = 'hidden';
    closeBtn.focus();
  }

  function closeAtlas() {
    gsap.to(overlay, {
      opacity: 0, y: 6, duration: 0.22, ease: 'power2.in',
      onComplete: () => {
        overlay.classList.remove('is-open');
        overlay.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        window.scrollTo({ top: savedScroll, behavior: 'instant' });
        trigger.focus();
      }
    });
  }

  trigger.addEventListener('click', openAtlas);
  closeBtn.addEventListener('click', closeAtlas);

  // ESC closes
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape' && overlay.classList.contains('is-open')) {
      closeAtlas();
    }
  });

  // Focus trap inside overlay
  overlay.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key !== 'Tab') return;
    const focusable = overlay.querySelectorAll<HTMLElement>(
      'button, a, [tabindex="0"]'
    );
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (e.shiftKey) {
      if (document.activeElement === first) { e.preventDefault(); last.focus(); }
    } else {
      if (document.activeElement === last) { e.preventDefault(); first.focus(); }
    }
  });
</script>
