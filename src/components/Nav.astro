---
interface Props {
  pathname: string;
}

const { pathname } = Astro.props;
const norm = pathname.replace(/\/$/, '') || '/';

const collectionActive = norm === '/collection' || norm.startsWith('/collection/');
const aboutActive = norm === '/about' || norm.startsWith('/about/');
---

<!--
  Skip link: WCAG 2.4.1 — allows keyboard users to bypass navigation.
  Visually hidden until focused (styled in global.css .skip-link).
-->
<a href="#main-content" class="skip-link">Skip to content</a>

<nav class="site-nav" aria-label="Site navigation">
  <a href="/" class="nav-logo" aria-label="Dai Pan — Three Worlds (return to home)">Dai Pan</a>
  <div class="nav-right">
    <a
      href="/collection"
      class:list={['nav-link', 'nav-link--collection', { 'is-active': collectionActive }]}
      aria-current={collectionActive ? 'page' : undefined}
    >Collection</a>
    <a
      href="/about"
      class:list={['nav-link', { 'is-active': aboutActive }]}
      aria-current={aboutActive ? 'page' : undefined}
    >About</a>
  </div>
</nav>

<style is:global>
  .site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--site-nav-height);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--margin-x);
    background: var(--color-bg, #f8f7f4);
    border-bottom: 0.5px solid color-mix(in srgb, var(--color-primary, #1a1a1a) 12%, transparent);
    z-index: 100;
    font-family: Georgia, 'Times New Roman', serif;
    box-sizing: border-box;
  }

  .nav-logo {
    font-size: 19px;
    font-weight: normal;
    text-decoration: none;
    color: var(--color-primary, #1a1a1a);
    letter-spacing: 0.01em;
    opacity: 1;
  }

  .nav-right {
    display: flex;
    gap: var(--space-lg);
    align-items: center;
  }

  .nav-link {
    font-size: 14px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-primary, #1a1a1a);
    opacity: 1;
    text-decoration-color: var(--ui-wavy-color, currentColor);
    transition: opacity 0.2s linear, color 0.2s linear, text-decoration 0.2s linear;
    /* Minimum touch target: pad out to at least 44px tall (WCAG 2.5.5) */
    padding-block: 15px;
  }

  .nav-link.is-active {
    text-decoration: underline;
    text-decoration-style: solid;
    text-underline-offset: 3px;
  }

  .nav-link:hover {
    text-decoration: underline;
    text-decoration-style: wavy;
    text-decoration-color: var(--ui-wavy-color, currentColor);
    text-underline-offset: 4px;
  }

  @media (max-width: 760px) {
    .site-nav {
      align-items: center;
      padding-inline: var(--margin-x);
      padding-top: var(--safe-top, 0px);
      border-bottom-color: color-mix(in srgb, var(--color-primary, #1a1a1a) 10%, transparent);
    }

    .nav-logo {
      display: flex;
      align-items: center;
      min-height: 60px;
      font-size: 19px;
      letter-spacing: 0;
      color: color-mix(in srgb, var(--color-primary, #1a1a1a) 84%, var(--color-meta, #595959));
    }

    .nav-right {
      flex-direction: row;
      justify-content: flex-end;
      align-items: center;
      gap: 0;
      min-height: 60px;
    }

    .nav-link--collection {
      display: none !important;
    }

    .nav-link {
      display: inline-flex;
      align-items: center;
      justify-content: flex-end;
      min-width: 86px;
      min-height: 48px;
      padding: 0 0 0 14px;
      font-size: 19px;
      line-height: 1;
      letter-spacing: 0.01em;
      text-transform: none;
      color: color-mix(in srgb, var(--color-primary, #1a1a1a) 84%, var(--color-meta, #595959));
    }
  }
</style>

<script>
  const waveColors = ['#c0392b', '#9b7b8b', '#6f876f', '#806637', '#5e6e80', '#8b4f45'];
  function setRandomWaveColor(el) {
    const color = waveColors[Math.floor(Math.random() * waveColors.length)];
    el.style.setProperty('--ui-wavy-color', color);
  }

  document.querySelectorAll('.nav-link').forEach((el) => {
    el.addEventListener('pointerenter', () => setRandomWaveColor(el));
    el.addEventListener('focus', () => setRandomWaveColor(el));
  });
</script>
