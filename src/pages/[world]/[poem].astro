---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PoemCanvas from '../../components/PoemCanvas.astro';
import IndexMenu from '../../components/IndexMenu.astro';
import { loadPoemsByWorldForIndexMenu } from '../../lib/index-menu-data';
import { analyzePoemText, computeEmotionScore } from '../../lib/poem-analyzer';
import { excerptWords } from '../../lib/seo';

type World = 'their-world' | 'bless-you' | 'still-life';

export async function getStaticPaths() {
  const worlds: readonly World[] = ['their-world', 'bless-you', 'still-life'];
  const poemsByWorld = await loadPoemsByWorldForIndexMenu();

  const byWorld: Record<World, CollectionEntry<World>[]> = {
    'their-world': [],
    'bless-you': [],
    'still-life': [],
  };

  for (const world of worlds) {
    const list = await getCollection(world);
    byWorld[world] = [...list].sort((a, b) => a.data.order - b.data.order);
  }

  const paths = [];

  for (const world of worlds) {
    for (const poem of byWorld[world]) {
      paths.push({
        params: { world, poem: poem.id },
        props: {
          poem,
          world,
          poemsByWorld,
        },
      });
    }
  }

  return paths;
}

const { poem, world, poemsByWorld } = Astro.props;
const rawText = poem.body ?? '';
const analysis = analyzePoemText(rawText, poem.data.title);
const currentEmotionScore = Math.round(computeEmotionScore(analysis.metrics) * 1000) / 1000;
const metaDescription = excerptWords(rawText, 30) || poem.data.title;

// Build stanzas for SSR static rendering (SEO + screen readers)
const seoStanzas = rawText
  .split(/\n\s*\n/)
  .map((s) => s.split('\n').map((l) => l.trimEnd()).filter((l) => l.length > 0))
  .filter((s) => s.length > 0);

const worldLabels: Record<string, string> = {
  'their-world': 'Their World',
  'bless-you': 'Bless You',
  'still-life': 'Still Life',
};
---

<BaseLayout
  world={world}
  title={poem.data.title}
  description={metaDescription}
  poem={{
    id: poem.id,
    world,
    order: poem.data.order,
    firstLine: poem.data.firstLine,
    rawText,
  }}
>
  <main class="poem-shell">
    <nav class="poem-nav" id="poem-nav">
      <a class="nav-prev" id="nav-prev" href="#" aria-label="Previous poem">←</a>
      <a class="nav-next" id="nav-next" href="#" aria-label="Next poem">→</a>
    </nav>

    <!--
      SSR-rendered poem text: visually hidden but fully readable by search engines,
      AI crawlers, and screen readers. The JS layout engine renders a visual version
      on top of this inside PoemCanvas.
    -->
    <article class="poem-seo-text" aria-label={`${poem.data.title} — poem in ${worldLabels[world] ?? world}`}>
      <h1>{poem.data.title}</h1>
      <p class="poem-seo-meta">
        From <em>{worldLabels[world] ?? world}</em> by Dai Pan (潘岱). Poem {poem.data.order}.
      </p>
      {seoStanzas.map((stanza) => (
        <p class="poem-seo-stanza">
          {stanza.map((line, i) => (
            <>
              {line}{i < stanza.length - 1 ? <br /> : null}
            </>
          ))}
        </p>
      ))}
    </article>

    <PoemCanvas
      poemId={poem.id}
      world={world}
      title={poem.data.title}
      rawText={rawText}
      order={poem.data.order}
    />
    <IndexMenu currentWorld={world} currentPoemId={poem.id} poemsByWorld={poemsByWorld} />
  </main>
</BaseLayout>

<script
  define:vars={{
    currentPoemId: poem.id,
    currentWorld: world,
    currentEmotionScore,
  }}
>
  const HISTORY_KEY = 'three-worlds-history';
  const MAX_HISTORY = 20;
  let hideTimer;

  function getHistory() {
    try {
      const raw = localStorage.getItem(HISTORY_KEY);
      return raw ? JSON.parse(raw) : [];
    } catch {
      return [];
    }
  }

  function pushToHistory(entry) {
    try {
      const h = getHistory().filter((x) => x.id !== entry.id);
      h.unshift(entry);
      localStorage.setItem(HISTORY_KEY, JSON.stringify(h.slice(0, MAX_HISTORY)));
    } catch {
      // ignore
    }
  }

  function contentSimilarity(typesA, typesB) {
    if (!typesA.length || !typesB.length) return 0;
    const intersection = typesA.filter((t) => typesB.includes(t)).length;
    const union = new Set([...typesA, ...typesB]).size;
    return intersection / union;
  }

  function getNextPoemId(ctx, allPoems) {
    const current = allPoems.find((p) => p.id === ctx.currentId);
    if (!current) return allPoems[0]?.id ?? ctx.currentId;

    let targetDirection = 'neutral';
    if (ctx.prev2 && ctx.prev1) {
      const risingTwice =
        ctx.prev2.emotionScore < ctx.prev1.emotionScore &&
        ctx.prev1.emotionScore < ctx.currentEmotionScore;
      const fallingTwice =
        ctx.prev2.emotionScore > ctx.prev1.emotionScore &&
        ctx.prev1.emotionScore > ctx.currentEmotionScore;
      if (risingTwice) targetDirection = 'down';
      else if (fallingTwice) targetDirection = 'up';
      else targetDirection = ctx.prev1.emotionScore < ctx.currentEmotionScore ? 'up' : 'down';
    }

    const excludeIds = new Set([ctx.currentId, ctx.prev1?.id, ctx.prev2?.id].filter(Boolean));

    const candidates = allPoems
      .filter((p) => !excludeIds.has(p.id))
      .map((p) => {
        let arcScore = 0.5;
        if (targetDirection === 'up') {
          arcScore = p.emotionScore > ctx.currentEmotionScore ? 1 : 0.2;
        } else if (targetDirection === 'down') {
          arcScore = p.emotionScore < ctx.currentEmotionScore ? 1 : 0.2;
        } else {
          arcScore = 1 - Math.abs(p.emotionScore - ctx.currentEmotionScore);
        }

        const contentScore = contentSimilarity(current.contentTypes || [], p.contentTypes || []);
        const worldScore = p.world !== ctx.currentWorld ? 1 : 0.3;
        const worldPenalty = ctx.prev1 && p.world === ctx.prev1.world ? 0.6 : 1;

        const total = (arcScore * 0.4 + contentScore * 0.35 + worldScore * 0.15 + 0.1) * worldPenalty;

        return { poem: p, score: total };
      });

    candidates.sort((a, b) => b.score - a.score);

    const top5 = candidates.slice(0, 5);
    const idx = Math.floor(Math.random() * top5.length);
    return top5[idx]?.poem.id ?? candidates[0]?.poem.id ?? ctx.currentId;
  }

  function getPrevPoemId(ctx) {
    return ctx.prev1?.id ?? null;
  }

  function bindKeyboard() {
    document.addEventListener('keydown', (e) => {
      if (document.body.classList.contains('index-open')) return;
      const t = e.target;
      if (t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.isContentEditable)) return;
      if (e.key === 'ArrowLeft') {
        document.getElementById('nav-prev')?.click();
      } else if (e.key === 'ArrowRight') {
        document.getElementById('nav-next')?.click();
      }
    });
  }

  function bindNavVisibility() {
    document.addEventListener('mousemove', () => {
      const nav = document.getElementById('poem-nav');
      nav?.classList.add('visible');
      clearTimeout(hideTimer);
      hideTimer = setTimeout(() => {
        nav?.classList.remove('visible');
      }, 2000);
    });
  }

  async function initNav() {
    bindKeyboard();
    bindNavVisibility();

    try {
      const res = await fetch('/poem-data.json');
      const allPoems = await res.json();

      const currentPoem = allPoems.find((p) => p.id === currentPoemId && p.world === currentWorld);
      const emotionScore = currentPoem?.emotionScore ?? currentEmotionScore ?? 0.5;

      pushToHistory({
        id: currentPoemId,
        world: currentWorld,
        emotionScore,
        timestamp: Date.now(),
      });

      const history = getHistory();
      const prev1 = history[1] ?? null;
      const prev2 = history[2] ?? null;

      const ctx = {
        currentId: currentPoemId,
        currentWorld,
        currentEmotionScore: emotionScore,
        prev1,
        prev2,
      };

      const nextId = getNextPoemId(ctx, allPoems);
      const nextPoem = allPoems.find((p) => p.id === nextId);

      const prevId = getPrevPoemId(ctx);
      const prevPoem = prevId ? allPoems.find((p) => p.id === prevId) : null;

      if (nextPoem) {
        const nextEl = document.getElementById('nav-next');
        if (nextEl) nextEl.setAttribute('href', `/${nextPoem.world}/${nextPoem.id}`);
      }

      if (prevPoem) {
        const prevEl = document.getElementById('nav-prev');
        if (prevEl) prevEl.setAttribute('href', `/${prevPoem.world}/${prevPoem.id}`);
      } else {
        const prevEl = document.getElementById('nav-prev');
        if (prevEl) prevEl.style.display = 'none';
      }
    } catch (err) {
      console.error('[dynamic-nav] failed to initialize:', err);
      const prevEl = document.getElementById('nav-prev');
      const nextEl = document.getElementById('nav-next');
      if (prevEl) prevEl.style.display = 'none';
      if (nextEl) nextEl.style.display = 'none';
    }
  }

  document.addEventListener('DOMContentLoaded', initNav);
</script>

<style>
  /*
   * SSR poem text: readable by search bots and screen readers;
   * visually hidden via clip / 0-size technique (not display:none or visibility:hidden,
   * which would suppress from accessibility tree).
   */
  .poem-seo-text {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .poem-shell {
    position: relative;
    /*
     * min-height ensures there's always a viewport-sized canvas.
     * For long poems, JS (layoutBody Phase 4) expands poem-page min-height
     * which naturally pushes the shell taller, keeping the footer below all content.
     */
    min-height: calc(100vh - var(--site-content-offset));
    padding-left: 0;
    padding-right: 0;
    padding-top: var(--space-sm);
    /* Extra bottom padding so the footer never sits flush against poem text */
    padding-bottom: var(--space-xl);
    max-width: none;
    width: 100%;
    margin: 0;
    background-color: var(--color-bg, #f5f2ed);
    /* Contain absolutely-positioned children (poem-seo-text) within this box */
    overflow: visible;
  }

  .poem-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    pointer-events: none;
    z-index: 40;
  }

  .nav-prev,
  .nav-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    font-size: 32px;
    line-height: 1;
    font-family: Georgia, serif;
    text-decoration: none;
    color: var(--color-primary, #1a1a1a);
    opacity: 0;
    transition: opacity 0.2s ease;
    pointer-events: all;
    /* Minimum 44×44 touch target (WCAG 2.5.5) */
    padding: var(--space-md);
    min-width: 44px;
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    user-select: none;
  }

  .nav-prev {
    left: var(--space-md);
  }

  .nav-next {
    right: var(--space-md);
  }

  .poem-nav.visible .nav-prev,
  .poem-nav.visible .nav-next {
    opacity: 0.5;
  }

  .nav-prev:hover,
  .nav-next:hover {
    opacity: 1 !important;
  }

  /* WCAG 2.4.7: Visible focus indicator for keyboard users */
  .nav-prev:focus-visible,
  .nav-next:focus-visible {
    opacity: 1 !important;
    outline: 2px solid var(--color-accent, #c0392b);
    outline-offset: 4px;
    border-radius: 2px;
  }
</style>
