---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { publication, worldMetadata, worldOrder } from '../lib/publication';

const collectionDescription =
  'Three Worlds — an ongoing poetry collection by Dai Pan (潘岱). Publication record: affective volumes, poem count, edition history, citation format, and copyright.';

const poemCounts = Object.fromEntries(
  await Promise.all(
    worldOrder.map(async (world) => {
      const poems = await getCollection(world);
      return [world, poems.length] as const;
    }),
  ),
) as Record<(typeof worldOrder)[number], number>;

const breadcrumbs = [
  { name: 'Three Worlds', url: 'https://daipan.ink/' },
  { name: 'Collection', url: 'https://daipan.ink/collection' },
];
---

<BaseLayout title="Collection" description={collectionDescription} breadcrumbs={breadcrumbs}>
  <main class="reading-page collection-page">

    <!-- ── Colophon / Publication Record ───────────────────────────────────── -->
    <header class="collection-masthead">
      <h1 class="collection-title">{publication.collectionTitle}</h1>
      <p class="collection-subtitle">Still Life · Bless You · Their World</p>
    </header>

    <section class="colophon" aria-label="Publication record">
      <dl class="colophon-grid">
        <div class="colophon-row">
          <dt>Collection</dt>
          <dd>{publication.collectionTitle} ({publication.collectionChineseTitle})</dd>
        </div>
        <div class="colophon-row">
          <dt>Author</dt>
          <dd>
            {publication.authorName} <span class="colophon-zh">{publication.authorChineseName}</span>
            <span class="colophon-aliases">also indexed as Pan Dai / PANDAI / daipan</span>
          </dd>
        </div>
        <div class="colophon-row">
          <dt>Written</dt>
          <dd>{publication.writtenRangeLabel}</dd>
        </div>
        <div class="colophon-row">
          <dt>Digital edition</dt>
          <dd>{publication.digitalEditionLabel}</dd>
        </div>
        <div class="colophon-row">
          <dt>Version</dt>
          <dd>{publication.versionLabel}</dd>
        </div>
        <div class="colophon-row">
          <dt>Language</dt>
          <dd>{publication.language}</dd>
        </div>
        <div class="colophon-row mobile-secondary-row">
          <dt>License</dt>
          <dd>{publication.license}</dd>
        </div>
        <div class="colophon-row">
          <dt>Contact</dt>
          <dd><a href={publication.visualArtUrl} target="_blank" rel="noopener noreferrer">daipan.art</a></dd>
        </div>
        <div class="colophon-row mobile-secondary-row">
          <dt>Site relation</dt>
          <dd>
            daipan.ink is the poetry and digital edition site; daipan.art is the visual art site by
            the same author, Dai Pan (潘岱).
          </dd>
        </div>
      </dl>
    </section>

    <!-- ── Volumes ─────────────────────────────────────────────────────────── -->
    <section class="colophon-volumes" aria-label="Volumes">
      <h2 class="colophon-section-label">Volumes</h2>
      <ol class="volume-list">
        <li class="volume-item">
          <div class="volume-link" aria-label="Their World volume">
            <span class="volume-roman">I</span>
            <span class="volume-info">
                <span class="volume-name">{worldMetadata['their-world'].label}</span>
                <span class="volume-meta">{poemCounts['their-world']} poems · {worldMetadata['their-world'].register}</span>
            </span>
          </div>
        </li>
        <li class="volume-item">
          <div class="volume-link" aria-label="Bless You volume">
            <span class="volume-roman">II</span>
            <span class="volume-info">
              <span class="volume-name">{worldMetadata['bless-you'].label}</span>
              <span class="volume-meta">{poemCounts['bless-you']} poems · {worldMetadata['bless-you'].register}</span>
            </span>
          </div>
        </li>
        <li class="volume-item">
          <div class="volume-link" aria-label="Still Life volume">
            <span class="volume-roman">III</span>
            <span class="volume-info">
              <span class="volume-name">{worldMetadata['still-life'].label}</span>
              <span class="volume-meta">{poemCounts['still-life']} poems · {worldMetadata['still-life'].register}</span>
            </span>
          </div>
        </li>
      </ol>
    </section>

    <!-- ── Citation ────────────────────────────────────────────────────────── -->
    <section class="colophon-citation" aria-label="Citation format">
      <h2 class="colophon-section-label">Cite this collection</h2>
      <div class="citation-block">
        <p class="citation-format">
          Dai Pan. <em>Three Worlds</em>. daipan.ink, 2025–.
          <span class="citation-url">{publication.collectionUrl}</span>
        </p>
        <p class="citation-note">
          For individual poems: {publication.individualCitationTemplate}
        </p>
      </div>
    </section>

    <section class="collection-mobile-note" aria-label="Mobile editorial note">
      <h2 class="colophon-section-label">Editorial frame</h2>
      <p>
        The three worlds are affective registers rather than geographic divisions:
        interior perception, address, and symbolic exterior.
      </p>
      <p>
        This is an ongoing digital edition, written and updated between 2024 and 2026.
      </p>
    </section>

    <!-- ── Editorial note ──────────────────────────────────────────────────── -->
    <section class="reading-prose collection-note mobile-secondary-section" aria-label="Editorial note">
      <h2 class="colophon-section-label">Note</h2>
      <p>
        Begun in 2024 and continuing through 2026, this collection emerged from a period of quiet
        withdrawal and has since become an ongoing digital record. Communication grew sparse, and
        something harder to name grew in its place: introspection, narrative reconfiguration, and
        an emotional intensity that had nowhere else to go.
      </p>
      <p>
        Dai Pan was born in Jiangsu, formed in Shanghai and New York. He has since lived across
        cities that never quite became home — which is not rootlessness, but a particular way of
        seeing: from the edges, in transit, between. <em>Three Worlds</em> holds that displacement
        without resolving it.
      </p>
      <p>
        The three volumes — <em>Still Life</em>, <em>Bless You</em>, and <em>Their World</em> —
        are not geographic divisions. They correspond to three affective registers: the internal
        world colored by intuition and perception; the address toward others, collapsing love and
        belief and grief into a single 'you'; and the symbolic exterior, the mechanical world that
        disfigures and defines us. These worlds are porous and overlapping, the way memory actually
        moves.
      </p>
      <p>
        Writing, for this author, becomes a way of circling the unreachable present. These poems
        do not capture reality; they return to it again and again, from different angles, hoping
        to touch a vanishing future. You are invited not to arrive at any answer, but to lose
        yourself in the memory.
      </p>
      <div class="reading-copyright-block">
        <p>
          All poems collected in <em>Three Worlds</em> are the original work of Dai Pan (潘岱)
          and are protected under copyright. No part of this collection may be reproduced,
          distributed, or transmitted in any form without the prior written permission of the
          author. This digital collection is maintained as an ongoing edition. For permissions and
          inquiries, visit daipan.art.
        </p>
      </div>
    </section>

  </main>
</BaseLayout>

<script>
  if (window.matchMedia('(max-width: 760px)').matches) {
    window.location.replace('/about');
  }
</script>

<style>
  .collection-page {
    max-width: min(68ch, 100%);
  }

  /* ── Masthead ───────────────────────────────────────────────────────────── */
  .collection-masthead {
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid rgba(26, 26, 26, 0.12);
  }

  .collection-title {
    margin: 0 0 var(--space-sm);
    font-size: var(--type-display);
    line-height: var(--leading-display);
    font-weight: normal;
    letter-spacing: -0.01em;
  }

  .collection-subtitle {
    margin: 0;
    font-size: var(--type-body);
    color: var(--color-meta, #595959);
    letter-spacing: 0.06em;
  }

  /* ── Colophon grid ──────────────────────────────────────────────────────── */
  .colophon {
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-xl);
    border-bottom: 0.5px solid rgba(26, 26, 26, 0.08);
  }

  .colophon-grid {
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 9rem 1fr;
    row-gap: 0;
  }

  .colophon-row {
    display: contents;
  }

  .colophon-grid dt,
  .colophon-grid dd {
    margin: 0;
    padding: var(--space-sm) 0;
    font-size: calc(var(--type-body) - 1px);
    line-height: var(--leading-body);
    border-bottom: 0.5px solid rgba(26, 26, 26, 0.06);
  }

  .colophon-grid dt {
    color: var(--color-meta, #595959);
    font-size: 13px;
    letter-spacing: 0.06em;
    padding-right: var(--space-md);
    align-self: baseline;
  }

  .colophon-grid dd {
    color: var(--color-primary, #1a1a1a);
  }

  .colophon-grid a {
    color: inherit;
    text-underline-offset: 3px;
    transition: color 0.18s ease;
  }

  .colophon-grid a:hover {
    color: var(--color-accent, #c0392b);
  }

  .colophon-zh {
    margin-left: var(--space-sm);
    color: var(--color-meta, #595959);
    font-size: 13px;
  }

  .colophon-aliases {
    display: block;
    margin-top: 0.15rem;
    color: var(--color-meta, #595959);
    font-size: 13px;
    line-height: 1.45;
  }

  /* ── Section label ──────────────────────────────────────────────────────── */
  .colophon-section-label {
    margin: 0 0 var(--space-md);
    font-size: 13px;
    font-weight: normal;
    letter-spacing: 0.1em;
    color: var(--color-accent, #c0392b);
  }

  /* ── Volumes ────────────────────────────────────────────────────────────── */
  .colophon-volumes {
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-xl);
    border-bottom: 0.5px solid rgba(26, 26, 26, 0.08);
  }

  .volume-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .volume-item {
    border-bottom: 0.5px solid rgba(26, 26, 26, 0.06);
  }

  .volume-link {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    text-decoration: none;
    color: inherit;
    padding: var(--space-md) 0;
  }

  .volume-roman {
    font-size: calc(var(--type-body) + 2px);
    color: var(--color-meta, #595959);
    min-width: 1.5rem;
    font-variant-numeric: tabular-nums;
  }

  .volume-info {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .volume-name {
    font-size: calc(var(--type-body) + 4px);
    font-weight: normal;
    line-height: 1.2;
  }

  .volume-meta {
    font-size: 13px;
    color: var(--color-meta, #595959);
    letter-spacing: 0.04em;
  }

  /* ── Citation ───────────────────────────────────────────────────────────── */
  .colophon-citation {
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-xl);
    border-bottom: 0.5px solid rgba(26, 26, 26, 0.08);
  }

  .citation-block {
    background: rgba(26, 26, 26, 0.03);
    border-left: 2px solid var(--color-accent, #c0392b);
    padding: var(--space-md) var(--space-lg);
  }

  .citation-format {
    margin: 0 0 var(--space-sm);
    font-size: calc(var(--type-body) - 1px);
    line-height: 1.6;
    color: var(--color-primary, #1a1a1a);
  }

  .citation-url {
    display: block;
    font-size: 13px;
    color: var(--color-meta, #595959);
    margin-top: 0.2rem;
    word-break: break-all;
  }

  .citation-note {
    margin: 0;
    font-size: 13px;
    color: var(--color-meta, #595959);
    line-height: 1.55;
  }

  /* ── Editorial note ─────────────────────────────────────────────────────── */
  .collection-note {
    /* inherits .reading-prose from global.css */
  }

  .collection-mobile-note {
    display: none;
  }

  @media (max-width: 760px) {
    .collection-page {
      max-width: 100%;
    }

    .collection-masthead {
      margin-bottom: var(--space-md);
      padding-bottom: var(--space-md);
    }

    .collection-title {
      font-size: clamp(44px, 15vw, 66px);
      line-height: 0.94;
      letter-spacing: -0.045em;
    }

    .collection-subtitle {
      font-size: 16px;
      line-height: 1.45;
    }

    .colophon {
      margin-bottom: var(--space-md);
      padding-bottom: var(--space-md);
    }

    .collection-note {
      display: none !important;
    }

    .mobile-secondary-row,
    .colophon-aliases {
      display: none !important;
    }

    .colophon-grid {
      display: block;
    }

    .colophon-row {
      display: block;
      padding: 10px 0;
      border-bottom: 0.5px solid rgba(26, 26, 26, 0.08);
    }

    .colophon-grid dt,
    .colophon-grid dd {
      display: block;
      padding: 0;
      border-bottom: 0;
    }

    .colophon-grid dt {
      margin-bottom: 3px;
      font-size: 11.5px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .colophon-grid dd {
      font-size: 17px;
      line-height: 1.42;
    }

    .colophon-zh,
    .colophon-aliases,
    .volume-meta,
    .citation-note,
    .citation-url {
      font-size: 12.5px;
    }

    .colophon-volumes,
    .colophon-citation {
      margin-bottom: var(--space-md);
      padding-bottom: var(--space-md);
    }

    .volume-link {
      align-items: flex-start;
      gap: 14px;
      padding: 11px 0;
      transition: none;
    }

    .volume-name {
      font-size: 20px;
      line-height: 1.16;
    }

    .citation-block {
      padding: 13px 15px;
    }

    .citation-format {
      margin-bottom: 7px;
      font-size: 16px;
      line-height: 1.48;
    }

    .citation-note {
      line-height: 1.42;
    }

    .collection-mobile-note {
      display: block;
      margin-bottom: var(--space-md);
      padding-bottom: var(--space-md);
      border-bottom: 0.5px solid rgba(26, 26, 26, 0.08);
    }

    .collection-mobile-note p {
      margin: 0 0 10px;
      color: var(--color-primary, #1a1a1a);
      font-size: 16.5px;
      line-height: 1.55;
    }

    .collection-mobile-note p:last-child {
      margin-bottom: 0;
    }
  }
</style>
