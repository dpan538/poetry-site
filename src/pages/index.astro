---
import BaseLayout from '../layouts/BaseLayout.astro';
import PoemCanvas from '../components/PoemCanvas.astro';
import IndexMenu from '../components/IndexMenu.astro';
import { getCollection } from 'astro:content';
import { loadPoemsByWorldForIndexMenu } from '../lib/index-menu-data';
import { analyzePoemText, computeEmotionScore } from '../lib/poem-analyzer';

const poemsByWorld = await loadPoemsByWorldForIndexMenu();

// Entry poem: first of their-world (stable — not random, so crawlers index a consistent page)
const list = await getCollection('their-world');
const sorted = [...list].sort((a, b) => a.data.order - b.data.order);
const poem = sorted[0];

if (!poem) {
  throw new Error('No poems in their-world collection');
}

const entryPoem = poem;
const entryWorld = 'their-world' as const;
const rawText = entryPoem.body ?? '';
const analysis = analyzePoemText(rawText, entryPoem.data.title);
const currentEmotionScore = Math.round(computeEmotionScore(analysis.metrics) * 1000) / 1000;

// Stable site-level description — not derived from a random poem
const siteDescription =
  'Three Worlds is a poetry collection by Dai Pan (潘岱) across three volumes: Still Life, Bless You, and Their World. Written 2024–2025, published as a digital first edition on daipan.ink.';
---

<BaseLayout
  title="Three Worlds"
  description={siteDescription}
  world="their-world"
>
  <!--
    SEO anchor for the home page: gives Google a clear, stable h1 that matches
    the <title> "Three Worlds — Dai Pan". Without this, Google sees the visually
    prominent poem title in PoemCanvas and rewrites the title to match it.
    Uses the same clip-rect invisible technique as .poem-seo-text (accessible
    to screen readers and crawlers, invisible to sighted users).
  -->
  <div class="home-seo-anchor">
    <h1>Three Worlds — A Poetry Collection by Dai Pan</h1>
    <p>
      Three Worlds (daipan.ink) is the debut poetry collection by Dai Pan (潘岱, also written Pan Dai),
      a visual artist and poet based in Brisbane. The collection is organized into three volumes —
      Still Life, Bless You, and Their World — written between 2024 and spring 2025.
    </p>
    <p>
      Enter the collection at <a href="/collection">/collection</a>, read the preface at
      <a href="/preface">/preface</a>, or navigate directly to a world:
      <a href="/their-world">Their World</a>, <a href="/bless-you">Bless You</a>,
      <a href="/still-life">Still Life</a>.
    </p>
  </div>

  <main class="home-main">
    <nav class="poem-nav" id="poem-nav">
      <a class="nav-prev" id="nav-prev" href="#" aria-label="Previous poem">←</a>
      <a class="nav-next" id="nav-next" href="#" aria-label="Next poem">→</a>
    </nav>

    <div class="entry-shell">
      <PoemCanvas
        poemId={entryPoem.id}
        world={entryWorld}
        title={entryPoem.data.title}
        rawText={rawText}
        order={entryPoem.data.order}
      />
    </div>
    <IndexMenu currentWorld="their-world" currentPoemId={entryPoem.id} poemsByWorld={poemsByWorld} />
  </main>
</BaseLayout>

<script
  define:vars={{
    currentPoemId: entryPoem.id,
    currentWorld: entryWorld,
    currentEmotionScore,
  }}
>
  const HISTORY_KEY = 'three-worlds-history';
  const MAX_HISTORY = 20;
  let hideTimer;

  function getHistory() {
    try {
      const raw = localStorage.getItem(HISTORY_KEY);
      return raw ? JSON.parse(raw) : [];
    } catch {
      return [];
    }
  }

  function pushToHistory(entry) {
    try {
      const h = getHistory().filter((x) => x.id !== entry.id);
      h.unshift(entry);
      localStorage.setItem(HISTORY_KEY, JSON.stringify(h.slice(0, MAX_HISTORY)));
    } catch {
      // ignore
    }
  }

  function contentSimilarity(typesA, typesB) {
    if (!typesA.length || !typesB.length) return 0;
    const intersection = typesA.filter((t) => typesB.includes(t)).length;
    const union = new Set([...typesA, ...typesB]).size;
    return intersection / union;
  }

  function getNextPoemId(ctx, allPoems) {
    const current = allPoems.find((p) => p.id === ctx.currentId);
    if (!current) return allPoems[0]?.id ?? ctx.currentId;

    let targetDirection = 'neutral';
    if (ctx.prev2 && ctx.prev1) {
      const risingTwice =
        ctx.prev2.emotionScore < ctx.prev1.emotionScore &&
        ctx.prev1.emotionScore < ctx.currentEmotionScore;
      const fallingTwice =
        ctx.prev2.emotionScore > ctx.prev1.emotionScore &&
        ctx.prev1.emotionScore > ctx.currentEmotionScore;
      if (risingTwice) targetDirection = 'down';
      else if (fallingTwice) targetDirection = 'up';
      else targetDirection = ctx.prev1.emotionScore < ctx.currentEmotionScore ? 'up' : 'down';
    }

    const excludeIds = new Set([ctx.currentId, ctx.prev1?.id, ctx.prev2?.id].filter(Boolean));

    const candidates = allPoems
      .filter((p) => !excludeIds.has(p.id))
      .map((p) => {
        let arcScore = 0.5;
        if (targetDirection === 'up') {
          arcScore = p.emotionScore > ctx.currentEmotionScore ? 1 : 0.2;
        } else if (targetDirection === 'down') {
          arcScore = p.emotionScore < ctx.currentEmotionScore ? 1 : 0.2;
        } else {
          arcScore = 1 - Math.abs(p.emotionScore - ctx.currentEmotionScore);
        }

        const contentScore = contentSimilarity(current.contentTypes || [], p.contentTypes || []);
        const worldScore = p.world !== ctx.currentWorld ? 1 : 0.3;
        const worldPenalty = ctx.prev1 && p.world === ctx.prev1.world ? 0.6 : 1;

        const total = (arcScore * 0.4 + contentScore * 0.35 + worldScore * 0.15 + 0.1) * worldPenalty;

        return { poem: p, score: total };
      });

    candidates.sort((a, b) => b.score - a.score);

    const top5 = candidates.slice(0, 5);
    const idx = Math.floor(Math.random() * top5.length);
    return top5[idx]?.poem.id ?? candidates[0]?.poem.id ?? ctx.currentId;
  }

  function getPrevPoemId(ctx) {
    return ctx.prev1?.id ?? null;
  }

  function bindKeyboard() {
    document.addEventListener('keydown', (e) => {
      if (document.body.classList.contains('index-open')) return;
      const t = e.target;
      if (t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.isContentEditable)) return;
      if (e.key === 'ArrowLeft') {
        document.getElementById('nav-prev')?.click();
      } else if (e.key === 'ArrowRight') {
        document.getElementById('nav-next')?.click();
      }
    });
  }

  function bindNavVisibility() {
    document.addEventListener('mousemove', () => {
      const nav = document.getElementById('poem-nav');
      nav?.classList.add('visible');
      clearTimeout(hideTimer);
      hideTimer = setTimeout(() => {
        nav?.classList.remove('visible');
      }, 2000);
    });
  }

  async function initNav() {
    bindKeyboard();
    bindNavVisibility();

    try {
      const res = await fetch('/poem-data.json');
      const allPoems = await res.json();

      const currentPoem = allPoems.find((p) => p.id === currentPoemId && p.world === currentWorld);
      const emotionScore = currentPoem?.emotionScore ?? currentEmotionScore ?? 0.5;

      pushToHistory({
        id: currentPoemId,
        world: currentWorld,
        emotionScore,
        timestamp: Date.now(),
      });

      const history = getHistory();
      const prev1 = history[1] ?? null;
      const prev2 = history[2] ?? null;

      const ctx = {
        currentId: currentPoemId,
        currentWorld,
        currentEmotionScore: emotionScore,
        prev1,
        prev2,
      };

      const nextId = getNextPoemId(ctx, allPoems);
      const nextPoem = allPoems.find((p) => p.id === nextId);

      const prevId = getPrevPoemId(ctx);
      const prevPoem = prevId ? allPoems.find((p) => p.id === prevId) : null;

      if (nextPoem) {
        const nextEl = document.getElementById('nav-next');
        if (nextEl) nextEl.setAttribute('href', `/${nextPoem.world}/${nextPoem.id}`);
      }

      if (prevPoem) {
        const prevEl = document.getElementById('nav-prev');
        if (prevEl) prevEl.setAttribute('href', `/${prevPoem.world}/${prevPoem.id}`);
      } else {
        const prevEl = document.getElementById('nav-prev');
        if (prevEl) prevEl.style.display = 'none';
      }
    } catch (err) {
      console.error('[dynamic-nav] failed to initialize:', err);
      const prevEl = document.getElementById('nav-prev');
      const nextEl = document.getElementById('nav-next');
      if (prevEl) prevEl.style.display = 'none';
      if (nextEl) nextEl.style.display = 'none';
    }
  }

  document.addEventListener('DOMContentLoaded', initNav);
</script>

<style>
  /*
   * SEO anchor: crawlable by search engines and screen readers,
   * invisible to sighted users (clip-rect technique, not display:none).
   */
  .home-seo-anchor {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .home-main {
    padding-left: 0;
    padding-right: 0;
    padding-bottom: 0;
    max-width: none;
    width: 100%;
    margin: 0;
    position: relative;
  }

  .entry-shell {
    min-height: calc(100vh - var(--site-content-offset));
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-lg) var(--margin-x);
    box-sizing: border-box;
  }

  .poem-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    pointer-events: none;
    z-index: 40;
  }

  .nav-prev,
  .nav-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    font-size: 32px;
    line-height: 1;
    font-family: Georgia, serif;
    text-decoration: none;
    color: var(--color-primary, #1a1a1a);
    opacity: 0;
    transition: opacity 0.2s ease;
    pointer-events: all;
    padding: var(--space-md);
    user-select: none;
  }

  .nav-prev {
    left: var(--space-md);
  }

  .nav-next {
    right: var(--space-md);
  }

  .poem-nav.visible .nav-prev,
  .poem-nav.visible .nav-next {
    opacity: 0.5;
  }

  .nav-prev:hover,
  .nav-next:hover {
    opacity: 1 !important;
  }
</style>
