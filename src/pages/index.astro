---
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadPoemsByWorldForIndexMenu } from '../lib/index-menu-data';
import type { IndexWorld } from '../lib/index-menu-data';
import { publication } from '../lib/publication';

const poemsByWorld = await loadPoemsByWorldForIndexMenu();
type PoemsByWorld = Awaited<ReturnType<typeof loadPoemsByWorldForIndexMenu>>;

const entryPoems = (
  Object.entries(poemsByWorld) as [IndexWorld, PoemsByWorld[IndexWorld]][]
).flatMap(([world, poems]) =>
  poems.map((poem) => ({
    id: poem.id,
    title: poem.title,
    world,
  }))
);

if (!entryPoems.length) {
  throw new Error('No poems available for the collection entry page');
}

// Stable site-level description: the root URL is now an entry point, not a poem page.
const siteDescription =
  `${publication.collectionTitle} is an ongoing poetry collection by ${publication.authorDisplayName} across three affective volumes: Still Life, Bless You, and Their World. Written and updated ${publication.copyrightYears}, published as a digital edition on daipan.ink.`;
---

<BaseLayout title="Three Worlds" description={siteDescription}>
  <!--
    SEO anchor for the home page: gives crawlers and assistive tech a stable
    description while the visible root page behaves as a collection entry.
  -->
  <div class="home-seo-anchor">
    <h1>Three Worlds — A Poetry Collection by Dai Pan</h1>
    <p>
      Three Worlds (daipan.ink) is the debut poetry collection by Dai Pan (潘岱, also written Pan Dai),
      a visual artist and poet based in Brisbane. The collection is organized into three affective
      volumes — Still Life, Bless You, and Their World — written and updated between 2024 and 2026.
    </p>
    <p>
      Enter the collection at <a href="/collection">/collection</a>, read the preface at
      <a href="/preface">/preface</a>, or navigate directly to a world:
      <a href="/their-world">Their World</a>, <a href="/bless-you">Bless You</a>,
      <a href="/still-life">Still Life</a>.
    </p>
  </div>

  <main class="home-entry" aria-labelledby="home-entry-title">
    <section class="entry-card" aria-live="polite">
      <p class="entry-kicker">Three Worlds</p>
      <h1 id="home-entry-title">Entering the collection</h1>
      <p class="entry-copy">
        Opening a different poem each time, then continuing through the collection from that page.
      </p>
      <p class="entry-fallback">
        If nothing opens, <a href="/collection">browse the collection index</a>.
      </p>
      <noscript>
        JavaScript is needed for the rotating entry. You can still
        <a href="/collection">browse the collection index</a>.
      </noscript>
    </section>
  </main>
</BaseLayout>

<script define:vars={{ entryPoems }}>
  const ENTRY_LAST_KEY = 'three-worlds-entry-last';
  const HISTORY_KEY = 'three-worlds-history';
  const RECENT_LIMIT = 4;

  function readRecentIds() {
    try {
      const raw = localStorage.getItem(HISTORY_KEY);
      const history = raw ? JSON.parse(raw) : [];
      if (!Array.isArray(history)) return [];
      return history
        .map((entry) => entry?.id)
        .filter((id) => typeof id === 'string')
        .slice(0, RECENT_LIMIT);
    } catch {
      return [];
    }
  }

  function pickEntryPoem(poems) {
    const lastId = localStorage.getItem(ENTRY_LAST_KEY);
    const recentIds = new Set([lastId, ...readRecentIds()].filter(Boolean));
    let pool = poems.filter((poem) => !recentIds.has(poem.id));

    if (!pool.length && lastId) {
      pool = poems.filter((poem) => poem.id !== lastId);
    }

    if (!pool.length) {
      pool = poems;
    }

    return pool[Math.floor(Math.random() * pool.length)];
  }

  function enterCollection() {
    if (!Array.isArray(entryPoems) || !entryPoems.length) return;

    const poem = pickEntryPoem(entryPoems);
    if (!poem?.world || !poem?.id) return;

    try {
      localStorage.setItem(ENTRY_LAST_KEY, poem.id);
    } catch {
      // The entry should still work when storage is unavailable.
    }

    window.location.replace(`/${poem.world}/${poem.id}`);
  }

  enterCollection();
</script>

<style>
  /*
   * SEO anchor: crawlable by search engines and screen readers,
   * invisible to sighted users (clip-rect technique, not display:none).
   */
  .home-seo-anchor {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .home-entry {
    min-height: calc(100vh - var(--site-content-offset));
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-xl) var(--margin-x);
    box-sizing: border-box;
  }

  .entry-card {
    max-width: 42rem;
    text-align: center;
    font-family: Georgia, 'Times New Roman', serif;
    color: var(--color-primary, #1a1a1a);
  }

  .entry-kicker {
    margin: 0 0 var(--space-md);
    font-size: 12px;
    line-height: 1.4;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .entry-card h1 {
    margin: 0;
    font-size: clamp(34px, 6vw, 78px);
    line-height: 0.95;
    font-weight: 500;
    letter-spacing: -0.04em;
  }

  .entry-copy {
    margin: var(--space-lg) auto 0;
    max-width: 32rem;
    font-size: clamp(17px, 2vw, 22px);
    line-height: 1.55;
    font-style: italic;
    color: var(--color-meta, #595959);
  }

  .entry-fallback,
  noscript {
    display: block;
    margin: var(--space-md) auto 0;
    font-size: 13px;
    line-height: 1.6;
    color: var(--color-meta, #777777);
  }

  .entry-fallback a,
  noscript a {
    color: currentColor;
    text-underline-offset: 0.18em;
  }
</style>
